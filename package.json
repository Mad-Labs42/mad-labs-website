{
  "name": "mad-labs-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MAD LABS — computer repair and mobile IT services website",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 4321",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0 --port 4322",
    "preview:dist": "python3 -m http.server 4322 --directory dist --bind 127.0.0.1",
    "check": "astro check",
    "lint": "eslint src tests",
    "test": "pnpm test:source",
    "test:source": "node tests/run-source-tests.mjs",
    "format": "prettier --write src tests package.json eslint.config.js astro.config.mjs",
    "format:check": "prettier --check src tests package.json eslint.config.js astro.config.mjs",
    "ci": "pnpm install && pnpm check && pnpm lint && pnpm test:source && pnpm format:check && pnpm build",
    "deploy": "pnpm build && wrangler pages deploy dist --project-name=mad-labs-website --branch=main",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^5.7.0",
    "moveable": "0.53.0",
    "sharp": "^0.35.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/ts-plugin": "^1.10.0",
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.0",
    "eslint": "^9.23.0",
    "eslint-plugin-astro": "^1.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.0",
    "wrangler": "^4.104.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
