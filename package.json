{
  "name": "mad-labs-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MAD LABS — computer repair and mobile IT services website",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "ci": "pnpm install && pnpm check && pnpm lint && pnpm format:check && pnpm build"
  },
  "dependencies": {
    "astro": "^5.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "typescript": "^5.8.0",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.0",
    "eslint": "^9.23.0",
    "@eslint/js": "^9.23.0",
    "eslint-plugin-astro": "^1.3.0",
    "typescript-eslint": "^8.30.0",
    "@astrojs/ts-plugin": "^1.10.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
