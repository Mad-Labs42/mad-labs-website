# Environment Variables
# Copy this file to .env and fill in your values. Do NOT commit .env to git.

# Site URL (used by Astro for sitemap, canonical URLs)
# PUBLIC_SITE_URL=https://madlabs.example.com

# Cloudflare Turnstile (contact form bot protection)
# Set these in Cloudflare Pages environment variables, NOT in .env for production.
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Notification topic (for contact form submissions)
# NTFY_TOPIC_URL=https://ntfy.sh/your-unique-topic
