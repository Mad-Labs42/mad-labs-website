# ── Environment Variables — MAD LABS ──
# Copy this file to .env and fill in your values. Do NOT commit .env to git.
#
# PUBLIC_* vars are available at build time (Astro server/client).
# Non-PUBLIC vars are only available server-side (Cloudflare Functions).
# Set production values in Cloudflare Pages → Settings → Environment Variables.

# ===== Site =====
# PUBLIC_SITE_URL=https://madlabs.rocks

# ===== Zoho Bookings =====
# ── Primary (preferred) ──
# Direct service-specific booking URLs for the contact tablet.
# Get these from Zoho Bookings → Services → [Select Service] → Embed as Widget
# These bypass the workspace service-picker and send customers straight
# to date/time selection for the specific service.
#
# Free Tech Triage Call (20 min, free):
# URL format: portal-embed + #/<serviceId> hash fragment
# The hash is REQUIRED — Zoho's JS bundle reads it to route to the specific
# service and skip the workspace service-picker screen. Without the hash,
# users see Zoho's generic landing page.
PUBLIC_TRIAGE_BOOKING_EMBED_URL=https://madlabs.zohobookings.com/portal-embed#/4947694000000039045
PUBLIC_TRIAGE_SERVICE_ID=4947694000000039045
#
# Deep-Dive Tech Consultation (60 min, $95):
PUBLIC_CONSULTATION_BOOKING_EMBED_URL=https://madlabs.zohobookings.com/portal-embed#/4947694000000102023
PUBLIC_CONSULT_SERVICE_ID=4947694000000102023
#
# ── Fallback (legacy) ──
# Generic workspace URL — shows Zoho's service-picker page.
# Used automatically when a specific service URL is not configured.
# Ideally remove once both direct URLs are set.
# PUBLIC_BOOKING_EMBED_URL=https://madlabs.zohobookings.com/portal-embed
#
# ===== Analytics =====
PUBLIC_CLARITY_ID=x4385g64yq
# GA4 measurement ID (Admin → Data streams → madlabs.rocks → Measurement ID)
PUBLIC_GA4_MEASUREMENT_ID=G-YXV4NXFYFN
# Optional reference (not used by gtag.js — for agent/MCP docs only):
# GA4_STREAM_NAME=madlabs.rocks
# GA4_STREAM_URL=https://madlabs.rocks
# GA4_STREAM_ID=15051150624

# ===== Zoho Desk Web-to-Case =====
# The ticket form is served as a local static file: public/contact/zoho-ticket-form.html
# No env var required — always available from the same origin.
# To disable the ticket iframe and revert to email fallback:
#   set TICKET_FORM_PATH = "" in ContactTablet.astro frontmatter
#
# The hidden form tokens (xnQsjsdp, xmIwtLD) in zoho-ticket-form.html must be replaced
# with real values from Zoho Desk → Settings → Channels → Web to Case.

# ===== Zoho MCP (AI Agent Integration) =====
# For Hermes to interact with Zoho apps directly via MCP:
#   1. Go to https://mcp.zoho.com → Create MCP Server
#   2. Select tools from: CRM, Desk, Mail, Books, Projects, Calendar, Cliq, Creator
#   3. Complete OAuth
#   4. Copy the Server URL — format:
#      https://[server-name]-[org-id].zohomcp.com/mcp/[api-key]/message
#   5. Set it in ~/.hermes/profiles/madlabs-website/config.yaml under `zoho-mcp`

# ===== Cloudflare Turnstile (future: native form) =====
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ===== Notification (future: form submissions) =====
# NTFY_TOPIC_URL=https://ntfy.sh/your-unique-topic

# ===== Google Analytics 4 (configured in ga4-mcp MCP) =====
# GA4_PROPERTY_ID=
# GA4_CLIENT_EMAIL=
# GA4_PRIVATE_KEY=
