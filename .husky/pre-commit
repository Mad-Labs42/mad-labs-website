#!/bin/bash
# MAD LABS pre-commit hook
# Runs lint + format check before every commit.
# Skip with: git commit --no-verify

echo "🔍 MAD LABS pre-commit check..."

# Run linter
echo "  → pnpm lint..."
if ! pnpm lint; then
  echo "❌ Lint failed. Fix errors before committing."
  echo "   Skip with: git commit --no-verify"
  exit 1
fi

# Run format check
echo "  → pnpm format:check..."
if ! pnpm format:check; then
  echo "⚠️  Format check failed. Run: pnpm format"
  echo "   Skip with: git commit --no-verify"
  exit 1
fi

echo "✅ Pre-commit checks passed."
exit 0
