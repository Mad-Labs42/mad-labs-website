---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Cincinnati Mobile Computer Repair & Practical Tech Support"
  description="Learn about MAD LABS, an independent Cincinnati mobile computer repair and practical tech support lab offering diagnostics, upgrades, and hands-on help across Greater Cincinnati by appointment."
  jsonLdType="about"
>
  <!-- ─── Hero / The Lab ─── -->
  <section class="about-hero lab-section">
    <div class="lab-section-inner-wide">
      <span class="lab-heading-accent">The Lab</span>
      <h1 class="about-heading">
        <span class="about-sub">About</span>
        <span class="about-brand">MAD LABS</span>
      </h1>
      <p class="about-intro">
        MAD LABS is an independent mobile computer repair and diagnostics lab serving Greater
        Cincinnati by appointment. We work on Windows PCs, workstations, and real-world tech
        problems with transparency, skill, and a genuine love for the work.
      </p>
    </div>
  </section>

  <!-- ─── Origin / The Story ─── -->
  <section class="about-story lab-section-alt" aria-labelledby="about-story-heading">
    <div class="lab-section-inner">
      <span class="lab-heading-accent">Origin</span>
      <h2 id="about-story-heading" class="section-heading">The Story</h2>
      <p class="story-text">
        MAD LABS started the same way most good repair shops do: a pile of broken laptops and
        desktops, a deep curiosity about how things work, and frustration with an industry that
        often recommends replacement over repair. What began as fixing friends' and family's
        computers grew into a by-appointment diagnostic lab serving home users, small businesses,
        and creative professionals across Greater Cincinnati.
      </p>
      <p class="story-text">
        There is no walk-in storefront or drop-off counter. The work is mobile, hands-on, and
        practical: a photographer's Windows workstation with years of edits, a small business
        desktop running on borrowed time, a student's only laptop, or a custom PC that needs a
        real diagnostic instead of a guess. We treat each system with the same care: find the real
        problem, explain it clearly, and fix it right.
      </p>
      <p class="story-text">
        That same mindset carries into newer workflow problems too. MAD LABS also spends time with
        WSL-based workflows, local tooling, practical automation, lightweight agents, and websites
        when the job calls for hands-on technical support rather than hype or a giant platform
        project.
      </p>
    </div>
  </section>

  <!-- ─── Approach / How We Work ─── -->
  <section class="about-approach lab-section" aria-labelledby="about-approach-heading">
    <div class="lab-section-inner-wide">
      <span class="lab-heading-accent">Approach</span>
      <h2 id="about-approach-heading" class="section-heading">How We Work</h2>
      <div class="approach-grid">
        <div class="approach-card">
          <span class="approach-step" aria-hidden="true">01</span>
          <h3 class="approach-card-title">Diagnose First</h3>
          <p class="approach-card-text">
            Every repair starts with a full diagnostic. We run hardware and software tests to find
            the root cause — not just treat the symptoms.
          </p>
        </div>
        <div class="approach-card">
          <span class="approach-step" aria-hidden="true">02</span>
          <h3 class="approach-card-title">Explain Clearly</h3>
          <p class="approach-card-text">
            We tell you what's wrong, why it matters, and what your options are. No jargon, no
            upselling, no surprises.
          </p>
        </div>
        <div class="approach-card">
          <span class="approach-step" aria-hidden="true">03</span>
          <h3 class="approach-card-title">Fix with Care</h3>
          <p class="approach-card-text">
            With your approval, we perform the repair using quality components and proven
            techniques. Every device is tested before it goes home.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Trust / Why People Trust MAD LABS ─── -->
  <section class="about-trust lab-section-alt" aria-labelledby="about-trust-heading">
    <div class="lab-section-inner">
      <span class="lab-heading-accent">Trust</span>
      <h2 id="about-trust-heading" class="section-heading">Why People Trust MAD LABS</h2>
      <div class="trust-grid">
        <div class="trust-card">
          <svg
            class="trust-icon"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <g transform="translate(10 10) scale(0.78) translate(-10 -10)">
              <path
                d="M12.25 5.25a0.83 0.83 0 0 0 0 1.17l1.33 1.33a0.83 0.83 0 0 0 1.17 0l2.59-2.59a0.72 0.72 0 0 1 0.82 0.18 5 5 0 0 1-6.88 5.88l-6.59 6.59a0.83 0.83 0 0 1-2.5-2.5l6.59-6.59a5 5 0 0 1 5.88-6.88 0.72 0.72 0 0 1 0.18 0.82z"
              ></path>
            </g>
          </svg>
          <div>
            <strong class="trust-label">Years of hands-on experience</strong>
            <p class="trust-text">
              We work with Windows PCs, WSL-based workflows, hardware upgrades, diagnostics, tuneups,
              troubleshooting, and real-world network problem solving.
            </p>
          </div>
        </div>
        <div class="trust-card">
          <svg
            class="trust-icon"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="10" cy="10" r="7.5"></circle>
            <path d="M7 10.5 9 12.5 13 7.5"></path>
          </svg>
          <div>
            <strong class="trust-label">Diagnostic-first approach</strong>
            <p class="trust-text">
              We find the real problem before we recommend repairs, upgrades, or replacement parts.
            </p>
          </div>
        </div>
        <div class="trust-card">
          <svg
            class="trust-icon"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M10 4.25v11.5"></path>
            <path
              d="M14.15 5.85H8.15a2.9 2.9 0 1 0 0 5.8h4.15a2.9 2.9 0 1 1 0 5.85H6.15"
            ></path>
          </svg>
          <div>
            <strong class="trust-label">Transparent pricing</strong>
            <p class="trust-text">
              We quote the work before we start, explain what is included, and never add hidden fees.
            </p>
          </div>
        </div>
        <div class="trust-card">
          <svg
            class="trust-icon"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="10" cy="10" r="7.5"></circle>
            <path d="M10 6v4.5l3 1.5"></path>
          </svg>
          <div>
            <strong class="trust-label">Fast turnaround when the job allows</strong>
            <p class="trust-text">
              Many common repairs can be handled the same day when parts, scope, and scheduling line
              up, because we know you cannot be without your computer for long.
            </p>
          </div>
        </div>
        <div class="trust-card">
          <svg
            class="trust-icon"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="7" width="14" height="11" rx="1.5"></rect>
            <path d="M6.5 7V5a3.5 3.5 0 0 1 7 0v2"></path>
          </svg>
          <div>
            <strong class="trust-label">Privacy-conscious support</strong>
            <p class="trust-text">
              We handle your system with care, explain data-sensitive steps clearly, and keep
              privacy in mind throughout the repair and support process.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Next Steps / CTA ─── -->
  <section class="about-cta lab-section-alt" aria-labelledby="about-cta-heading">
    <div class="lab-section-inner cta-inner">
      <span class="lab-heading-accent">Next Steps</span>
      <h2 id="about-cta-heading" class="cta-heading">Have a computer that needs attention?</h2>
      <p class="cta-text">
        Tell us what's going on, or take a look at our core repair and support work before you
        reach out.
      </p>
      <div class="cta-actions">
        <a href="/services/" class="lab-button">See Services</a>
        <a href="/contact/" class="cta-secondary-link lab-link">Contact MAD LABS</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Typography ─── */
  .about-heading {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    color: var(--lab-heading);
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .about-sub {
    font-family: "Jersey 25", monospace;
  }

  .about-brand {
    font-family: "Monofett", monospace;
    font-size: 1.15em;
  }

  .about-intro {
    font-family: "Jersey 25", monospace;
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--lab-text);
    max-width: 620px;
    line-height: 1.6;
  }

  .section-heading {
    font-family: "Early GameBoy", "Jersey 25", monospace;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 400;
    color: var(--lab-heading);
    margin-bottom: 1rem;
  }

  /* ─── Story section ─── */
  .about-story {
    position: relative;
  }
  .about-story > * {
    position: relative;
    z-index: 1;
  }
  .about-story::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(232, 144, 80, 0.04) 0%, transparent 70%);
  }
  .about-story .lab-heading-accent {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .about-story .section-heading {
    font-size: clamp(1.875rem, 3.75vw, 2.4375rem);
    margin-bottom: 1.5rem;
  }

  .story-text {
    font-family: "Jersey 25", monospace;
    font-size: clamp(1.35rem, 2.25vw, 1.575rem);
    color: var(--lab-text);
    line-height: 1.6;
    max-width: 780px;
    margin-bottom: 1.5rem;
  }

  .story-text:last-child {
    margin-bottom: 0;
  }

  /* ─── Approach grid ─── */
  .approach-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .approach-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 900px) {
    .approach-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .approach-card {
    background: var(--lab-card, #131325);
    border: calc(1px * 1.05) solid var(--lab-border, rgba(232, 144, 80, 0.12));
    border-left: calc(3px * 1.05) solid var(--divider-orange);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
    isolation: isolate;
    position: relative;
  }
  .approach-card:hover {
    border-color: rgba(232, 144, 80, 0.35);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.35),
      0 0 40px rgba(232, 144, 80, 0.04);
  }

  .approach-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: linear-gradient(
      110deg,
      transparent 25%,
      rgba(232, 144, 80, 0.035) 48%,
      rgba(232, 144, 80, 0.07) 50%,
      rgba(232, 144, 80, 0.035) 52%,
      transparent 75%
    );
    background-size: 200% 100%;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: -1;
  }
  .approach-card:hover::after {
    opacity: 1;
    animation: shimmer 2s ease-in-out infinite;
  }
  .approach-step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 5px;
    border: 2px solid var(--divider-orange);
    border-radius: 6px;
    font-family: "Monofett", monospace;
    font-size: 1.6rem;
    color: var(--divider-orange);
    opacity: 0.85;
    line-height: 1;
  }
  .approach-card-title {
    display: inline-block;
    align-self: flex-start;
    font-family: "Jersey 25", monospace;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--lab-accent, #e89050);
    margin: 1rem 0 0;
  }
  .approach-card-title::after {
    content: "";
    display: block;
    width: 100%;
    height: 3px;
    background: var(--divider-orange);
    border-radius: 2px;
    margin-top: 0.2rem;
  }

  .approach-card-text {
    font-family: "Jersey 25", monospace;
    font-size: 0.9rem;
    color: var(--lab-text, #b0b0c8);
    line-height: 1.5;
    margin: 0;
  }

  /* ─── Trust grid ─── */
  .about-trust {
    position: relative;
  }
  .about-trust > * {
    position: relative;
    z-index: 1;
  }
  .about-trust::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(232, 144, 80, 0.04) 0%, transparent 70%);
  }
  .trust-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .trust-card {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background: var(--lab-card, #131325);
    border: calc(1px * 1.05) solid var(--lab-border, rgba(232, 144, 80, 0.08));
    border-radius: 6px;
    padding: 1rem 1.25rem;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
    isolation: isolate;
    position: relative;
  }
  .trust-card:hover {
    border-color: rgba(232, 144, 80, 0.3);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.35),
      0 0 40px rgba(232, 144, 80, 0.04);
  }

  .trust-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 6px;
    background: linear-gradient(
      110deg,
      transparent 25%,
      rgba(232, 144, 80, 0.035) 48%,
      rgba(232, 144, 80, 0.07) 50%,
      rgba(232, 144, 80, 0.035) 52%,
      transparent 75%
    );
    background-size: 200% 100%;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: -1;
  }
  .trust-card:hover::after {
    opacity: 1;
    animation: shimmer 2s ease-in-out infinite;
  }
  .trust-card:hover .trust-icon {
    filter: drop-shadow(0 0 6px rgba(0, 230, 118, 0.35));
  }

  .trust-icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    margin-top: 0.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--crt-led-on, #00e676);
  }

  .trust-icon :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .trust-label {
    font-family: "Jersey 25", monospace;
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--lab-heading, #e0d0ff);
    display: block;
    margin-bottom: 0.1rem;
  }

  .trust-text {
    font-family: "Jersey 25", monospace;
    font-size: 0.85rem;
    color: var(--lab-text, #b0b0c8);
    line-height: 1.5;
    margin: 0;
  }

  /* ─── CTA ─── */
  .about-cta {
    position: relative;
  }
  .about-cta > * {
    position: relative;
    z-index: 1;
  }
  .about-cta::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(232, 144, 80, 0.04) 0%, transparent 70%);
  }
  .cta-inner {
    text-align: center;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }

  .cta-heading {
    font-family: "Early GameBoy", "Jersey 25", monospace;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 400;
    color: var(--lab-heading);
    margin-bottom: 0.5rem;
  }

  .cta-text {
    font-family: "Jersey 25", monospace;
    font-size: clamp(0.9rem, 1.6vw, 1rem);
    color: var(--lab-text-muted, #706888);
    max-width: 450px;
    margin: 0 auto 1.5rem;
    line-height: 1.5;
  }

  .cta-secondary-link {
    font-size: 0.95rem;
  }

  @media (min-width: 640px) {
    .cta-actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .approach-card,
    .trust-card {
      transition: none;
      transform: none;
    }
    .approach-card::after,
    .trust-card::after {
      display: none;
    }
  }
</style>
