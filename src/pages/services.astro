---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import { services } from "../data/services";
import MadLabsIcon from "../components/MadLabsIcon.astro";
---

<BaseLayout
  title="Cincinnati IT Services, Computer Repair & AI"
  description="Mobile computer repair, websites, Wi-Fi and network setup, security, custom PCs, and practical AI automation for Cincinnati homes and small businesses. Free 20-minute triage for new customers."
  jsonLdType="services"
>
  <section class="page-header lab-section">
    <div class="lab-section-inner-wide">
      <span class="lab-heading-accent">What We Do</span>
      <h1 class="page-heading">Services</h1>
      <p class="header-intro">
        Every project starts with a clear diagnostic: what is broken, what is possible, what it
        costs, and whether MAD LABS is the right fit. Repairs, networks, websites, hardware,
        security, and AI all get scoped before work begins.
      </p>
    </div>
  </section>

  <section class="services-grid-section lab-section-alt">
    <div class="lab-section-inner-wide">
      <div class="services-grid">
        {
          services.map((s) => (
            <ServiceCard
              name={s.name}
              shortDescription={s.shortDescription}
              bullets={s.bullets}
              icon={s.icon}
              pricing={s.pricing}
              category={s.category}
            />
          ))
        }
      </div>

      <!-- Trust strip — semantic list per WCAG 1.3.1 -->
      <ul class="trust-strip" aria-label="Our service promise">
        <li class="trust-item">
          <MadLabsIcon name="diagnostic" />
          Full diagnostic first
        </li>
        <li class="trust-item">
          <MadLabsIcon name="quote" />
          Clear quote before work
        </li>
        <li class="trust-item">
          <MadLabsIcon name="no-upsell" />
          No upsells — just what you need
        </li>
        <li class="trust-item">
          <MadLabsIcon name="discount" />
          Senior &amp; veteran discount
        </li>
      </ul>
    </div>
  </section>

  <section class="process-section lab-section">
    <div class="lab-section-inner-wide">
      <ProcessSteps />
    </div>
  </section>

  <section class="cta-section lab-section-alt">
    <div class="lab-section-inner cta-inner">
      <span class="lab-heading-accent">Next Steps</span>
      <h2 class="cta-heading">Not sure what you need?</h2>
      <p class="cta-copy">
        Describe the problem or project and we will recommend the right next step. No commitment, no
        pressure, no mystery invoice.
      </p>
      <a href="/contact/" class="lab-button">Contact us for a diagnostic quote</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-heading {
    font-family: "Monofett", monospace;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    color: var(--lab-heading);
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .header-intro {
    font-family: "Jersey 25", monospace;
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--lab-text);
    max-width: 600px;
    line-height: 1.5;
  }

  /* ─── Diagnostic flair ─── */
  .services-grid-section {
    position: relative;
    overflow: hidden;
  }

  .services-grid-section::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(232, 144, 80, 0.04) 0%, transparent 70%),
      radial-gradient(
        ellipse at 50% 30%,
        transparent 30%,
        rgba(232, 144, 80, 0.035) 60%,
        transparent 80%
      );
  }

  .services-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem 2.5rem;
    }
  }

  .cta-section {
    position: relative;
  }

  .cta-section > * {
    position: relative;
    z-index: 1;
  }

  .cta-inner {
    text-align: center;
  }

  .cta-heading {
    margin-bottom: 0.5rem;
    color: var(--lab-heading);
    font-family: "Early GameBoy", "Jersey 25", monospace;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 400;
    line-height: 1.25;
  }

  .cta-copy {
    max-width: 560px;
    margin: 0 auto 1.5rem;
    color: var(--lab-text-muted);
    font-family: "Jersey 25", monospace;
    font-size: 1rem;
    line-height: 1.55;
  }

  .trust-strip {
    --mad-labs-icon-color: var(--lab-accent);
    --mad-labs-icon-size: 1rem;

    position: relative;
    z-index: var(--z-base);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.75rem 1.5rem;
    margin-top: 2rem;
    padding: 1.25rem 1rem;
    border: 1px solid rgba(232, 144, 80, 0.15);
    border-radius: 8px;
    background: rgba(30, 26, 50, 0.6);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 4px 16px rgba(0, 0, 0, 0.2);
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .trust-item {
    font-family: "Jersey 25", monospace;
    font-size: 0.9rem;
    color: var(--lab-text);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
    line-height: 1.4;
  }

  @media (max-width: 480px) {
    .trust-strip {
      gap: 0.5rem 1.25rem;
      padding: 1rem 0.5rem;
    }

    .trust-item {
      font-size: 0.8rem;
    }
  }
</style>
