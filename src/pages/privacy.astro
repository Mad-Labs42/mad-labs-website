---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CONTACT_EMAIL } from "../data/contact";

const summaryItems = [
  "We do not sell your data.",
  "We do not run ad pixels or remarketing.",
  "We do not track you across the web.",
  "We use limited launch diagnostics to see whether the site is working.",
  "If you contact us, we use what you send only to respond and help.",
];

const collectedItems = [
  "Basic page views, traffic sources, device, browser, and performance information from Google Analytics 4 and Cloudflare Web Analytics/RUM.",
  "Page interactions while Microsoft Clarity is enabled, such as clicks, scroll behavior, page navigation, session replay, and heatmap-style diagnostics.",
  "Contact, booking, or service details you choose to send through MAD LABS or Zoho Bookings/Nimbuspop, such as your name, email, phone number, appointment details, and issue description.",
];

const notDoneItems = [
  "No selling visitor or customer data.",
  "No ad profiles.",
  "No remarketing pixels.",
  "No cross-site tracking strategy.",
  "No publishing, renting, or selling customer contact details.",
  "No stuffing your inbox because you asked one question.",
];

const thirdPartyTools = [
  "Google Analytics 4 for basic page views, traffic sources, device/browser information, and launch health checks.",
  "Microsoft Clarity for temporary behavior diagnostics during the early launch window.",
  "Cloudflare Web Analytics/RUM for site traffic, performance, and reliability signals on the Cloudflare-hosted site.",
  "Zoho Bookings/Nimbuspop as the embedded booking provider on the contact page.",
  "Email providers and payment processors as needed for normal business operations.",
];
---

<BaseLayout
  title="Privacy Policy"
  description="Plain-English privacy policy for MAD LABS: what we collect, what we don't do, and how temporary site diagnostics are used."
>
  <section class="privacy-hero" aria-labelledby="privacy-heading">
    <div class="privacy-shell">
      <p class="privacy-kicker">Privacy Protocol</p>
      <h1 id="privacy-heading">Your data is not lab fuel.</h1>
      <p class="privacy-lede">
        MAD LABS is built by people who actually care how technology treats humans. We use the
        smallest amount of data we can get away with. No ad tracking. No resale. No creepy dossiers.
        No corporate surveillance cosplay.
      </p>
      <div class="privacy-status" aria-label="Privacy posture">
        <span>SELLING DATA: OFF</span>
        <span>AD PIXELS: OFF</span>
        <span>DEBUG MODE: TEMPORARY</span>
      </div>
    </div>
  </section>

  <section class="privacy-section" aria-labelledby="containment-heading">
    <div class="privacy-shell">
      <div class="privacy-panel privacy-panel--summary">
        <div class="privacy-panel-label">Containment Protocol</div>
        <h2 id="containment-heading">Privacy-first by default.</h2>
        <p>
          We are tech people. We know how ugly the data economy can get. MAD LABS does not maintain
          a private visitor database or sell/monetize visitor data. If you contact us, we keep only
          what we need to respond and do the work.
        </p>
        <ul class="privacy-checklist">
          {summaryItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="privacy-section privacy-section--grid" aria-label="Privacy details">
    <div class="privacy-shell privacy-grid">
      <article class="privacy-panel" aria-labelledby="collect-heading">
        <div class="privacy-panel-label">Data Intake</div>
        <h2 id="collect-heading">What We Collect</h2>
        <p>
          MAD LABS does not want more data than needed. The site may collect limited technical
          information so we can tell whether the site works, where people get stuck, and what needs
          repair.
        </p>
        <p>
          During the launch/debugging window, that includes basic page views and site health signals
          from Google Analytics 4 and Cloudflare Web Analytics/RUM, behavior diagnostics from
          Microsoft Clarity, and booking details you choose to send through Zoho Bookings/Nimbuspop.
        </p>
        <ul>
          {collectedItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="privacy-panel" aria-labelledby="dont-heading">
        <div class="privacy-panel-label">Hard No List</div>
        <h2 id="dont-heading">What We Don't Do</h2>
        <p>
          We are not trying to squeeze a marketing profile out of every click. If that sounds
          refreshing, good. It should be normal.
        </p>
        <ul>
          {notDoneItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="privacy-section" aria-labelledby="clarity-heading">
    <div class="privacy-shell">
      <article class="privacy-panel privacy-panel--warning">
        <div class="privacy-panel-label">Temporary Debugging Window</div>
        <h2 id="clarity-heading">Microsoft Clarity is launch equipment, not an ad machine.</h2>
        <p>
          During the early launch window, MAD LABS uses Microsoft Clarity to understand how real
          visitors move through the site: where people click, where they stop, what breaks, and what
          gets confusing. That helps us fix bottlenecks instead of guessing.
        </p>
        <p>
          Clarity may collect behavioral diagnostics such as clicks, scrolling, page navigation,
          device/browser information, and session replay/heatmap-style data. That data is handled by
          Microsoft Clarity, not a MAD LABS-owned analytics database. We use it only to improve the
          site experience, diagnose bottlenecks, and make the site easier to use. MAD LABS plans to
          remove Clarity after the short debugging window.
        </p>
      </article>
    </div>
  </section>

  <section class="privacy-section privacy-section--grid" aria-label="Contact and tool details">
    <div class="privacy-shell privacy-grid">
      <article class="privacy-panel" aria-labelledby="contact-heading">
        <div class="privacy-panel-label">When You Contact the Lab</div>
        <h2 id="contact-heading">You choose what to send.</h2>
        <p>
          When you contact MAD LABS, book a call, or submit a request, we receive the information
          you choose to send: name, email, phone number, appointment details, and issue description.
          The booking flow is handled through Zoho Bookings/Nimbuspop as the embedded booking
          provider. We use what you send to respond, schedule work, provide service, support you, and
          keep basic business records.
        </p>
        <p>
          We may need to keep service messages or records long enough to complete work, answer
          follow-up questions, handle business records, or meet ordinary business obligations.
        </p>
      </article>

      <article class="privacy-panel" aria-labelledby="tools-heading">
        <div class="privacy-panel-label">Third-Party Tools</div>
        <h2 id="tools-heading">Useful tools, limited blast radius.</h2>
        <p>
          Some parts of the site and service flow run through outside tools. We use them for normal
          operations, not to build creepy profiles of visitors.
        </p>
        <ul>
          {thirdPartyTools.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="privacy-section privacy-section--final" aria-labelledby="move-heading">
    <div class="privacy-shell">
      <article class="privacy-panel privacy-panel--final">
        <div class="privacy-panel-label">Your Move</div>
        <h2 id="move-heading">Questions, corrections, deletion requests.</h2>
        <p>
          If you want to ask about your information, request a correction, or ask us to delete
          something where possible, contact the lab at
          <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>. We will handle it like humans,
          not like a maze.
        </p>
        <p class="privacy-updated">Last updated: June 29, 2026</p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .privacy-hero,
  .privacy-section {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(126, 88, 206, 0.22), transparent 58%),
      linear-gradient(180deg, rgba(10, 6, 24, 0.98), rgba(0, 0, 0, 0.96));
  }

  .privacy-hero {
    border-bottom: 1px solid rgba(232, 144, 80, 0.18);
    padding: clamp(5rem, 10vw, 8rem) 1rem clamp(3rem, 8vw, 5rem);
  }

  .privacy-section {
    border-bottom: 1px solid rgba(232, 144, 80, 0.1);
    padding: clamp(2rem, 5vw, 4rem) 1rem;
  }

  .privacy-shell {
    width: min(100%, 1080px);
    margin: 0 auto;
  }

  .privacy-kicker,
  .privacy-panel-label {
    color: var(--crt-led-on);
    font-family: "Early GameBoy", "Jersey 25", monospace;
    font-size: clamp(0.62rem, 1.1vw, 0.78rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-shadow: 0 0 10px rgba(0, 230, 118, 0.28);
  }

  .privacy-hero h1 {
    max-width: 880px;
    margin: 0.85rem 0 1rem;
    color: var(--lab-heading);
    font-family: "Jersey 25", "VT323", monospace;
    font-size: clamp(2.5rem, 9vw, 5.5rem);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-shadow:
      0 0 18px rgba(216, 180, 254, 0.34),
      0 0 42px rgba(147, 51, 234, 0.22);
  }

  .privacy-lede {
    max-width: 820px;
    color: #d8ccf2;
    font-family: "Jersey 25", "VT323", monospace;
    font-size: clamp(1.18rem, 2.4vw, 1.55rem);
    line-height: 1.35;
    letter-spacing: 0.025em;
  }

  .privacy-status {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.6rem;
  }

  .privacy-status span {
    border: 1px solid rgba(0, 230, 118, 0.3);
    border-radius: 4px;
    background: rgba(0, 230, 118, 0.08);
    color: #baf7d1;
    padding: 0.45rem 0.65rem;
    font-family: "Early GameBoy", "Jersey 25", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
  }

  .privacy-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .privacy-panel {
    position: relative;
    height: 100%;
    border: 1px solid rgba(232, 144, 80, 0.18);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(40, 24, 76, 0.82), rgba(12, 8, 32, 0.92)),
      repeating-linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.025) 0,
        rgba(255, 255, 255, 0.025) 1px,
        transparent 1px,
        transparent 5px
      );
    box-shadow:
      0 0 0 1px rgba(216, 180, 254, 0.04),
      0 20px 60px rgba(0, 0, 0, 0.32);
    padding: clamp(1.2rem, 3vw, 1.8rem);
  }

  .privacy-panel--summary {
    border-color: rgba(0, 230, 118, 0.25);
  }

  .privacy-panel--warning {
    border-color: rgba(247, 158, 85, 0.34);
    background:
      linear-gradient(180deg, rgba(70, 35, 48, 0.74), rgba(14, 8, 30, 0.94)),
      repeating-linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.025) 0,
        rgba(255, 255, 255, 0.025) 1px,
        transparent 1px,
        transparent 5px
      );
  }

  .privacy-panel h2 {
    margin: 0.65rem 0 0.85rem;
    color: #f0eaff;
    font-family: "Jersey 25", "VT323", monospace;
    font-size: clamp(1.55rem, 3.2vw, 2.35rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: 0.035em;
    text-transform: uppercase;
  }

  .privacy-panel p,
  .privacy-panel li {
    color: #cec4e6;
    font-family: "Jersey 25", "VT323", monospace;
    font-size: clamp(1.04rem, 2vw, 1.24rem);
    line-height: 1.42;
    letter-spacing: 0.024em;
  }

  .privacy-panel p + p,
  .privacy-panel p + ul {
    margin-top: 0.9rem;
  }

  .privacy-panel ul {
    display: grid;
    gap: 0.55rem;
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
  }

  .privacy-panel li {
    position: relative;
    padding-left: 1.1rem;
  }

  .privacy-panel li::before {
    content: ">";
    position: absolute;
    left: 0;
    color: var(--lab-accent);
  }

  .privacy-checklist li::before {
    color: var(--crt-led-on);
  }

  .privacy-panel a {
    color: #f7b16d;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .privacy-panel a:focus-visible {
    border-radius: 3px;
    outline: 2px solid var(--divider-orange);
    outline-offset: 3px;
  }

  .privacy-updated {
    margin-top: 1.2rem;
    color: #a8f2c4;
    font-family: "Early GameBoy", "Jersey 25", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 780px) {
    .privacy-grid {
      grid-template-columns: 1fr;
    }

    .privacy-status {
      align-items: stretch;
      flex-direction: column;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .privacy-panel,
    .privacy-status span {
      transition: none;
    }
  }
</style>
