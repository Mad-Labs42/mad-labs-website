---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactInfo from "../components/ContactInfo.astro";
import ContactTablet from "../components/ContactTablet.astro";
import { CONTACT_EMAIL, CONTACT_PHONE } from "../data/contact";
---

<BaseLayout title="Book Computer Repair in Cincinnati" description={`Book a free 20-minute computer triage or 60-minute consultation with MAD LABS in Cincinnati. Same-day responses. Call ${CONTACT_PHONE} or book online.`} jsonLdType="contact">
  
  <section class="lab-section">
    <div class="lab-section-inner-wide">
      <div class="contact-hero-grid">
        <div class="contact-hero-left">
          <span class="lab-heading-accent">Reach the Lab</span>
          <h1 class="lab-heading contact-hero-heading">CONTACT</h1>
          <p class="contact-hero-text">
            Tell us what's going on with your device. We'll follow up with next steps and a rough
            timeline — no charge, no commitment.
          </p>
        </div>
        <div class="contact-hero-right">
          <div class="contact-tablet-instruction">
            <span class="instruction-orange">Book a time below.</span>
            <span>Twenty-minute call. No charge, no commitment.</span>
            <span
              >For complex jobs (repairs, tuneups, malware cleanup, networks, custom builds), we'll
              quote and schedule after the call.</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  
  <section class="lab-section-alt contact-layout-section">
    <div class="lab-section-inner-wide">
          <a href="#contact-info-col" class="skip-to-info sr-only-focusable">Skip to contact information</a>
      <div class="contact-layout">
        
        <div id="contact-info-col" class="contact-info-col">
          <span class="lab-heading-accent contact-accent-wrap">
            <svg
              class="contact-accent-icon"
              viewBox="0 0 64 64"
              aria-hidden="true"
              fill="none"
              stroke="#e89050"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              
              <path
                d="M37 2.7H4.2C2.4 2.7 1 4.2 1 6v41c0 1.8 1.4 3.2 3.2 3.2h55.6c1.8 0 3.2-1.4 3.2-3.2V6c0-1.8-1.4-3.2-3.2-3.2L37 2.7h0zM5 40.5h58"
              ></path>
              
              <circle cx="33.7" cy="19.9" r="4.1"></circle>
              
              <path d="m33.7 24-2 5.3"></path>
              
              <circle cx="30.7" cy="31.7" r="2.6"></circle>
              
              <path d="M29.6 19.9h-5.1"></path>
              
              <circle cx="21.9" cy="19.9" r="2.6"></circle>
              
              <path d="m36.7 17 3.5-3.6"></path>
              
              <circle cx="42.1" cy="11.5" r="2.6" transform="rotate(-45.001 42.086 11.513)"
              ></circle>
              
              <path d="m36.7 22.8 3.5 3.6"></path>
              
              <circle cx="42.1" cy="28.3" r="2.6" transform="rotate(-45.001 42.123 28.297)"
              ></circle>
              
              <path d="m30.8 17-3.6-3.6"></path>
              
              <circle cx="25.4" cy="11.5" r="2.6" transform="rotate(-45.001 25.373 11.48)"></circle>
              
              <path
                d="m42.3 57.1-.9-.6c-.2-.2-.5-.4-.6-.7H23.2c-.2.3-.4.5-.6.7l-.9.6c-.6.4-.9 1.1-.9 1.9v.9c0 .8.6 1.4 1.4 1.4h19.7c.8 0 1.4-.6 1.4-1.4V59c0-.8-.4-1.5-1-1.9zM40.4 55l-2-4.8H25.5l-2 4.8c-.1.3-.2.6-.4.8h17.6c0-.3-.2-.5-.3-.8zM29.4 45.4h5.2"
              ></path>
            </svg>
            Contact Us
          </span>
          <h2
            class="lab-heading reach-us-heading"
            style="font-size:clamp(1.1rem,2.5vw,1.5rem); margin-top:0; margin-bottom:0.25rem;"
          >
            We'd love to hear from you!
          </h2>
          <div style="display:flex; flex-direction:column; gap:0.75rem;">
            <div class="contact-info-card">
              <ContactInfo
                email={CONTACT_EMAIL}
                phone={CONTACT_PHONE}
                location="Greater Cincinnati Area"
              />
            </div>
            <div class="contact-response-card">
              <p style="font-size:0.9rem; color:var(--lab-text); line-height:1.6;">
                We typically respond within
                <strong style="color:var(--lab-heading);">2–4 hours</strong>
                during business hours. For urgent issues, mention it in your message and we'll prioritize
                your request.
              </p>
            </div>
          </div>

          <div class="contact-extras">
            <div>
              <h2
                class="lab-heading"
                style="font-size:clamp(1rem,2vw,1.3rem); margin-bottom:0.75rem; color:var(--lab-accent);"
              >
                Service Area
              </h2>
              <p class="lab-text" style="font-size:0.9rem; line-height:1.6; margin-bottom:0.6rem;">
                We serve the greater Cincinnati metropolitan area, including Cincinnati, Covington,
                Newport, and surrounding communities.
              </p>
              <p class="lab-text" style="font-size:0.9rem; line-height:1.6;">
                Remote diagnostics and software support are available for clients anywhere — we can
                diagnose and resolve many issues without an in-person visit.
              </p>
            </div>
            <div>
              <h2
                class="lab-heading"
                style="font-size:clamp(1rem,2vw,1.3rem); margin-bottom:0.75rem; color:var(--lab-accent);"
              >
                Hours
              </h2>
              <dl style="margin:0; padding:0;">
                <div
                  class="hours-row"
                >
                  <dt class="hours-day">Monday – Friday</dt>
                  <dd class="hours-time">9:00 AM – 6:00 PM</dd>
                </div>
                <div
                  class="hours-row"
                >
                  <dt class="hours-day">Saturday</dt>
                  <dd class="hours-time">10:00 AM – 4:00 PM</dd>
                </div>
                <div
                  class="hours-row"
                >
                  <dt class="hours-day">Sunday</dt>
                  <dd class="hours-time">Closed</dd>
                </div>
              </dl>
              <p class="contact-dropoff-text">
                Hardware drop-offs by appointment only. Evening pickup available upon request.
              </p>
            </div>
          </div>
        </div>

        
        <div class="contact-tablet-col">
          
          <div id="contact-tablet-instructions" class="contact-tablet-instruction">
            <span class="instruction-orange">Book a time below.</span>
            <span>Twenty-minute call. No charge, no commitment.</span>
            <span
              >For complex jobs (repairs, tuneups, malware cleanup, networks, custom builds), we'll
              quote and schedule after the call.</span
            >
          </div>

          
          <p class="contact-scroll-cue" aria-hidden="true">
            <span class="scroll-chevron"></span>
            Scroll down to book a consultation or submit a repair ticket.
            <span class="scroll-chevron"></span>
          </p>

          <ContactTablet />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero: 2-column grid (left=intro, right=instruction) ─── */
  .contact-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }

  @media (min-width: 1100px) {
    .contact-hero-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .contact-hero-left {
    display: flex;
    flex-direction: column;
    max-width: 460px;
  }

  .contact-hero-right {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
  }

  @media (max-width: 1099px) {
    .contact-hero-right {
      display: none;
    }
  }

  .contact-hero-heading {
    font-family: "Monofett", monospace;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    color: var(--lab-heading);
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .contact-hero-text {
    font-size: clamp(0.85rem, 1.6vw, 1rem);
    color: var(--lab-text);
    line-height: 1.5;
    max-width: 460px;
  }

  /* ─── Contact Us + Tablet section ─── */
  .contact-layout-section {
    position: relative;
  }
  .contact-layout-section > * {
    position: relative;
    z-index: 1;
  }

  /* ─── Two-column layout ─── */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 1100px) {
    .contact-layout {
      grid-template-columns: 1fr 1.2fr;
      gap: 3rem;
    }
  }

  @media (min-width: 1200px) {
    .contact-layout {
      gap: 4rem;
    }
  }

  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-extras {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ─── Typography: "Reach Us" and phone number in Jersey 25 ─── */
  .reach-us-heading {
    font-family: "Jersey 25", "VT323", "Courier New", monospace !important;
  }

  /* ─── Contact info card (Email/Phone/Location) ─── */
  .contact-info-card {
    position: relative;
    background: rgba(30, 26, 50, 0.6);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    transition: box-shadow 0.25s ease;
    /* Continuous orange border all around */
    box-shadow:
      inset 0 0 0 1px rgba(232, 144, 80, 0.25),
      inset 0 2px 0 rgba(232, 144, 80, 0.35),
      inset 0 -2px 0 rgba(232, 144, 80, 0.35),
      inset 2px 0 0 rgba(232, 144, 80, 0.35),
      inset -2px 0 0 rgba(232, 144, 80, 0.35);
  }
  .contact-info-card:hover {
    box-shadow:
      0 0 24px rgba(232, 144, 80, 0.08),
      inset 0 0 0 1px rgba(232, 144, 80, 0.35),
      inset 0 3px 0 rgba(232, 144, 80, 0.55),
      inset 0 -3px 0 rgba(232, 144, 80, 0.55),
      inset 3px 0 0 rgba(232, 144, 80, 0.55),
      inset -3px 0 0 rgba(232, 144, 80, 0.55);
  }

  /* ─── Section top-edge glow ─── */
  .contact-layout-section::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(232, 144, 80, 0.04) 0%, transparent 70%);
  }

  /* ─── Dropoff text card ─── */
  .contact-dropoff-text {
    font-size: 0.82rem;
    color: var(--lab-text-muted);
    margin-top: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--lab-card);
    border: calc(1px * 1.05) solid var(--lab-border);
    border-radius: 8px;
    line-height: 1.5;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  .contact-dropoff-text:hover {
    border-color: rgba(232, 144, 80, 0.35);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 0 24px rgba(232, 144, 80, 0.08);
  }

  /* ─── Response-time card with service-card-style effects ─── */
  .contact-response-card {
    position: relative;
    isolation: isolate;
    background: var(--lab-card);
    border: calc(1px * 1.05) solid var(--lab-border);
    border-radius: 8px;
    padding: 1.25rem;
    overflow: hidden;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  .contact-response-card::before,
  .contact-response-card::after {
    content: "";
    position: absolute;
    top: 6px;
    bottom: 6px;
    width: 3px;
    border-radius: 2px;
    background: rgba(232, 144, 80, 0.25);
    pointer-events: none;
    z-index: 1;
    transition: background 0.25s ease;
  }
  .contact-response-card::before {
    left: 0;
  }
  .contact-response-card::after {
    right: 0;
  }
  .contact-response-card:hover::before,
  .contact-response-card:hover::after {
    background: rgba(232, 144, 80, 0.55);
  }

  .contact-response-card:hover {
    border-color: rgba(232, 144, 80, 0.35);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 0 24px rgba(232, 144, 80, 0.08);
  }

  .contact-response-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: linear-gradient(
      110deg,
      transparent 25%,
      rgba(232, 144, 80, 0.035) 48%,
      rgba(232, 144, 80, 0.07) 50%,
      rgba(232, 144, 80, 0.035) 52%,
      transparent 75%
    );
    background-size: 200% 100%;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: -1;
  }

  .contact-response-card:hover::after,
  .contact-response-card:focus-visible::after {
    opacity: 1;
    animation: shimmer 2s ease-in-out infinite;
  }

  /* ─── Tablet column ─── */
  .contact-tablet-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ─── Tablet instruction text ─── */
  .contact-tablet-instruction {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin: 0 0 0.75rem;
    color: var(--lab-text-muted);
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
    font-size: 0.78rem;
    line-height: 1.35;
    letter-spacing: 0.02em;
  }

  .contact-tablet-instruction strong {
    color: var(--lab-accent);
    font-weight: 600;
  }

  .instruction-orange {
    color: var(--lab-accent);
  }

  /* Hide the hero-right instruction on desktop since it's now in the tablet column */
  @media (min-width: 1100px) {
    .contact-hero-right {
      display: none;
    }
  }

  /* ─── Contact Us accent icon ─── */
  .contact-accent-wrap {
    display: inline-flex !important;
    align-items: center;
    gap: 0.8rem;
  }

  .contact-accent-icon {
    width: 1.8em;
    height: 1.8em;
    flex-shrink: 0;
  }

  /* ─── Mobile scroll cue ─── */
  .contact-scroll-cue {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0;
    color: var(--lab-text-muted);
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-align: center;
    text-transform: uppercase;
  }

  .scroll-chevron {
    display: inline-block;
    width: 0.6rem;
    height: 0.6rem;
    border-right: 2px solid var(--lab-accent);
    border-bottom: 2px solid var(--lab-accent);
    transform: rotate(45deg);
    opacity: 0.6;
  }

  @media (min-width: 1100px) {
    .contact-scroll-cue {
      display: none;
    }

    .contact-tablet-col {
      justify-content: flex-start;
      padding-top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-response-card {
      transition: none;
    }

    .contact-response-card::after {
      display: none;
    }

    .scroll-chevron {
      animation: none;
    }
  }

  /* ─── Hours and service area inline style cleanup ─── */
  .hours-row {
    display: flex;
    justify-content: space-between;
    padding: 0.35rem 0;
    border-bottom: 1.15px solid rgba(232, 144, 80, 0.18);
    font-size: 0.9rem;
  }
  .hours-row:last-of-type {
    border-bottom: none;
  }
  .hours-day {
    color: var(--lab-heading);
    font-weight: 500;
  }
  .hours-time {
    color: var(--lab-text-muted);
    margin: 0;
  }
</style>

<style>
</style>

<style>
  .skip-to-info.sr-only-focusable {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    white-space: nowrap;
  }
  .skip-to-info.sr-only-focusable:focus {
    position: static;
    width: auto;
    height: auto;
    padding: 0.5rem 1rem;
    background: var(--lab-card);
    color: var(--lab-accent);
    border: 1px solid var(--divider-orange);
    border-radius: 4px;
    font-family: "Jersey 25", monospace;
    font-size: 0.85rem;
    z-index: 100;
    margin-bottom: 1rem;
    display: inline-block;
  }
</style>
