---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactInfo from "../components/ContactInfo.astro";
import ContactTablet from "../components/ContactTablet.astro";
---

<BaseLayout title="Contact">
  <!-- ─── Hero: intro + instruction (2-col on desktop) ─── -->
  <section class="lab-section">
    <div class="lab-section-inner-wide">
      <div class="contact-hero-grid">
        <div class="contact-hero-left">
          <span class="lab-heading-accent">Reach the Lab</span>
          <h1
            class="lab-heading contact-hero-heading"
          >
            Get in Touch
          </h1>
          <p
            class="contact-hero-text"
          >
            Tell us what's going on with your device. We'll follow up with next
            steps and a rough timeline — no charge, no commitment.
          </p>
        </div>
        <div class="contact-hero-right">
          <div class="contact-tablet-instruction">
            <span class="instruction-orange">You may use this tablet to contact us online.</span>
            <span>— Click <strong>Book a Consultation</strong> for diagnostics, service planning, AI help, websites, or questions about what you need.</span>
            <span>— Click <strong>Submit a Repair Ticket</strong> for computer repair, tuneups, malware cleanup, network issues, or existing support requests.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Contact Info + Tablet (side-by-side on desktop) ─── -->
  <section class="lab-section-alt">
    <div class="lab-section-inner-wide">
      <div class="contact-layout">
        <!-- Left: contact details, service area, hours -->
        <div class="contact-info-col">
          <span class="lab-heading-accent contact-accent-wrap">
            <svg class="contact-accent-icon" viewBox="-1 -1 22 22" aria-hidden="true" fill="none" stroke="#e89050" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="10" cy="10" r="3.5"/>
              <path d="M5.5 5.5a7 7 0 0 0 0 9"/>
              <path d="M14.5 5.5a7 7 0 0 1 0 9"/>
              <path d="M3 3a10 10 0 0 0 0 14"/>
            </svg>
            Contact Us
          </span>
          <h2
            class="lab-heading reach-us-heading"
            style="font-size:clamp(1.1rem,2.5vw,1.5rem); margin-bottom:1.25rem;"
          >
            We'd love to hear from you!
          </h2>
          <div style="display:flex; flex-direction:column; gap:1.5rem;">
            <ContactInfo
              email="customer-service@madlabs.rocks"
              phone="(513) 306-5331"
              location="Greater Cincinnati Area"
            />
            <div
              class="contact-response-card"
            >
              <p style="font-size:0.9rem; color:var(--lab-text); line-height:1.6;">
                We typically respond within
                <strong style="color:var(--lab-heading);">2–4 hours</strong>
                during business hours. For urgent issues, mention it in your
                message and we'll prioritize your request.
              </p>
            </div>
          </div>

          <div class="contact-extras">
            <div>
              <h2
                class="lab-heading"
                style="font-size:clamp(1rem,2vw,1.3rem); margin-bottom:0.75rem;"
              >
                Service Area
              </h2>
              <p
                class="lab-text"
                style="font-size:0.9rem; line-height:1.6; margin-bottom:0.6rem;"
              >
                We serve the greater Cincinnati metropolitan area, including
                Cincinnati, Covington, Newport, and surrounding communities.
              </p>
              <p class="lab-text" style="font-size:0.9rem; line-height:1.6;">
                Remote diagnostics and software support are available for
                clients anywhere — we can diagnose and resolve many issues
                without an in-person visit.
              </p>
            </div>
            <div>
              <h2
                class="lab-heading"
                style="font-size:clamp(1rem,2vw,1.3rem); margin-bottom:0.75rem;"
              >
                Hours
              </h2>
              <dl style="margin:0; padding:0;">
                <div
                  style="display:flex; justify-content:space-between; padding:0.35rem 0; border-bottom:1px solid var(--lab-border); font-size:0.9rem;"
                >
                  <dt style="color:var(--lab-heading); font-weight:500;">
                    Monday – Friday
                  </dt>
                  <dd style="color:var(--lab-text-muted); margin:0;">
                    9:00 AM – 6:00 PM
                  </dd>
                </div>
                <div
                  style="display:flex; justify-content:space-between; padding:0.35rem 0; border-bottom:1px solid var(--lab-border); font-size:0.9rem;"
                >
                  <dt style="color:var(--lab-heading); font-weight:500;">
                    Saturday
                  </dt>
                  <dd style="color:var(--lab-text-muted); margin:0;">
                    10:00 AM – 4:00 PM
                  </dd>
                </div>
                <div
                  style="display:flex; justify-content:space-between; padding:0.35rem 0; font-size:0.9rem;"
                >
                  <dt style="color:var(--lab-heading); font-weight:500;">
                    Sunday
                  </dt>
                  <dd style="color:var(--lab-text-muted); margin:0;">
                    Closed
                  </dd>
                </div>
              </dl>
              <p
                style="font-size:0.82rem; color:var(--lab-text-muted); margin-top:0.75rem;"
              >
                Hardware drop-offs by appointment only. Evening pickup available
                upon request.
              </p>
            </div>
          </div>
        </div>

        <!-- Right: tablet terminal -->
        <div class="contact-tablet-col">
          <!-- Mobile scroll cue -->
          <p class="contact-scroll-cue" aria-hidden="true">
            <span class="scroll-chevron"></span>
            Scroll down to book a consultation or submit a repair ticket.
            <span class="scroll-chevron"></span>
          </p>

          <ContactTablet />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero: 2-column grid (left=intro, right=instruction) ─── */
  .contact-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 2rem 0;
  }

  @media (min-width: 900px) {
    .contact-hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .contact-hero-left {
    display: flex;
    flex-direction: column;
    max-width: 460px;
  }

  .contact-hero-right {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
  }

  @media (max-width: 899px) {
    .contact-hero-right {
      display: none;
    }
  }

  .contact-hero-heading {
    font-size: clamp(1.35rem, 3.2vw, 2.15rem) !important;
    margin-bottom: 0.5rem;
  }

  .contact-hero-text {
    font-size: clamp(0.85rem, 1.6vw, 1rem);
    color: var(--lab-text);
    line-height: 1.5;
    max-width: 460px;
  }

  /* ─── Two-column layout ─── */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr 1.2fr;
      gap: 3rem;
    }
  }

  @media (min-width: 1200px) {
    .contact-layout {
      gap: 4rem;
    }
  }

  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-extras {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ─── Typography: "Reach Us" and phone number in Jersey 25 ─── */
  .reach-us-heading {
    font-family: "Jersey 25", "VT323", "Courier New", monospace !important;
  }

  /* ─── Response-time card with service-card-style effects ─── */
  .contact-response-card {
    position: relative;
    isolation: isolate;
    background: var(--lab-card);
    border: calc(1px * 1.05) solid var(--lab-border);
    border-radius: 8px;
    padding: 1.25rem;
    overflow: hidden;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
    transform: translateY(0);
  }

  .contact-response-card:hover {
    transform: translateY(-3px);
    border-color: rgba(232, 144, 80, 0.35);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 0 24px rgba(232, 144, 80, 0.08);
  }

  .contact-response-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: linear-gradient(
      110deg,
      transparent 25%,
      rgba(232, 144, 80, 0.035) 48%,
      rgba(232, 144, 80, 0.07) 50%,
      rgba(232, 144, 80, 0.035) 52%,
      transparent 75%
    );
    background-size: 200% 100%;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: -1;
  }

  .contact-response-card:hover::after {
    opacity: 1;
    animation: response-shimmer 2s ease-in-out infinite;
  }

  @keyframes response-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ─── Tablet column ─── */
  .contact-tablet-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ─── Tablet instruction text ─── */
  .contact-tablet-instruction {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin: 0.5rem 0 0;
    color: var(--lab-text-muted);
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
    font-size: 0.78rem;
    line-height: 1.35;
    letter-spacing: 0.02em;
  }

  .contact-tablet-instruction strong {
    color: var(--lab-accent);
    font-weight: 600;
  }

  .instruction-orange {
    color: var(--lab-accent);
  }

  @media (max-width: 899px) {
    .contact-tablet-instruction {
      display: none;
    }
  }

  /* ─── Contact Us accent icon ─── */
  .contact-accent-wrap {
    display: inline-flex !important;
    align-items: center;
    gap: 0.25rem;
  }

  .contact-accent-icon {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
  }

  /* ─── Mobile scroll cue ─── */
  .contact-scroll-cue {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0;
    color: var(--lab-text-muted);
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-align: center;
    text-transform: uppercase;
  }

  .scroll-chevron {
    display: inline-block;
    width: 0.6rem;
    height: 0.6rem;
    border-right: 2px solid var(--lab-accent);
    border-bottom: 2px solid var(--lab-accent);
    transform: rotate(45deg);
    opacity: 0.6;
  }

  @media (min-width: 900px) {
    .contact-scroll-cue {
      display: none;
    }

    .contact-tablet-col {
      justify-content: flex-start;
      padding-top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-response-card {
      transition: none;
      transform: none;
    }

    .contact-response-card::after {
      display: none;
    }

    .scroll-chevron {
      animation: none;
    }
  }
</style>
