---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactInfo from "../components/ContactInfo.astro";
import ContactTablet from "../components/ContactTablet.astro";
---

<BaseLayout title="Contact">
  <!-- ─── Hero: intro + instruction (2-col on desktop) ─── -->
  <section class="lab-section">
    <div class="lab-section-inner-wide">
      <div class="contact-hero-grid">
        <div class="contact-hero-left">
          <span class="lab-heading-accent">Reach the Lab</span>
          <h1 class="lab-heading contact-hero-heading">Get in Touch</h1>
          <p class="contact-hero-text">
            Tell us what's going on with your device. We'll follow up with next steps and a rough
            timeline — no charge, no commitment.
          </p>
        </div>
        <div class="contact-hero-right">
          <div class="contact-tablet-instruction">
            <span class="instruction-orange">You may use this tablet to contact us online.</span>
            <span
              >— Click <strong>Book a Consultation</strong> for diagnostics, service planning, AI help,
              websites, or questions about what you need.</span
            >
            <span
              >— Click <strong>Submit a Repair Ticket</strong> for computer repair, tuneups, malware cleanup,
              network issues, or existing support requests.</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Contact Info + Tablet (side-by-side on desktop) ─── -->
  <section class="lab-section-alt">
    <div class="lab-section-inner-wide">
      <div class="contact-layout">
        <!-- Left: contact details, service area, hours -->
        <div class="contact-info-col">
          <span class="lab-heading-accent contact-accent-wrap">
            <svg
              class="contact-accent-icon"
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="none"
              stroke="#e89050"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <!-- Antenna mast -->
              <line x1="12" y1="20" x2="12" y2="10"></line>
              <!-- Antenna top -->
              <circle cx="12" cy="8" r="2" fill="#e89050"></circle>
              <!-- Signal arcs — symmetric, fully inside viewBox -->
              <path d="M6.5 13.5a5 5 0 0 1 11 0"></path>
              <path d="M4 16a8 8 0 0 1 16 0"></path>
              <!-- Base -->
              <line x1="8" y1="21" x2="16" y2="21"></line>
            </svg>
            Contact Us
          </span>
          <h2
            class="lab-heading reach-us-heading"
            style="font-size:clamp(1.1rem,2.5vw,1.5rem); margin-top:0; margin-bottom:0.5rem;"
          >
            We'd love to hear from you!
          </h2>
          <div style="display:flex; flex-direction:column; gap:0.75rem;">
            <div class="contact-info-card">
              <ContactInfo
                email="customer-service@madlabs.rocks"
                phone="(513) 306-5331"
                location="Greater Cincinnati Area"
              />
            </div>
            <div class="contact-response-card">
              <p style="font-size:0.9rem; color:var(--lab-text); line-height:1.6;">
                We typically respond within
                <strong style="color:var(--lab-heading);">2–4 hours</strong>
                during business hours. For urgent issues, mention it in your message and we'll prioritize
                your request.
              </p>
            </div>
          </div>

          <div class="contact-extras">
            <div>
              <h2
                class="lab-heading"
                style="font-size:clamp(1rem,2vw,1.3rem); margin-bottom:0.75rem; color:#e89050;"
              >
                Service Area
              </h2>
              <p class="lab-text" style="font-size:0.9rem; line-height:1.6; margin-bottom:0.6rem;">
                We serve the greater Cincinnati metropolitan area, including Cincinnati, Covington,
                Newport, and surrounding communities.
              </p>
              <p class="lab-text" style="font-size:0.9rem; line-height:1.6;">
                Remote diagnostics and software support are available for clients anywhere — we can
                diagnose and resolve many issues without an in-person visit.
              </p>
            </div>
            <div>
              <h2
                class="lab-heading"
                style="font-size:clamp(1rem,2vw,1.3rem); margin-bottom:0.75rem; color:#e89050;"
              >
                Hours
              </h2>
              <dl style="margin:0; padding:0;">
                <div
                  style="display:flex; justify-content:space-between; padding:0.35rem 0; border-bottom:1px solid var(--lab-border); font-size:0.9rem;"
                >
                  <dt style="color:var(--lab-heading); font-weight:500;">Monday – Friday</dt>
                  <dd style="color:var(--lab-text-muted); margin:0;">9:00 AM – 6:00 PM</dd>
                </div>
                <div
                  style="display:flex; justify-content:space-between; padding:0.35rem 0; border-bottom:1px solid var(--lab-border); font-size:0.9rem;"
                >
                  <dt style="color:var(--lab-heading); font-weight:500;">Saturday</dt>
                  <dd style="color:var(--lab-text-muted); margin:0;">10:00 AM – 4:00 PM</dd>
                </div>
                <div
                  style="display:flex; justify-content:space-between; padding:0.35rem 0; font-size:0.9rem;"
                >
                  <dt style="color:var(--lab-heading); font-weight:500;">Sunday</dt>
                  <dd style="color:var(--lab-text-muted); margin:0;">Closed</dd>
                </div>
              </dl>
              <p class="contact-dropoff-text">
                Hardware drop-offs by appointment only. Evening pickup available upon request.
              </p>
            </div>
          </div>
        </div>

        <!-- Right: tablet terminal -->
        <div class="contact-tablet-col">
          <!-- Instruction text — visible on all widths, positioned above tablet -->
          <div class="contact-tablet-instruction">
            <span class="instruction-orange">You may use this tablet to contact us online.</span>
            <span
              >— Click <strong>Book a Consultation</strong> for diagnostics, service planning, AI help,
              websites, or questions about what you need.</span
            >
            <span
              >— Click <strong>Submit a Repair Ticket</strong> for computer repair, tuneups, malware cleanup,
              network issues, or existing support requests.</span
            >
          </div>

          <!-- Mobile scroll cue -->
          <p class="contact-scroll-cue" aria-hidden="true">
            <span class="scroll-chevron"></span>
            Scroll down to book a consultation or submit a repair ticket.
            <span class="scroll-chevron"></span>
          </p>

          <ContactTablet />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero: 2-column grid (left=intro, right=instruction) ─── */
  .contact-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }

  @media (min-width: 1100px) {
    .contact-hero-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .contact-hero-left {
    display: flex;
    flex-direction: column;
    max-width: 460px;
  }

  .contact-hero-right {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
  }

  @media (max-width: 1099px) {
    .contact-hero-right {
      display: none;
    }
  }

  .contact-hero-heading {
    font-size: clamp(1.35rem, 3.2vw, 2.15rem) !important;
    margin-bottom: 0.5rem;
  }

  .contact-hero-text {
    font-size: clamp(0.85rem, 1.6vw, 1rem);
    color: var(--lab-text);
    line-height: 1.5;
    max-width: 460px;
  }

  /* ─── Two-column layout ─── */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 1100px) {
    .contact-layout {
      grid-template-columns: 1fr 1.2fr;
      gap: 3rem;
    }
  }

  @media (min-width: 1200px) {
    .contact-layout {
      gap: 4rem;
    }
  }

  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-extras {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ─── Typography: "Reach Us" and phone number in Jersey 25 ─── */
  .reach-us-heading {
    font-family: "Jersey 25", "VT323", "Courier New", monospace !important;
  }

  /* ─── Contact info card (Email/Phone/Location) ─── */
  .contact-info-card {
    position: relative;
    background: rgba(30, 26, 50, 0.6);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    transition: box-shadow 0.25s ease;
    /* Continuous orange border all around */
    box-shadow:
      inset 0 0 0 1px rgba(232, 144, 80, 0.25),
      inset 0 2px 0 rgba(232, 144, 80, 0.35),
      inset 0 -2px 0 rgba(232, 144, 80, 0.35),
      inset 2px 0 0 rgba(232, 144, 80, 0.35),
      inset -2px 0 0 rgba(232, 144, 80, 0.35);
  }
  .contact-info-card:hover {
    box-shadow:
      0 0 20px rgba(232, 144, 80, 0.06),
      inset 0 0 0 1px rgba(232, 144, 80, 0.35),
      inset 0 3px 0 rgba(232, 144, 80, 0.55),
      inset 0 -3px 0 rgba(232, 144, 80, 0.55),
      inset 3px 0 0 rgba(232, 144, 80, 0.55),
      inset -3px 0 0 rgba(232, 144, 80, 0.55);
  }

  /* ─── Dropoff text card ─── */
  .contact-dropoff-text {
    font-size: 0.82rem;
    color: var(--lab-text-muted);
    margin-top: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--lab-card);
    border: calc(1px * 1.05) solid var(--lab-border);
    border-radius: 8px;
    line-height: 1.5;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  .contact-dropoff-text:hover {
    border-color: rgba(232, 144, 80, 0.35);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 0 24px rgba(232, 144, 80, 0.08);
  }

  /* ─── Response-time card with service-card-style effects ─── */
  .contact-response-card {
    position: relative;
    isolation: isolate;
    background: var(--lab-card);
    border: calc(1px * 1.05) solid var(--lab-border);
    border-radius: 8px;
    padding: 1.25rem;
    overflow: hidden;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  .contact-response-card::before,
  .contact-response-card::after {
    content: "";
    position: absolute;
    top: 6px;
    bottom: 6px;
    width: 3px;
    border-radius: 2px;
    background: rgba(232, 144, 80, 0.25);
    pointer-events: none;
    z-index: 1;
    transition: background 0.25s ease;
  }
  .contact-response-card::before {
    left: 0;
  }
  .contact-response-card::after {
    right: 0;
  }
  .contact-response-card:hover::before,
  .contact-response-card:hover::after {
    background: rgba(232, 144, 80, 0.55);
  }

  .contact-response-card:hover {
    border-color: rgba(232, 144, 80, 0.35);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 0 24px rgba(232, 144, 80, 0.08);
  }

  .contact-response-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: linear-gradient(
      110deg,
      transparent 25%,
      rgba(232, 144, 80, 0.035) 48%,
      rgba(232, 144, 80, 0.07) 50%,
      rgba(232, 144, 80, 0.035) 52%,
      transparent 75%
    );
    background-size: 200% 100%;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: -1;
  }

  .contact-response-card:hover::after {
    opacity: 1;
    animation: response-shimmer 2s ease-in-out infinite;
  }

  @keyframes response-shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  /* ─── Tablet column ─── */
  .contact-tablet-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ─── Tablet instruction text ─── */
  .contact-tablet-instruction {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin: 0 0 0.75rem;
    color: var(--lab-text-muted);
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
    font-size: 0.78rem;
    line-height: 1.35;
    letter-spacing: 0.02em;
  }

  .contact-tablet-instruction strong {
    color: var(--lab-accent);
    font-weight: 600;
  }

  .instruction-orange {
    color: var(--lab-accent);
  }

  /* Hide the hero-right instruction on desktop since it's now in the tablet column */
  @media (min-width: 1100px) {
    .contact-hero-right {
      display: none;
    }
  }

  /* ─── Contact Us accent icon ─── */
  .contact-accent-wrap {
    display: inline-flex !important;
    align-items: center;
    gap: 0.25rem;
  }

  .contact-accent-icon {
    width: 1.5em;
    height: 1.5em;
    flex-shrink: 0;
  }

  /* ─── Mobile scroll cue ─── */
  .contact-scroll-cue {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0;
    color: var(--lab-text-muted);
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-align: center;
    text-transform: uppercase;
  }

  .scroll-chevron {
    display: inline-block;
    width: 0.6rem;
    height: 0.6rem;
    border-right: 2px solid var(--lab-accent);
    border-bottom: 2px solid var(--lab-accent);
    transform: rotate(45deg);
    opacity: 0.6;
  }

  @media (min-width: 1100px) {
    .contact-scroll-cue {
      display: none;
    }

    .contact-tablet-col {
      justify-content: flex-start;
      padding-top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-response-card {
      transition: none;
    }

    .contact-response-card::after {
      display: none;
    }

    .scroll-chevron {
      animation: none;
    }
  }
</style>
