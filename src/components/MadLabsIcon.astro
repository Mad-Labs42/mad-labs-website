---
export interface Props {
  name:
    | "clock"
    | "check"
    | "line"
    | "shield"
    | "users"
    | "diagnostic"
    | "quote"
    | "no-upsell"
    | "discount";
  class?: string;
}

const { name, class: className = "" } = Astro.props;

const icons: Record<string, string> = {
  clock: `<circle cx="8" cy="8" r="6"/><path d="M8 5v3.5l2 1.5"/>`,
  check: `<path d="M4 8.5 6.5 11 12 5.5"/>`,
  line: `<line x1="3" y1="8" x2="13" y2="8"/>`,
  shield: `<path d="M8 2.5 2 5.5v3c0 4.2 2.5 7.5 6 8.5 3.5-1 6-4.3 6-8.5v-3L8 2.5Z"/><path d="m6 8 1.5 1.5 3-3"/>`,
  users: `<path d="M3 10h14"/><path d="M10 3v14"/>`,
  diagnostic: `<circle cx="7" cy="7" r="4.5"/><path d="M10.5 10.5 13.5 13.5"/><path d="M5.5 7h1.2l.8-1.5 1.2 3 1-1.5h.8"/>`,
  quote: `<path d="M4.5 2.5h5L12.5 5.5v8h-8z"/><path d="M9.5 2.5v3h3"/><path d="M6 8h5"/><path d="M6 10.5h3.5"/>`,
  "no-upsell": `<path d="M4 4 12 12"/><path d="M12 4 4 12"/>`,
  discount: `<path d="M8 1.8 2.5 4.4v3.2c0 3.9 2.3 6.6 5.5 7.4 3.2-.8 5.5-3.5 5.5-7.4V4.4L8 1.8Z"/><path d="m6.2 8.1 1.3 1.3 2.7-3"/>`,
};
---

<span class={`trust-icon ${className}`} aria-hidden="true">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 16 16"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <g set:html={icons[name] || ""} />
  </svg>
</span>

<style>
  .trust-icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: var(--mad-labs-icon-size, 1rem);
    height: var(--mad-labs-icon-size, 1rem);
    color: var(--mad-labs-icon-color, var(--lab-accent, currentColor));
    line-height: 0;
  }

  .trust-icon svg {
    display: block;
    width: 100%;
    height: 100%;
    stroke: currentColor;
    stroke-width: var(--mad-labs-icon-stroke-width, 1.5);
  }
</style>
