---
// Process Steps — "How It Works" for Services page.
// Semantic <ol> with numbered steps for screen-reader clarity.
export interface Step {
  number: number;
  title: string;
  description: string;
}

const steps: Step[] = [
  {
    number: 1,
    title: "Diagnose",
    description:
      "We start by understanding the issue, checking the setup, and identifying the best path forward.",
  },
  {
    number: 2,
    title: "Quote",
    description:
      "You get a clear explanation of the work, the cost, and any parts or third-party services involved.",
  },
  {
    number: 3,
    title: "Fix / Build / Configure",
    description:
      "With your approval, we repair, upgrade, configure, automate, or build the solution.",
  },
  {
    number: 4,
    title: "Test & Walk Through",
    description:
      "We verify the work and make sure you understand what changed before the job is done.",
  },
];
---

<section class="process">
  <h2 class="process-heading">How It Works</h2>
  <ol class="process-list">
    {
      steps.map((step) => (
        <li class="process-step">
          <div class="step-marker" aria-hidden="true">
            <span class="step-number">{step.number}</span>
          </div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.description}</p>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .process {
    max-width: 700px;
    margin: 0 auto;
  }

  .process-heading {
    font-family: "Early GameBoy", "Jersey 25", monospace;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 400;
    color: var(--lab-heading, #e0d0ff);
    text-align: center;
    margin-bottom: 2rem;
  }

  ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    position: relative;
  }

  /* ─── Vertical connector trace ─── */
  .step-marker {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 36px;
    padding-top: 2px;
  }

  .step-number {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--lab-accent, #e89050);
    color: #000;
    font-size: 0.9rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 12px rgba(232, 144, 80, 0.3);
    font-family: "Jersey 25", monospace;
    position: relative;
    z-index: 1;
  }

  /* Trace line connecting steps */
  .step-marker::after {
    content: "";
    position: absolute;
    top: 38px;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: calc(100% + 1rem);
    background: linear-gradient(
      to bottom,
      rgba(232, 144, 80, 0.35),
      rgba(232, 144, 80, 0.1) 60%,
      transparent
    );
  }

  li:last-child .step-marker::after {
    display: none;
  }

  .step-content {
    flex: 1;
    padding-bottom: 1.5rem;
  }

  li:last-child .step-content {
    padding-bottom: 0;
  }

  .step-title {
    font-family: "Jersey 25", monospace;
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--lab-heading, #e0d0ff);
    margin-bottom: 0.2rem;
  }

  .step-desc {
    font-family: "Jersey 25", monospace;
    font-size: 0.9rem;
    color: var(--lab-text, #b0b0c8);
    line-height: 1.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .step-marker::after {
      display: none;
    }
  }
</style>
