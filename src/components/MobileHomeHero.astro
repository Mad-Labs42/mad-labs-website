---
// Mobile-only homepage hero for phones (< 768px).
// Reuses the exact MAD LABS atom symbol. Content is intentionally minimal so it
// does not duplicate the CTAs and copy that appear further down the page.
import CrtAtomLogo from "./CrtAtomLogo.astro";
import MadLabsGlassNav from "./MadLabsGlassNav.astro";
---

<section class="mobile-hero" aria-label="MAD LABS homepage">
  <div class="mobile-hero__glass" aria-hidden="true"></div>
  <div class="mobile-energy-field" aria-hidden="true">
    <span class="mobile-energy-field__particle mobile-energy-field__particle--cyan"></span>
    <span class="mobile-energy-field__particle mobile-energy-field__particle--pink"></span>
    <span class="mobile-energy-field__particle mobile-energy-field__particle--green"></span>
  </div>
  <div class="mobile-lab-hud" aria-hidden="true">
    <span class="mobile-lab-hud__corner mobile-lab-hud__corner--tl"></span>
    <span class="mobile-lab-hud__corner mobile-lab-hud__corner--tr"></span>
    <span class="mobile-lab-hud__corner mobile-lab-hud__corner--bl"></span>
    <span class="mobile-lab-hud__corner mobile-lab-hud__corner--br"></span>
    <span class="mobile-lab-trace mobile-lab-trace--primary"></span>
    <span class="mobile-lab-trace mobile-lab-trace--secondary"></span>
    <span class="mobile-lab-trace mobile-lab-trace--tertiary"></span>
  </div>

  <div class="mobile-hero-inner">
    <!-- Exact MAD LABS atom from CrtHero (unique gradientId avoids duplicate IDs) -->
    <div class="mobile-atom-slot">
      <CrtAtomLogo gradientId="nucleus-grad-mobile" />
    </div>

    <!-- Wordmark -->
    <h1 class="mobile-wordmark">MAD LABS</h1>

    <!-- Brand divider: > \ < -->
    <div class="mobile-divider" aria-hidden="true">
      <span class="mobile-divider-line mobile-divider-line--left"></span>
      <span class="mobile-divider-mark">&gt; \ &lt;</span>
      <span class="mobile-divider-line mobile-divider-line--right"></span>
    </div>

    <!-- Exact tagline from CrtHero.astro -->
    <p class="mobile-tagline">Computer Repair, Tech Support, &amp; AI Solutions</p>

    <!-- Primary mobile navigation -->
    <div class="mobile-hero-nav-slot">
      <MadLabsGlassNav context="mobile-hero" />
    </div>

    <!-- Scroll indicator -->
    <div class="mobile-scroll-indicator" aria-hidden="true">
      <svg class="mobile-scroll-indicator__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 9l6 6 6-6" />
      </svg>
      <span class="mobile-scroll-indicator__text">Scroll</span>
    </div>
  </div>
</section>

<style>
  .mobile-hero {
    position: relative;
    isolation: isolate;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 50% 31%, rgba(126, 88, 206, 0.36) 0%, rgba(64, 48, 115, 0.2) 34%, transparent 66%),
      radial-gradient(ellipse at 50% 100%, rgba(247, 158, 85, 0.1) 0%, transparent 54%),
      radial-gradient(ellipse at center, #3a2e5c 0%, #2c234a 35%, #1c1638 75%, #0c0820 100%);
    padding: 2rem 1rem;
    text-align: center;
  }

  .mobile-hero__glass,
  .mobile-energy-field,
  .mobile-lab-hud {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .mobile-hero__glass {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055) 0%, transparent 26%, rgba(255, 255, 255, 0.03) 100%),
      radial-gradient(circle at 50% 28%, rgba(238, 222, 255, 0.12) 0%, transparent 38%),
      repeating-linear-gradient(
        180deg,
        transparent 0,
        transparent 7px,
        rgba(235, 224, 255, 0.018) 7px,
        rgba(235, 224, 255, 0.018) 8px
      );
    opacity: 0.82;
  }

  .mobile-energy-field {
    inset: -8%;
    background:
      radial-gradient(circle at 20% 32%, rgba(77, 231, 255, 0.13) 0 1px, transparent 2px),
      radial-gradient(circle at 78% 28%, rgba(255, 79, 216, 0.12) 0 1px, transparent 2px),
      radial-gradient(circle at 72% 70%, rgba(0, 240, 122, 0.1) 0 1px, transparent 2px),
      radial-gradient(circle at 28% 76%, rgba(247, 158, 85, 0.12) 0 1px, transparent 2px);
    background-size: 92px 92px, 118px 118px, 132px 132px, 108px 108px;
    opacity: 0.58;
    animation: mobileHeroEnergyDrift 18s linear infinite;
  }

  .mobile-energy-field__particle {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    opacity: 0.68;
    transform: translate3d(0, 0, 0);
    animation: mobileHeroCorePulse 9s ease-in-out infinite;
  }

  .mobile-energy-field__particle--cyan {
    top: 23%;
    left: 17%;
    background: rgba(77, 231, 255, 0.82);
    box-shadow: 0 0 14px rgba(77, 231, 255, 0.5);
  }

  .mobile-energy-field__particle--pink {
    top: 36%;
    right: 15%;
    background: rgba(255, 79, 216, 0.76);
    box-shadow: 0 0 14px rgba(255, 79, 216, 0.46);
    animation-delay: -2.6s;
  }

  .mobile-energy-field__particle--green {
    right: 23%;
    bottom: 28%;
    background: rgba(0, 240, 122, 0.68);
    box-shadow: 0 0 14px rgba(0, 240, 122, 0.38);
    animation-delay: -5.2s;
  }

  .mobile-lab-hud {
    inset: clamp(14px, 4vw, 28px);
    opacity: 0.56;
    mix-blend-mode: screen;
  }

  .mobile-lab-hud__corner {
    position: absolute;
    width: clamp(42px, 14vw, 76px);
    height: clamp(42px, 14vw, 76px);
    border-color: rgba(238, 222, 255, 0.22);
    filter: drop-shadow(0 0 8px rgba(168, 116, 255, 0.22));
  }

  .mobile-lab-hud__corner::before,
  .mobile-lab-hud__corner::after {
    content: "";
    position: absolute;
    background: currentColor;
    border-radius: 999px;
    opacity: 0.72;
  }

  .mobile-lab-hud__corner::before {
    width: 22px;
    height: 1px;
  }

  .mobile-lab-hud__corner::after {
    width: 1px;
    height: 22px;
  }

  .mobile-lab-hud__corner--tl,
  .mobile-lab-hud__corner--tr {
    top: 0;
    color: rgba(77, 231, 255, 0.44);
    border-top: 1px solid;
  }

  .mobile-lab-hud__corner--bl,
  .mobile-lab-hud__corner--br {
    bottom: 0;
    color: rgba(247, 158, 85, 0.38);
    border-bottom: 1px solid;
  }

  .mobile-lab-hud__corner--tl,
  .mobile-lab-hud__corner--bl {
    left: 0;
    border-left: 1px solid;
  }

  .mobile-lab-hud__corner--tr,
  .mobile-lab-hud__corner--br {
    right: 0;
    border-right: 1px solid;
  }

  .mobile-lab-hud__corner--tl::before,
  .mobile-lab-hud__corner--bl::before {
    left: 8px;
  }

  .mobile-lab-hud__corner--tr::before,
  .mobile-lab-hud__corner--br::before {
    right: 8px;
  }

  .mobile-lab-hud__corner--tl::after,
  .mobile-lab-hud__corner--tr::after {
    top: 8px;
  }

  .mobile-lab-hud__corner--bl::after,
  .mobile-lab-hud__corner--br::after {
    bottom: 8px;
  }

  .mobile-lab-hud__corner--tl::before,
  .mobile-lab-hud__corner--tr::before {
    top: 8px;
  }

  .mobile-lab-hud__corner--bl::before,
  .mobile-lab-hud__corner--br::before {
    bottom: 8px;
  }

  .mobile-lab-hud__corner--tl::after,
  .mobile-lab-hud__corner--bl::after {
    left: 8px;
  }

  .mobile-lab-hud__corner--tr::after,
  .mobile-lab-hud__corner--br::after {
    right: 8px;
  }

  .mobile-lab-trace {
    position: absolute;
    height: 1px;
    width: clamp(94px, 28vw, 168px);
    border-radius: 999px;
    background:
      linear-gradient(90deg, transparent, rgba(238, 222, 255, 0.4), rgba(77, 231, 255, 0.34), transparent);
    opacity: 0.64;
    transform: translate3d(0, 0, 0);
    animation: mobileHeroTraceScan 12s ease-in-out infinite;
    will-change: transform, opacity;
  }

  .mobile-lab-trace::before,
  .mobile-lab-trace::after {
    content: "";
    position: absolute;
    top: -2px;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: rgba(238, 222, 255, 0.58);
    box-shadow: 0 0 10px rgba(168, 116, 255, 0.32);
  }

  .mobile-lab-trace::before {
    left: 18%;
  }

  .mobile-lab-trace::after {
    right: 14%;
  }

  .mobile-lab-trace--primary {
    top: 29%;
    right: min(7vw, 54px);
  }

  .mobile-lab-trace--secondary {
    left: min(6vw, 42px);
    bottom: 34%;
    width: clamp(76px, 24vw, 138px);
    background:
      linear-gradient(90deg, transparent, rgba(255, 79, 216, 0.26), rgba(247, 158, 85, 0.32), transparent);
    animation-delay: -4s;
  }

  .mobile-lab-trace--tertiary {
    left: 50%;
    bottom: 18%;
    width: clamp(62px, 20vw, 112px);
    background:
      linear-gradient(90deg, transparent, rgba(0, 240, 122, 0.26), rgba(77, 231, 255, 0.3), transparent);
    opacity: 0.45;
    animation-delay: -7s;
  }

  .mobile-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 420px;
  }

  /* Atom */
  .mobile-atom-slot {
    position: relative;
    width: clamp(120px, 38vw, 160px);
    height: clamp(120px, 38vw, 160px);
    margin: 0 auto 1.25rem;
  }

  .mobile-atom-slot::before {
    content: "";
    position: absolute;
    inset: 10%;
    z-index: -1;
    border-radius: 999px;
    background:
      radial-gradient(circle, rgba(238, 222, 255, 0.2) 0%, rgba(168, 116, 255, 0.12) 36%, transparent 72%);
    opacity: 0.86;
    transform: scale(0.98);
    animation: mobileHeroCorePulse 9s ease-in-out infinite;
  }

  .mobile-atom-slot :global(.crt-atom) {
    width: 100%;
    height: 100%;
    opacity: 1;
    transform: translateY(0) scale(1);
    animation: crtHeroNeonFlicker 6s infinite;
  }

  /* Boost atom orbit highlights for mobile visibility and true button colors */
  .mobile-hero-inner .mobile-atom-slot :global(.atom-orbit-highlight) {
    stroke-width: 5.5;
    mix-blend-mode: normal;
  }

  .mobile-hero-inner .mobile-atom-slot :global(.atom-orbit-highlight--one) {
    filter:
      drop-shadow(0 0 1px rgba(160, 240, 255, 1))
      drop-shadow(0 0 3px rgba(77, 231, 255, 0.98))
      drop-shadow(0 0 7px rgba(77, 231, 255, 0.85))
      drop-shadow(0 0 14px rgba(77, 231, 255, 0.55))
      drop-shadow(0 0 24px rgba(77, 231, 255, 0.28));
  }

  .mobile-hero-inner .mobile-atom-slot :global(.atom-orbit-highlight--two) {
    filter:
      drop-shadow(0 0 1px rgba(255, 210, 245, 1))
      drop-shadow(0 0 3px rgba(255, 79, 216, 0.98))
      drop-shadow(0 0 7px rgba(255, 79, 216, 0.85))
      drop-shadow(0 0 14px rgba(255, 79, 216, 0.55))
      drop-shadow(0 0 24px rgba(255, 79, 216, 0.28));
  }

  .mobile-hero-inner .mobile-atom-slot :global(.atom-orbit-highlight--three) {
    filter:
      drop-shadow(0 0 1px rgba(205, 255, 228, 1))
      drop-shadow(0 0 3px rgba(0, 240, 122, 0.98))
      drop-shadow(0 0 7px rgba(0, 240, 122, 0.85))
      drop-shadow(0 0 14px rgba(0, 240, 122, 0.55))
      drop-shadow(0 0 24px rgba(0, 240, 122, 0.28));
  }

  /* Wordmark */
  .mobile-wordmark {
    margin: 0 0 0.75rem;
    color: #ffffff;
    font-family: "Monofett", "Jersey 25", monospace;
    font-size: clamp(2.8rem, 12vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
    text-shadow:
      0 0 20px rgba(232, 144, 80, 0.5),
      0 0 40px rgba(147, 51, 234, 0.4);
  }

  /* Divider: > \ < */
  .mobile-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(90%, 340px);
    gap: 0.5rem;
    margin: 0 auto 1rem;
  }

  .mobile-divider-line {
    display: block;
    flex: 1 1 0;
    height: 2px;
    border-radius: 999px;
    background: #f79e55;
    box-shadow:
      0 0 4px rgba(247, 158, 85, 0.52),
      0 0 10px rgba(247, 158, 85, 0.24);
  }

  .mobile-divider-mark {
    flex: 0 0 auto;
    color: #f79e55;
    font-family: "Jersey 25", "Arial Rounded MT Bold", "Trebuchet MS", monospace;
    font-size: clamp(0.9rem, 3.4vw, 1.1rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0.075em;
    text-shadow:
      0 0 4px rgba(247, 158, 85, 0.46),
      0 0 9px rgba(247, 158, 85, 0.22);
  }

  /* Tagline */
  .mobile-tagline {
    margin: 0 0 1.5rem;
    color: #c8b8e0;
    font-family: "Jersey 25", "Arial Rounded MT Bold", "Trebuchet MS", monospace;
    font-size: clamp(0.95rem, 4vw, 1.15rem);
    font-weight: 400;
    line-height: 1.4;
    text-align: center;
  }

  /* Mobile nav slot */
  .mobile-hero-nav-slot {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  /* Scroll indicator */
  .mobile-scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    margin-top: 2rem;
    color: rgba(247, 158, 85, 0.72);
    opacity: 0.85;
  }

  .mobile-scroll-indicator__chevron {
    width: 22px;
    height: 22px;
    animation: mobileScrollBounce 2s ease-in-out infinite;
    filter: drop-shadow(0 0 4px rgba(247, 158, 85, 0.35));
  }

  .mobile-scroll-indicator__text {
    font-family: "Jersey 25", "Arial Rounded MT Bold", "Trebuchet MS", monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  @keyframes mobileScrollBounce {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.7;
    }

    50% {
      transform: translateY(5px);
      opacity: 1;
    }
  }

  @keyframes mobileHeroEnergyDrift {
    0% {
      transform: translate3d(-1.8%, -1.2%, 0);
    }

    50% {
      transform: translate3d(1.8%, 1.2%, 0);
    }

    100% {
      transform: translate3d(-1.8%, -1.2%, 0);
    }
  }

  @keyframes mobileHeroCorePulse {
    0%,
    100% {
      opacity: 0.58;
      transform: scale(0.96);
    }

    50% {
      opacity: 0.92;
      transform: scale(1.04);
    }
  }

  @keyframes mobileHeroTraceScan {
    0%,
    100% {
      opacity: 0.34;
      transform: translate3d(-8px, 0, 0);
    }

    45%,
    55% {
      opacity: 0.74;
      transform: translate3d(8px, 0, 0);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .mobile-energy-field,
    .mobile-energy-field__particle,
    .mobile-atom-slot::before,
    .mobile-lab-trace {
      animation: none;
      will-change: auto;
    }

    .mobile-atom-slot :global(.crt-atom) {
      animation: none;
    }

    .mobile-scroll-indicator__chevron {
      animation: none;
    }
  }

  @keyframes crtHeroNeonFlicker {
    0%,
    89%,
    92%,
    95%,
    100% {
      opacity: 1;
    }

    90%,
    93%,
    96% {
      opacity: 0.9;
    }
  }
</style>
