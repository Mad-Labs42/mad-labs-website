---
// AtomIcon.astro
// Small MAD LABS atom icon (3 orbits + nucleus) — reusable.
// Used in ContactInfo.astro and other components where the atom
// icon appears as a decorative inline element.
// Props mirror SVG attributes with sensible defaults.

interface Props {
  size?: number;
  class?: string;
}

const { size = 20, class: className } = Astro.props;
---

<svg
  viewBox="0 0 20 20"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  class:list={[className]}
  aria-hidden="true"
>
  <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#e89050" stroke-width="1.0" opacity="0.9" />
  <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#e89050" stroke-width="1.0" opacity="0.9" transform="rotate(60 10 10)" />
  <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#e89050" stroke-width="1.0" opacity="0.9" transform="rotate(-60 10 10)" />
  <circle cx="10" cy="10" r="1.35" fill="#ffffff" opacity="1" />
</svg>
