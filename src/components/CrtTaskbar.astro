---
import MadLabsGlassNav from './MadLabsGlassNav.astro';

export interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props as Props;
---

<div class="crt-taskbar-nav-shell">
  <MadLabsGlassNav context="crt-taskbar" currentPath={currentPath} />
</div>

<style>
  .crt-taskbar-nav-shell {
    width: 100%;
    min-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;

    /* CRT surface tokens passed to MadLabsGlassNav.is-crt-taskbar.
       Sizing/glow tokens live in the nav component so they override
       the mobile-hero defaults on the component itself. */
    --ml-nav-crt-surface-top: rgba(168, 124, 232, 0.52);
    --ml-nav-crt-surface-mid: rgba(108, 70, 182, 0.48);
    --ml-nav-crt-surface-bottom: rgba(52, 28, 102, 0.78);
    --ml-nav-crt-border: rgba(220, 192, 255, 0.78);
    --ml-nav-crt-inner-shine: rgba(255, 255, 255, 0.24);
    --ml-nav-crt-neon-glow: rgba(200, 160, 255, 0.45);
  }
</style>