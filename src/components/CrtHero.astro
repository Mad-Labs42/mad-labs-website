    pointer-events: none;
  }

  .crt-glitch-chroma {
    z-index: 31;
    mix-blend-mode: screen;
    background: linear-gradient(
      90deg,
      rgba(255, 30, 120, 0.15) 0%,
      transparent 20%,
      transparent 80%,
      rgba(0, 255, 170, 0.15) 100%
    );
  }

  .crt-glitch-static {
    z-index: 32;
    background-image:
      linear-gradient(transparent, transparent),
      repeating-linear-gradient(180deg, rgba(255, 255, 255, 0.1) 0 1px, rgba(0, 0, 0, 0.04) 1px 3px);
    mix-blend-mode: screen;
  }

  .crt-glitch-tear {
    z-index: 33;
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 24%,
      rgba(255, 255, 255, 0.14) 26%,
      transparent 28%,
      transparent 54%,
      rgba(255, 255, 255, 0.1) 56%,
      transparent 58%,
      transparent 100%
    );
  }

  .crt-glitch-slices {
    z-index: 34;
    background: linear-gradient(
      180deg,
      transparent 0 12%,
      rgba(255, 255, 255, 0.08) 12% 14%,
      transparent 14% 38%,
      rgba(255, 255, 255, 0.06) 38% 40%,
      transparent 40% 67%,
      rgba(255, 255, 255, 0.08) 67% 69%,
      transparent 69% 100%
    );
  }

  .crt-glare {
    position: absolute;
    z-index: 18;
    top: 3%;
    right: 0;
    left: 0;
    height: 36%;
    pointer-events: none;
    background: linear-gradient(
      162deg,
      rgba(255, 255, 255, 0.075) 0%,
      rgba(255, 255, 255, 0.015) 32%,
      transparent 58%,
      transparent 100%
    );
    clip-path: polygon(8% 0%, 92% 0%, 84% 100%, 16% 100%);
  }

  .crt-tint {
    position: absolute;
    inset: 0;
    z-index: 22;
    pointer-events: none;
    border-radius: 30px;
    mix-blend-mode: soft-light;
    background: linear-gradient(
      180deg,
      rgba(60, 0, 80, 0.08) 0%,
      rgba(20, 0, 60, 0.04) 50%,
      rgba(60, 0, 80, 0.08) 100%
    );
  }

  .crt-bands {
    position: absolute;
    inset: 0;
    z-index: 23;
    pointer-events: none;
    opacity: 0.78;
    mix-blend-mode: screen;
    will-change: background-position;
    background: repeating-linear-gradient(
      180deg,
      transparent 0,
      transparent 48px,
      rgba(255, 255, 255, 0.012) 48px,
      rgba(255, 255, 255, 0.012) 50px
    );
    animation: crtHeroRoll 10.7s linear infinite;
  }

  .crt-phosphor-dots {
    position: absolute;
    inset: 0;
    z-index: 21;
    pointer-events: none;
    mix-blend-mode: screen;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.09) 1px, transparent 1px);
    background-size: 3px 3px;
  }

  .crt-scanlines {
    position: absolute;
    inset: 0;
    z-index: 19;
    pointer-events: none;
    opacity: 0.72;
    background: repeating-linear-gradient(
      180deg,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.12) 2px,
      rgba(0, 0, 0, 0.12) 3px
    );
  }

  .crt-vignette {
    position: absolute;
    inset: 0;
    z-index: 20;
    pointer-events: none;
    background:
      radial-gradient(ellipse at top left, rgba(0, 0, 0, 0.18) 0%, transparent 50%),
      radial-gradient(ellipse at top right, rgba(0, 0, 0, 0.18) 0%, transparent 50%),
      radial-gradient(ellipse at bottom left, rgba(0, 0, 0, 0.18) 0%, transparent 50%),
      radial-gradient(ellipse at bottom right, rgba(0, 0, 0, 0.18) 0%, transparent 50%);
  }

  .crt-bevel-inner {
    position: absolute;
    inset: 0;
    z-index: 17;
    pointer-events: none;
    border-radius: 30px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 1px 0 0 rgba(255, 255, 255, 0.05),
      inset -1px 0 0 rgba(255, 255, 255, 0.05),
      inset 0 -1px 0 rgba(0, 0, 0, 0.42);
  }

  .crt-corner {
    position: absolute;
    z-index: 30;
    width: 22px;
    height: 22px;
    pointer-events: none;
    border-color: #9333ea;
    border-style: solid;
    opacity: 0.6;
    transition:
      opacity 0.38s ease,
      transform 0.38s ease;
  }

  .is-major-glitching .crt-corner,
  .is-restoring .crt-corner {
    opacity: 0;
    transform: scale(0.92);
  }

  /* Corner brackets remain subtly visible in stable state */
  .is-stable .crt-corner {
    opacity: 0.2;
    transform: scale(1);
  }

  .crt-corner--tl {
    top: 16px;
    left: 16px;
    border-width: 2px 0 0 2px;
  }

  .crt-corner--tr {
    top: 16px;
    right: 16px;
    border-width: 2px 2px 0 0;
  }

  .crt-corner--bl {
    bottom: 56px;
    left: 16px;
    border-width: 0 0 2px 2px;
  }

  .crt-corner--br {
    right: 16px;
    bottom: 56px;
    border-width: 0 2px 2px 0;
  }

  .crt-content {
    position: absolute;
    z-index: 10;
    inset: clamp(18px, 3.5vw, 42px) clamp(24px, 5vw, 72px) clamp(70px, 8vw, 96px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    will-change: opacity;
  }

  .crt-bloom {
    display: none;
  }

  .crt-atom {
    width: clamp(96px, 15vw, 206px);
    height: clamp(96px, 15vw, 206px);
    margin-bottom: clamp(8px, 1.4vw, 16px);
    overflow: visible;
    transform: translateY(10px) scale(0.88);
    transform-origin: center center;
    opacity: 0;
    transition:
      opacity 0.95s ease-out,
      transform 0.95s cubic-bezier(0.18, 0.84, 0.24, 1);
  }

  .is-atom-revealing .crt-atom,
  .is-title-sequencing .crt-atom,
  .is-title-glowing .crt-atom,
  .is-divider-opening .crt-atom,
  .is-restoring .crt-atom,
  .is-stable .crt-atom {
    opacity: 1;
    transform: translateY(0) scale(1);
    animation: crtHeroNeonFlicker 6s infinite;
  }

  .atom-orbits {
    --atom-ring-white: #fbf8ff;
    --atom-glow-orange: #ff9d3d;
    --atom-glow-pink: #ff4fd8;
    --atom-glow-green: #00f07a;

    overflow: visible;
    transform-origin: 88px 88px;
    animation: atomWireframeSpin 18s linear infinite;
    filter: drop-shadow(0 0 2px rgba(251, 248, 255, 0.2))
      drop-shadow(0 0 6px rgba(251, 248, 255, 0.12));
  }

  .atom-orbit {
    stroke: var(--atom-ring-white);
    stroke-width: 2.9;
    opacity: 0.84;
    filter: drop-shadow(0 0 1px rgba(255, 255, 255, 0.15));
  }

  .atom-orbit--two {
    opacity: 0.76;
  }

  .atom-orbit--three {
    opacity: 0.8;
  }

  .atom-nucleus-halo {
    transform-origin: 88px 88px;
    opacity: 0.8;
    filter: drop-shadow(0 0 5px rgba(216, 180, 254, 0.72))
      drop-shadow(0 0 15px rgba(147, 51, 234, 0.42));
    animation: atomNucleusShimmer 2.8s ease-in-out infinite;
  }

  .atom-nucleus-core {
    transform-origin: 88px 88px;
    opacity: 0.96;
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.78))
      drop-shadow(0 0 10px rgba(216, 180, 254, 0.58));
    animation: atomCoreShimmer 2.8s ease-in-out infinite;
  }

  .crt-wordmark-slot,
  .crt-divider-slot {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  .crt-divider-slot {
    position: relative;
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .is-title-sequencing .crt-wordmark-slot,
  .is-title-glowing .crt-wordmark-slot,
  .is-divider-building .crt-wordmark-slot,
  .is-divider-opening .crt-wordmark-slot,
  .is-restoring .crt-wordmark-slot,
  .is-stable .crt-wordmark-slot,
  .is-divider-building .crt-divider-slot,
  .is-divider-opening .crt-divider-slot {
    opacity: 1;
    transform: translateY(0);
  }

  .is-restoring .crt-divider-slot,
  .is-stable .crt-divider-slot {
    opacity: 1;
    transform: translateY(0);
  }

  .crt-tagline {
    max-width: 92%;
    margin: 0;
    color: #e9d8ff;
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
    font-size: clamp(0.82rem, 1.55vw, 1.45rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: clamp(0.06em, 0.5vw, 0.14em);
    text-align: center;
    text-transform: uppercase;
    white-space: nowrap;
    text-shadow:
      0 0 8px rgba(232, 144, 80, 0.38),
      0 0 16px rgba(232, 144, 80, 0.24);
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.55s cubic-bezier(0.18, 0.84, 0.24, 1),
      transform 0.55s cubic-bezier(0.18, 0.84, 0.24, 1);
    transition-delay: 0.34s;
  }

  .is-restoring .crt-tagline,
  .is-stable .crt-tagline {
    opacity: 1;
    transform: translateY(0);
  }

  .crt-taskbar-area {
    position: absolute;
    z-index: 25;
    right: 0;
    bottom: 0;
    left: 0;
    opacity: 0;
    transform: translateY(14px) scaleY(0.97);
    transition:
      opacity 0.68s cubic-bezier(0.18, 0.84, 0.24, 1),
      transform 0.68s cubic-bezier(0.18, 0.84, 0.24, 1);
    transition-delay: 0.76s;
  }

  .is-restoring .crt-taskbar-area,
  .is-stable .crt-taskbar-area {
    opacity: 1;
    transform: translateY(0) scaleY(1);
  }

  .is-major-glitching .crt-divider-slot,
  .is-major-glitching .crt-tagline,
  .is-major-glitching .crt-taskbar-area {
    opacity: 0 !important;
    transform: translateY(10px) scaleY(0.96) !important;
    transition-delay: 0s;
  }

  .crt-power-btn {
    position: absolute;
    z-index: 30;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    right: clamp(106px, 12.2vw, 160px);
    bottom: clamp(23px, 2.6vw, 46px);
    border: 1px solid rgba(104, 97, 92, 0.92);
    background: linear-gradient(180deg, #b5aea8 0%, #a59d97 100%);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.16),
      inset 0 -1px 1px rgba(84, 77, 72, 0.34),
      0 0 0 1px rgba(80, 73, 68, 0.1);
  }

  .crt-power-btn::before {
    content: "";
    position: absolute;
    z-index: -1;
    inset: -6px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 45%,
      rgba(111, 103, 98, 0.28) 0%,
      rgba(94, 87, 82, 0.2) 45%,
      rgba(56, 51, 48, 0.12) 72%,
      transparent 100%
    );
    box-shadow:
      inset 0 2px 3px rgba(70, 64, 60, 0.28),
      inset 0 -1px 2px rgba(255, 255, 255, 0.08);
  }

  .crt-power-btn::after {
    content: "";
    position: absolute;
    inset: 4px;
    border-radius: 50%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
    opacity: 0.65;
    pointer-events: none;
  }

  .crt-power-led {
    position: absolute;
    z-index: 30;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    right: clamp(82px, 9.8vw, 128px);
    bottom: clamp(27px, 3vw, 50px);
    background: radial-gradient(circle at 40% 35%, #8cff94 0%, #35e35a 45%, #12952a 100%);
    box-shadow:
      0 0 4px rgba(55, 227, 90, 0.65),
      0 0 10px rgba(55, 227, 90, 0.28);
  }

  /* ─── Mute Button (audio toggle on monitor housing) ─── */
  .crt-mute-btn {
    position: absolute;
    z-index: 30;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    left: clamp(106px, 12.2vw, 160px);
    bottom: clamp(23px, 2.6vw, 46px);
    border: 1px solid rgba(104, 97, 92, 0.92);
    background: linear-gradient(180deg, #b5aea8 0%, #a59d97 100%);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.16),
      inset 0 -1px 1px rgba(84, 77, 72, 0.34),
      0 0 0 1px rgba(80, 73, 68, 0.1);
    cursor: pointer;
  }

  .crt-mute-btn::before {
    content: "";
    position: absolute;
    z-index: -1;
    inset: -5px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 45%,
      rgba(111, 103, 98, 0.28) 0%,
      rgba(94, 87, 82, 0.2) 45%,
      rgba(56, 51, 48, 0.12) 72%,
      transparent 100%
    );
    box-shadow:
      inset 0 2px 3px rgba(70, 64, 60, 0.28),
      inset 0 -1px 2px rgba(255, 255, 255, 0.08);
  }

  .crt-mute-btn::after {
    content: "";
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
    opacity: 0.65;
    pointer-events: none;
  }

  .crt-mute-btn:focus-visible {
    outline: 2px solid rgba(247, 158, 85, 0.86);
    outline-offset: 6px;
  }

  .crt-mute-btn:hover {
    filter: brightness(1.2);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.22),
      inset 0 -1px 1px rgba(84, 77, 72, 0.34),
      0 0 10px rgba(247, 158, 85, 0.28);
  }

  .crt-mute-btn.is-muted {
    background: linear-gradient(180deg, #9e9792 0%, #908983 100%);
    box-shadow:
      inset 0 2px 3px rgba(40, 36, 32, 0.25),
      inset 0 -1px 1px rgba(84, 77, 72, 0.2),
      0 0 0 1px rgba(80, 73, 68, 0.1);
  }

  .crt-mute-btn.is-muted:hover {
    filter: brightness(1.1);
    box-shadow:
      inset 0 2px 3px rgba(40, 36, 32, 0.25),
      inset 0 -1px 1px rgba(84, 77, 72, 0.2),
      0 0 7px rgba(247, 158, 85, 0.18);
  }

  .crt-mute-led {
    position: absolute;
    z-index: 30;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    left: clamp(132px, 14.1vw, 184px);
    bottom: clamp(27px, 3vw, 50px);
    background: radial-gradient(circle at 40% 35%, #fcd34d 0%, #f59e0b 45%, #b45309 100%);
    box-shadow:
      0 0 4px rgba(245, 158, 11, 0.55),
      0 0 8px rgba(245, 158, 11, 0.22);
  }

  .crt-mute-led.is-muted {
    background: radial-gradient(circle at 40% 35%, #55504c 0%, #3d3936 45%, #242220 100%);
    box-shadow: none;
  }

  .is-crt-flicker-pop {
    filter: brightness(1.16) contrast(1.08);
  }

  .is-crt-glitch-minor {
    filter: saturate(1.08) contrast(1.06);
  }

  .is-crt-glitch-minor .crt-glitch-chroma,
  .is-crt-glitch-minor .crt-glitch-static,
  .is-crt-glitch-minor .crt-glitch-tear,
  .is-crt-glitch-minor .crt-glitch-slices {
    opacity: 1;
  }

  .is-crt-glitch-minor .crt-content {
    animation: crtJoltSmall 0.14s steps(2, end) infinite;
  }

  .is-crt-glitch-minor .crt-glitch-chroma {
    animation: crtChromaSmall 0.16s steps(2, end) infinite;
  }

  .is-crt-glitch-minor .crt-glitch-static {
    animation: crtStaticFuzz 0.1s steps(2, end) infinite;
  }

  .is-crt-glitch-minor .crt-glitch-tear {
    animation: crtTearScan 0.16s linear infinite;
  }

  .is-crt-glitch-major {
    filter: saturate(1.22) contrast(1.18) brightness(1.06);
  }

  .is-crt-glitch-major .crt-glitch-chroma,
  .is-crt-glitch-major .crt-glitch-static,
  .is-crt-glitch-major .crt-glitch-tear,
  .is-crt-glitch-major .crt-glitch-slices {
    opacity: 1;
  }

  .is-crt-glitch-major .crt-content,
  .is-crt-glitch-major .crt-taskbar-area {
    animation: crtJoltHard 0.08s steps(2, end) infinite;
  }

  .is-crt-glitch-major .crt-glitch-chroma {
    animation: crtChromaHard 0.08s steps(2, end) infinite;
  }

  .is-crt-glitch-major .crt-glitch-static {
    animation: crtStaticHard 0.05s steps(2, end) infinite;
  }

  .is-crt-glitch-major .crt-glitch-tear {
    animation: crtTearHard 0.08s linear infinite;
  }

  .is-crt-glitch-major .crt-glitch-slices {
    animation: crtSliceJump 0.08s steps(2, end) infinite;
  }

  .is-crt-proud-glow {
    animation: crtProudGlow 0.98s ease-out both;
  }

  .is-stable .crt-bands {
    animation-duration: 10.7s;
    opacity: 0.92;
  }

  .is-stable .crt-scanlines {
    opacity: 0.82;
  }

  .is-stable .crt-screen {
    filter: contrast(1.08) brightness(1.04) saturate(1.08);
  }

  .is-stable .crt-screen .crt-bands {
    animation-duration: 10.7s;
    opacity: 1;
  }

  .is-stable .crt-screen .crt-scanlines {
    background: repeating-linear-gradient(
      180deg,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.2) 2px,
      rgba(0, 0, 0, 0.2) 3px
    );
  }

  .is-stable .crt-screen .crt-phosphor-dots {
    opacity: 1;
    filter: brightness(1.14);
  }

  @keyframes crtPowerBloom {
    0% {
      opacity: 0;
      transform: scale(0.04);
    }

    16% {
      opacity: 1;
      transform: scale(0.16);
    }

    46% {
      opacity: 1;
      transform: scale(0.62);
    }

    82% {
      opacity: 0.9;
      transform: scale(1.08);
    }

    100% {
      opacity: 0;
      transform: scale(1.38);
    }
  }

  @keyframes crtPixelAtomSpin {
    from {
      transform: rotate(0deg);
    }

    to {
      transform: rotate(360deg);
    }
  }

  @keyframes crtPixelNucleusGlow {
    0%,
    100% {
      opacity: 0.78;
      filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.7))
        drop-shadow(0 0 9px rgba(216, 180, 254, 0.52));
    }

    50% {
      opacity: 1;
      filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.95))
        drop-shadow(0 0 14px rgba(216, 180, 254, 0.78));
    }
  }

  @keyframes crtLoadingAtomVanish {
    0% {
      opacity: 1;
      transform: scale(1);
      filter: brightness(1.05) drop-shadow(0 0 7px rgba(216, 180, 254, 0.34))
        drop-shadow(0 0 16px rgba(147, 51, 234, 0.2));
    }

    58% {
      opacity: 1;
      transform: scale(0.86);
      filter: brightness(1.55) drop-shadow(0 0 12px rgba(255, 255, 255, 0.5))
        drop-shadow(0 0 24px rgba(216, 180, 254, 0.38));
    }

    100% {
      opacity: 0;
      transform: scale(0.08);
      filter: brightness(2.2) drop-shadow(0 0 4px rgba(255, 255, 255, 0));
      visibility: hidden;
    }
  }

  @keyframes crtHeroFlicker {
    0%,
    100% {
      opacity: 1;
    }

    92% {
      opacity: 0.97;
    }

    93% {
      opacity: 1;
    }

    94% {
      opacity: 0.96;
    }

    95% {
      opacity: 1;
    }
  }

  @keyframes crtHeroRoll {
    0% {
      background-position: 0 0;
    }

    100% {
      background-position: 0 300px;
    }
  }

  @keyframes crtHeroNeonFlicker {
    0%,
    95%,
    100% {
      opacity: 1;
    }

    96% {
      opacity: 0.85;
    }

    97% {
      opacity: 1;
    }

    98% {
      opacity: 0.9;
    }
  }

  @keyframes atomWireframeSpin {
    from {
      transform: rotate(0deg);
    }

    to {
      transform: rotate(360deg);
    }
  }

  @keyframes atomNucleusShimmer {
    0%,
    100% {
      opacity: 0.68;
      transform: scale(0.96);
      filter: drop-shadow(0 0 4px rgba(216, 180, 254, 0.62))
        drop-shadow(0 0 12px rgba(147, 51, 234, 0.34));
    }

    50% {
      opacity: 0.95;
      transform: scale(1.08);
      filter: drop-shadow(0 0 7px rgba(255, 255, 255, 0.72))
        drop-shadow(0 0 19px rgba(216, 180, 254, 0.62))
        drop-shadow(0 0 28px rgba(147, 51, 234, 0.36));
    }
  }

  @keyframes atomCoreShimmer {
    0%,
    100% {
      opacity: 0.88;
      transform: scale(0.98);
    }

    50% {
      opacity: 1;
      transform: scale(1.12);
    }
  }

  @keyframes crtJoltSmall {
    0%,
    100% {
      transform: translate(0, 0);
    }

    25% {
      transform: translate(-1px, 0);
    }

    50% {
      transform: translate(1px, 0);
    }

    75% {
      transform: translate(0, 1px);
    }
  }

  @keyframes crtJoltHard {
    0%,
    100% {
      transform: translate(0, 0) skewX(0deg);
    }

    20% {
      transform: translate(-3px, 1px) skewX(-0.8deg);
    }

    40% {
      transform: translate(3px, -1px) skewX(0.7deg);
    }

    60% {
      transform: translate(-2px, 0) skewX(-0.4deg);
