---
import CrtTaskbar from "./CrtTaskbar.astro";
import CrtTypingLabel from "./CrtTypingLabel.astro";
import CrtDivider from "./CrtDivider.astro";
---

<section class="crt-hero" aria-label="MAD LABS homepage hero" data-crt-hero>
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="crt-bezel" data-crt-bezel>
    <div class="crt-bezel-rim" aria-hidden="true"></div>
    <div class="crt-bezel-inner-shadow" aria-hidden="true"></div>

    <div class="crt-screen" data-crt-screen>
      <div class="crt-metal" aria-hidden="true"></div>

      <div class="crt-boot-overlay" aria-hidden="true">
        <div class="crt-power-bloom"></div>

        <div class="crt-loading-icon" aria-hidden="true">
          <svg class="crt-loading-atom" viewBox="0 0 96 96" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="loading-nucleus-grad" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#ffffff"></stop>
                <stop offset="44%" stop-color="#d8b4fe"></stop>
                <stop offset="100%" stop-color="#9333ea"></stop>
              </radialGradient>
            </defs>

            <g class="loading-atom-orbits" aria-hidden="true">
              <ellipse class="loading-atom-orbit" cx="48" cy="48" rx="39" ry="18" fill="none"
              ></ellipse>
              <ellipse
                class="loading-atom-orbit"
                cx="48"
                cy="48"
                rx="39"
                ry="18"
                fill="none"
                transform="rotate(60 48 48)"></ellipse>
              <ellipse
                class="loading-atom-orbit"
                cx="48"
                cy="48"
                rx="39"
                ry="18"
                fill="none"
                transform="rotate(-60 48 48)"></ellipse>
            </g>

            <rect
              class="loading-atom-nucleus"
              x="42"
              y="42"
              width="12"
              height="12"
              rx="2"
              fill="url(#loading-nucleus-grad)"></rect>
          </svg>
        </div>
      </div>

      <div class="crt-shutdown-overlay" aria-hidden="true">
        <div class="crt-shutdown-bloom"></div>
        <p class="crt-goodbye-message">GOODBYE, HUMAN.</p>
      </div>

      <div class="crt-glitch-chroma" aria-hidden="true"></div>
      <div class="crt-glitch-static" aria-hidden="true"></div>
      <div class="crt-glitch-tear" aria-hidden="true"></div>
      <div class="crt-glitch-slices" aria-hidden="true"></div>

      <div class="crt-glare" aria-hidden="true"></div>
      <div class="crt-tint" aria-hidden="true"></div>
      <div class="crt-bands" aria-hidden="true"></div>
      <div class="crt-phosphor-dots" aria-hidden="true"></div>
      <div class="crt-scanlines" aria-hidden="true"></div>
      <div class="crt-vignette" aria-hidden="true"></div>
      <div class="crt-bevel-inner" aria-hidden="true"></div>

      <!-- Ambient floating particles inside CRT screen -->
      <div class="crt-particles" aria-hidden="true">
        <span
          class="crt-particle"
          style="--drift-x: 18px; --drift-y: -14px; --drift-dur: 12s; --drift-delay: 0s; left: 12%; top: 22%;"
        ></span>
        <span
          class="crt-particle"
          style="--drift-x: -22px; --drift-y: 10px; --drift-dur: 15s; --drift-delay: 1.8s; left: 28%; top: 65%;"
        ></span>
        <span
          class="crt-particle"
          style="--drift-x: 14px; --drift-y: -20px; --drift-dur: 18s; --drift-delay: 3.2s; left: 45%; top: 38%;"
        ></span>
        <span
          class="crt-particle"
          style="--drift-x: -16px; --drift-y: -8px; --drift-dur: 13s; --drift-delay: 5s; left: 62%; top: 72%;"
        ></span>
        <span
          class="crt-particle"
          style="--drift-x: 20px; --drift-y: 16px; --drift-dur: 16s; --drift-delay: 0.6s; left: 78%; top: 18%;"
        ></span>
        <span
          class="crt-particle"
          style="--drift-x: -10px; --drift-y: 22px; --drift-dur: 20s; --drift-delay: 7s; left: 88%; top: 52%;"
        ></span>
        <span
          class="crt-particle"
          style="--drift-x: 24px; --drift-y: -6px; --drift-dur: 14s; --drift-delay: 2.4s; left: 8%; top: 80%;"
        ></span>
        <span
          class="crt-particle"
          style="--drift-x: -18px; --drift-y: -16px; --drift-dur: 17s; --drift-delay: 4.6s; left: 55%; top: 8%;"
        ></span>
      </div>

      <div class="crt-corner crt-corner--tl" aria-hidden="true"></div>
      <div class="crt-corner crt-corner--tr" aria-hidden="true"></div>
      <div class="crt-corner crt-corner--bl" aria-hidden="true"></div>
      <div class="crt-corner crt-corner--br" aria-hidden="true"></div>

      <div class="crt-content">
        <svg
          class="crt-atom"
          viewBox="0 0 176 176"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <radialGradient id="nucleus-grad" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#ffffff"></stop>
              <stop offset="45%" stop-color="#d8b4fe"></stop>
              <stop offset="100%" stop-color="#9333ea"></stop>
            </radialGradient>
          </defs>

          <g class="atom-orbits">
            <ellipse
              class="atom-orbit atom-orbit--one"
              cx="88"
              cy="88"
              rx="82"
              ry="31"
              fill="none"
              transform="rotate(0 88 88)"></ellipse>
            <ellipse
              class="atom-orbit atom-orbit--two"
              cx="88"
              cy="88"
              rx="82"
              ry="31"
              fill="none"
              transform="rotate(60 88 88)"></ellipse>
            <ellipse
              class="atom-orbit atom-orbit--three"
              cx="88"
              cy="88"
              rx="82"
              ry="31"
              fill="none"
              transform="rotate(-60 88 88)"></ellipse>

            <ellipse
              class="atom-orbit-highlight atom-orbit-highlight--one"
              cx="88"
              cy="88"
              rx="82"
              ry="31"
              fill="none"
              transform="rotate(0 88 88)"></ellipse>
            <ellipse
              class="atom-orbit-highlight atom-orbit-highlight--two"
              cx="88"
              cy="88"
              rx="82"
              ry="31"
              fill="none"
              transform="rotate(60 88 88)"></ellipse>
            <ellipse
              class="atom-orbit-highlight atom-orbit-highlight--three"
              cx="88"
              cy="88"
              rx="82"
              ry="31"
              fill="none"
              transform="rotate(-60 88 88)"></ellipse>
          </g>

          <circle class="atom-nucleus-halo" cx="88" cy="88" r="14" fill="url(#nucleus-grad)"
          ></circle>
          <circle class="atom-nucleus-core" cx="88" cy="88" r="7" fill="#f8f0ff"></circle>
        </svg>

        <div class="crt-bloom" aria-hidden="true"></div>

        <div class="crt-wordmark-slot">
          <CrtTypingLabel />
        </div>

        <div class="crt-divider-slot">
          <CrtDivider />
        </div>

        <p class="crt-tagline">Computer Repair, Tech Support, &amp; AI Solutions</p>
      </div>

      <div class="crt-taskbar-area">
        <CrtTaskbar />
      </div>

      <!-- ARE YOU SURE? confirmation overlay -->
      <div class="crt-confirm-overlay" aria-hidden="true">
        <p class="crt-confirm-message">We're sorry to see you go! &mdash; ARE YOU SURE?</p>
        <div class="crt-confirm-buttons">
          <button class="crt-confirm-btn crt-confirm-yes" type="button">YES</button>
          <button class="crt-confirm-btn crt-confirm-no" type="button">NO</button>
        </div>
      </div>
    </div>

    <button
      class="crt-power-btn"
      type="button"
      aria-label="Turn CRT monitor off"
      aria-pressed="true"
      data-crt-power-button></button>
    <div class="crt-power-led" aria-hidden="true"></div>

    <!-- Audio mute button on monitor housing -->
    <button
      class="crt-mute-btn"
      type="button"
      aria-label="Mute CRT sounds"
      aria-pressed="false"
      data-crt-mute-button></button>
    <div class="crt-mute-led" aria-hidden="true"></div>
  </div>
</section>

<!-- Scroll-down indicator below CRT bezel -->
<div class="crt-scroll-indicator" aria-hidden="true" data-scroll-indicator>
  <span class="crt-scroll-chevron"></span>
</div>

<script>
  const crtHeroCandidate = document.querySelector<HTMLElement>("[data-crt-hero]");
  const crtScreenCandidate = document.querySelector<HTMLElement>("[data-crt-screen]");
  const powerButtonCandidate = document.querySelector<HTMLButtonElement>("[data-crt-power-button]");
  const confirmOverlayCandidate = document.querySelector<HTMLElement>(".crt-confirm-overlay");
  const confirmYesCandidate = document.querySelector<HTMLButtonElement>(".crt-confirm-yes");
  const confirmNoCandidate = document.querySelector<HTMLButtonElement>(".crt-confirm-no");

  if (
    crtHeroCandidate &&
    crtScreenCandidate &&
    powerButtonCandidate &&
    confirmOverlayCandidate &&
    confirmYesCandidate &&
    confirmNoCandidate
  ) {
    const crtHero = crtHeroCandidate;
    const crtScreen = crtScreenCandidate;
    const powerButton = powerButtonCandidate;
    const confirmOverlay = confirmOverlayCandidate;
    const confirmYesBtn = confirmYesCandidate;
    const confirmNoBtn = confirmNoCandidate;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const TIMELINE_DURATION_MS = 14800;
    const SAFETY_MARGIN_MS = 3000;
    const timers: number[] = [];
    let rafId: number | null = null;
    let safetyTimerId: number | null = null;
    let glareRafId: number | null = null;

    const heroPhaseClasses = [
      "is-loading",
      "is-powering-on",
      "is-atom-revealing",
      "is-title-sequencing",
      "is-title-glowing",
      "is-divider-building",
      "is-divider-opening",
      "is-major-glitching",
      "is-restoring",
      "is-final-glow",
      "is-stable",
      "is-shutting-down",
      "is-powered-off",
    ];

    const screenEffectClasses = [
      "is-crt-flicker-pop",
      "is-crt-glitch-minor",
      "is-crt-glitch-major",
      "is-crt-proud-glow",
    ];

    let isPoweredOn = true;
    let introPaused = false;
    let introWasActive = false;  // Was the intro running when overlay was shown?

    const introSeenStorageKey = "madlabs:crt-hero-intro-seen";

    const hasSeenIntroThisSession = (): boolean => {
      try {
        return window.sessionStorage.getItem(introSeenStorageKey) === "true";
      } catch {
        return false;
      }
    };

    const markIntroSeenThisSession = (): void => {
      try {
        window.sessionStorage.setItem(introSeenStorageKey, "true");
      } catch {
        // Storage can be unavailable in some privacy/browser modes.
      }
    };

    const clearTimers = (): void => {
      timers.forEach((timerId) => window.clearTimeout(timerId));
      timers.length = 0;
      if (rafId !== null) {
        window.cancelAnimationFrame(rafId);
        rafId = null;
      }
      if (safetyTimerId !== null) {
        window.clearTimeout(safetyTimerId);
        safetyTimerId = null;
      }
      if (glareRafId !== null) {
        window.cancelAnimationFrame(glareRafId);
        glareRafId = null;
      }
    };

    const schedule = (delay: number, callback: () => void): void => {
      timers.push(window.setTimeout(callback, delay));
    };

    const resetHeroState = (): void => {
      clearTimers();

      heroPhaseClasses.forEach((className) => {
        crtHero.classList.remove(className);
      });

      screenEffectClasses.forEach((className) => {
        crtScreen.classList.remove(className);
      });

      window.dispatchEvent(new CustomEvent("madlabs:hero-reset"));
    };

    const setPowerButtonState = (poweredOn: boolean): void => {
      powerButton.setAttribute(
        "aria-label",
        poweredOn ? "Turn CRT monitor off" : "Turn CRT monitor on",
      );
      powerButton.setAttribute("aria-pressed", poweredOn ? "true" : "false");
    };

    const showStablePoweredOnState = (): void => {
      resetHeroState();
      isPoweredOn = true;
      setPowerButtonState(true);
      crtHero.classList.add("is-stable");
      markIntroSeenThisSession();
    };

    const restartTimedClass = (element: HTMLElement, className: string, duration: number): void => {
      element.classList.remove(className);
      void element.offsetWidth;
      element.classList.add(className);

      schedule(duration, () => {
        element.classList.remove(className);
      });
    };

    const addHeroPhase = (className: string): void => {
      crtHero.classList.add(className);
    };

    const startTimeline = (): void => {
      resetHeroState();
      isPoweredOn = true;
      setPowerButtonState(true);
      void crtHero.offsetWidth;

      // Phase schedule: [time_ms, callback]
      // Times are relative to timeline start (t=0).
      // Tightened from original ~18.04s to ~14.8s.
      const phases: Array<[number, () => void]> = [
        [0, () => addHeroPhase("is-loading")],
        [
          450,
          () => {
            addHeroPhase("is-powering-on");
            startCrtHum();
          },
        ],
        [2800, () => addHeroPhase("is-atom-revealing")],
        [
          3800,
          () => {
            addHeroPhase("is-title-sequencing");
            scheduleTypingBlips();
            window.dispatchEvent(new CustomEvent("madlabs:hero-title-sequence-start"));
          },
        ],
        [
          6400,
          () => {
            addHeroPhase("is-title-glowing");
            window.dispatchEvent(new CustomEvent("madlabs:hero-title-glow-start"));
          },
        ],
        [
          7400,
          () => {
            crtHero.classList.remove("is-title-glowing");
            addHeroPhase("is-divider-building");
            window.dispatchEvent(new CustomEvent("madlabs:hero-divider-line-build"));
          },
        ],
        [
          8200,
          () => {
            addHeroPhase("is-divider-opening");
            window.dispatchEvent(new CustomEvent("madlabs:hero-divider-open"));
          },
        ],
        [9500, () => restartTimedClass(crtScreen, "is-crt-flicker-pop", 220)],
        [9800, () => restartTimedClass(crtScreen, "is-crt-glitch-minor", 720)],
        [
          11000,
          () => {
            addHeroPhase("is-major-glitching");
            restartTimedClass(crtScreen, "is-crt-glitch-major", 390);
          },
        ],
        [11560, () => restartTimedClass(crtScreen, "is-crt-glitch-major", 520)],
        [
          12800,
          () => {
            crtHero.classList.remove("is-major-glitching");
            addHeroPhase("is-restoring");
          },
        ],
        [
          14000,
          () => {
            addHeroPhase("is-final-glow");
            restartTimedClass(crtScreen, "is-crt-proud-glow", 980);
          },
        ],
        [
          14800,
          () => {
            crtHero.classList.remove("is-final-glow");
            addHeroPhase("is-stable");
            stopCrtHum();
            markIntroSeenThisSession();
          },
        ],
      ];

      // Set initial phase synchronously (avoids 1-frame gap before RAF starts)
      addHeroPhase("is-loading");

      // ----- requestAnimationFrame clock -----
      const startTime = performance.now();
      let phaseIndex = 0;

      const tick = (now: number): void => {
        // Skip phase advancement while confirmation overlay is visible
        if (introPaused) {
          rafId = window.requestAnimationFrame(tick);
          return;
        }

        const elapsed = now - startTime;

        // Fire all phases that are due
        while (phaseIndex < phases.length) {
          const phase = phases[phaseIndex];
          if (phase && elapsed >= phase[0]) {
            phase[1]();
            phaseIndex++;
          } else {
            break;
          }
        }

        if (phaseIndex < phases.length) {
          rafId = window.requestAnimationFrame(tick);
        }
      };

      rafId = window.requestAnimationFrame(tick);

      // ----- Fail-safe: force stable state if timeline stalls -----
      safetyTimerId = window.setTimeout(() => {
        if (!crtHero.classList.contains("is-stable")) {
          showStablePoweredOnState();
        }
      }, TIMELINE_DURATION_MS + SAFETY_MARGIN_MS);
    };

    const shutDownMonitor = (): void => {
      if (!isPoweredOn || crtHero.classList.contains("is-shutting-down")) {
        return;
      }

      isPoweredOn = false;
      clearTimers();

      heroPhaseClasses.forEach((className) => {
        crtHero.classList.remove(className);
      });

      screenEffectClasses.forEach((className) => {
        crtScreen.classList.remove(className);
      });

      stopCrtHum();

      window.dispatchEvent(new CustomEvent("madlabs:hero-reset"));

      crtHero.classList.add("is-shutting-down");
      setPowerButtonState(false);

      schedule(2850, () => {
        crtHero.classList.remove("is-shutting-down");
        crtHero.classList.add("is-powered-off");
      });
    };

    const powerOnMonitor = (): void => {
      if (isPoweredOn || crtHero.classList.contains("is-shutting-down")) {
        return;
      }

      startTimeline();
    };

    const showConfirmOverlay = (): void => {
      confirmOverlay.classList.add("is-visible");
      confirmOverlay.setAttribute("aria-hidden", "false");
      confirmYesBtn.focus();

      // Pause the intro timeline if it's running
      if (!crtHero.classList.contains("is-stable") &&
          !crtHero.classList.contains("is-shutting-down") &&
          !crtHero.classList.contains("is-powered-off")) {
        introWasActive = true;
        introPaused = true;
      }
    };

    const hideConfirmOverlay = (): void => {
      confirmOverlay.classList.remove("is-visible");
      confirmOverlay.setAttribute("aria-hidden", "true");

      // Resume intro if it was paused
      if (introWasActive) {
        introPaused = false;
        introWasActive = false;
      }
    };

    powerButton.addEventListener("click", () => {
      if (crtHero.classList.contains("is-powered-off")) {
        powerOnMonitor();
        return;
      }

      // Always show confirmation overlay before any power action
      showConfirmOverlay();
    });

    confirmYesBtn.addEventListener("click", () => {
      hideConfirmOverlay();
      introWasActive = false; // Don't resume — we're shutting down
      introPaused = false;
      shutDownMonitor();
    });

    confirmNoBtn.addEventListener("click", () => {
      hideConfirmOverlay();
      // Intro timeline resumes automatically via hideConfirmOverlay
      // If stable, overlay just closes with no other action
    });

    // ─── Audio System ──────────────────────────────────────
    let audioCtx: AudioContext | null = null;
    let crtHumOsc1: OscillatorNode | null = null;
    let crtHumOsc2: OscillatorNode | null = null;
    let crtHumGain: GainNode | null = null;
    let isMuted = false;

    const MUTE_STORAGE_KEY = "madlabs:crt-mute";

    try {
      audioCtx = new AudioContext();
    } catch {
      // Web Audio API not available — audio calls become no-ops
    }

    const loadMutePreference = (): void => {
      try {
        isMuted = localStorage.getItem(MUTE_STORAGE_KEY) === "true";
      } catch {
        isMuted = false;
      }
    };

    const saveMutePreference = (): void => {
      try {
        localStorage.setItem(MUTE_STORAGE_KEY, String(isMuted));
      } catch {
        // Storage may be unavailable
      }
    };

    const ensureAudioContext = (): AudioContext | null => {
      if (!audioCtx) return null;
      if (audioCtx.state === "suspended") {
        // Fire-and-forget resume; the blip will be silent if not yet resumed
        audioCtx.resume().catch(() => {});
      }
      // Return the context regardless — the oscillator scheduling will
      // play when the context is running. If still suspended, the sound
      // is queued and plays as soon as the context resumes.
      if (audioCtx.state === "closed") return null;
      return audioCtx;
    };

    const playTypingBlip = (): void => {
      const ctx = ensureAudioContext();
      if (!ctx || isMuted) return;
      try {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type = "square";
        osc.frequency.setValueAtTime(800, ctx.currentTime);
        gain.gain.setValueAtTime(0.14, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.06);
        osc.connect(gain).connect(ctx.destination);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.06);
      } catch {
        // Audio context may be in a broken state; safely skip
      }
    };

    const startCrtHum = (): void => {
      const ctx = ensureAudioContext();
      if (!ctx || isMuted || crtHumGain) return;
      try {
        crtHumGain = ctx.createGain();
        crtHumGain.gain.setValueAtTime(0, ctx.currentTime);
        crtHumGain.gain.linearRampToValueAtTime(0.05, ctx.currentTime + 1.2);

        crtHumOsc1 = ctx.createOscillator();
        crtHumOsc1.type = "sine";
        crtHumOsc1.frequency.setValueAtTime(60, ctx.currentTime);

        crtHumOsc2 = ctx.createOscillator();
        crtHumOsc2.type = "sine";
        crtHumOsc2.frequency.setValueAtTime(120, ctx.currentTime);

        crtHumOsc1.connect(crtHumGain);
        crtHumOsc2.connect(crtHumGain);
        crtHumGain.connect(ctx.destination);

        crtHumOsc1.start(ctx.currentTime);
        crtHumOsc2.start(ctx.currentTime);
      } catch {
        // Tear down partial setup if any step failed
        stopCrtHum();
      }
    };

    const stopCrtHum = (): void => {
      if (!crtHumGain || !audioCtx) {
        crtHumGain = null;
        crtHumOsc1 = null;
        crtHumOsc2 = null;
        return;
      }
      try {
        // Capture references before nulling so the timeout cleanup still works
        const gain = crtHumGain;
        const osc1 = crtHumOsc1;
        const osc2 = crtHumOsc2;

        // Null immediately — allows a new hum to start right away
        crtHumGain = null;
        crtHumOsc1 = null;
        crtHumOsc2 = null;

        const now = audioCtx.currentTime;
        gain.gain.cancelScheduledValues(0);
        gain.gain.setValueAtTime(gain.gain.value, now);
        gain.gain.linearRampToValueAtTime(0, now + 0.8);

        // Disconnect after fade-out (don't keep the old nodes alive)
        window.setTimeout(() => {
          try { osc1?.stop(); } catch { /* already stopped */ }
          try { osc2?.stop(); } catch { /* already stopped */ }
          osc1?.disconnect();
          osc2?.disconnect();
          gain.disconnect();
        }, 850);
      } catch {
        crtHumGain = null;
        crtHumOsc1 = null;
        crtHumOsc2 = null;
      }
    };

    // Schedule typing blips to mirror CSS letter animation timing.
    // Uses raw setTimeout (NOT schedule) so clearTimers() doesn't kill them.
    const scheduleTypingBlips = (): void => {
      // Letter timings (from CrtTypingLabel's letterStepSeconds: 0.228s)
      // "M" "A" "D" " " "L" "A" "B" "S" — skip the space
      const offsets = [0, 228, 456, /* space */ 912, 1140, 1368, 1596];
      offsets.forEach((offset) => {
        window.setTimeout(playTypingBlip, offset);
      });
    };

    const muteButtonCandidate = document.querySelector<HTMLButtonElement>("[data-crt-mute-button]");

    if (muteButtonCandidate) {
      const muteBtn = muteButtonCandidate;
      const muteLed = muteBtn.nextElementSibling;

      loadMutePreference();

      const updateMuteUI = (): void => {
        muteBtn.setAttribute("aria-pressed", isMuted ? "true" : "false");
        muteBtn.setAttribute("aria-label", isMuted ? "Unmute CRT sounds" : "Mute CRT sounds");
        muteBtn.classList.toggle("is-muted", isMuted);
        if (muteLed instanceof HTMLElement) {
          muteLed.classList.toggle("is-muted", isMuted);
        }
      };

      updateMuteUI();

      muteBtn.addEventListener("click", () => {
        isMuted = !isMuted;
        updateMuteUI();
        saveMutePreference();

        if (isMuted) {
          stopCrtHum();
        } else {
          // Restart hum if we're in any boot phase (not stable, not off, not shutting down)
          const isBooting =
            !crtHero.classList.contains("is-stable") &&
            !crtHero.classList.contains("is-powered-off") &&
            !crtHero.classList.contains("is-shutting-down");
          if (isBooting) {
            startCrtHum();
          }
        }
      });
    }

    // Resume AudioContext on first user interaction (browser autoplay policy)
    const autoResumeAudio = (): void => {
      if (audioCtx && audioCtx.state === "suspended") {
        audioCtx.resume().catch(() => {});
      }
    };

    document.addEventListener("click", autoResumeAudio, { once: true });
    document.addEventListener("keydown", autoResumeAudio, { once: true });
    document.addEventListener("touchstart", autoResumeAudio, { once: true, passive: true });

    // ─── Mouse-Responsive Screen Glare ─────────────────────
    const glare = crtScreen.querySelector<HTMLElement>(".crt-glare");
    let targetGlareX = 0;
    let targetGlareY = 0;
    let currentGlareX = 0;
    let currentGlareY = 0;

    if (glare) {
      const MAX_GLARE_SHIFT = 14;

      crtScreen.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = crtScreen.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width;
        const y = (e.clientY - rect.top) / rect.height;
        targetGlareX = (x - 0.5) * 2 * MAX_GLARE_SHIFT;
        targetGlareY = (y - 0.5) * 2 * MAX_GLARE_SHIFT;
      });

      crtScreen.addEventListener("mouseleave", () => {
        targetGlareX = 0;
        targetGlareY = 0;
      });

      const updateGlarePosition = (): void => {
        currentGlareX += (targetGlareX - currentGlareX) * 0.08;
        currentGlareY += (targetGlareY - currentGlareY) * 0.08;
        glare.style.transform = `translate(${currentGlareX.toFixed(1)}px, ${currentGlareY.toFixed(1)}px)`;
        glareRafId = window.requestAnimationFrame(updateGlarePosition);
      };

      glareRafId = window.requestAnimationFrame(updateGlarePosition);
    }

    if (prefersReducedMotion) {
      crtHero.classList.add("is-reduced-motion");
      showStablePoweredOnState();
    } else if (hasSeenIntroThisSession()) {
      showStablePoweredOnState();
    } else {
      startTimeline();
    }

    document.addEventListener(
      "astro:before-swap",
      () => {
        clearTimers();
      },
      { once: true },
    );

    // ─── Momentum Skip-Link Handler ─────────────────────────
    document.addEventListener("madlabs:skip-intro", () => {
      if (!crtHero.classList.contains("is-stable")) {
        // Accelerated transition: add all intermediate classes then
        // force stable state after a brief blur animation
        crtHero.classList.add("is-skip-compressing");
        clearTimers();
        stopCrtHum();
        window.setTimeout(() => {
          showStablePoweredOnState();
        }, 600);
      }
    });

    // ─── Scroll-Down Indicator ──────────────────────────────
    const scrollIndicator = document.querySelector<HTMLElement>("[data-scroll-indicator]");

    if (scrollIndicator) {
      let indicatorShown = false;

      const showIndicator = (): void => {
        if (!indicatorShown) {
          indicatorShown = true;
          scrollIndicator.classList.add("is-visible");
        }
      };

      const hideIndicator = (): void => {
        if (indicatorShown) {
          indicatorShown = false;
          scrollIndicator.classList.remove("is-visible");
        }
      };

      // Show indicator when stable, hide after 200px scroll
      const observer = new MutationObserver(() => {
        if (crtHero.classList.contains("is-stable") && !indicatorShown) {
          showIndicator();
        }
      });

      observer.observe(crtHero, { attributes: true, attributeFilter: ["class"] });

      // Initial check in case we're already stable
      if (crtHero.classList.contains("is-stable")) {
        showIndicator();
      }

      window.addEventListener(
        "scroll",
        () => {
          if (window.scrollY > 200) {
            hideIndicator();
          } else if (crtHero.classList.contains("is-stable")) {
            showIndicator();
          }
        },
        { passive: true },
      );
    }
  }
</script>

