---
// ContactInfo — structured contact details using a semantic <dl>.
export interface Props {
  email: string;
  phone?: string;
  location?: string;
}

const { email, phone, location } = Astro.props;

const telHref = phone ? `tel:${phone.replace(/[\s()-]/g, "")}` : "";
---

<dl class="contact-list">
  <div class="contact-item">
    <dt class="ci-dt">
      <svg class="ci-atom" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#00b86e" stroke-width="0.8" opacity="0.7"/>
        <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#00b86e" stroke-width="0.8" opacity="0.7" transform="rotate(60 10 10)"/>
        <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#00b86e" stroke-width="0.8" opacity="0.7" transform="rotate(-60 10 10)"/>
        <circle cx="10" cy="10" r="1.5" fill="#00b86e" opacity="0.9"/>
      </svg>
      Email
    </dt>
    <dd><a href="mailto:{email}">{email}</a></dd>
  </div>
  {
    phone && (
      <div class="contact-item contact-phone">
        <dt class="ci-dt">
          <svg class="ci-atom" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#00b86e" stroke-width="0.8" opacity="0.7"/>
            <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#00b86e" stroke-width="0.8" opacity="0.7" transform="rotate(60 10 10)"/>
            <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#00b86e" stroke-width="0.8" opacity="0.7" transform="rotate(-60 10 10)"/>
            <circle cx="10" cy="10" r="1.5" fill="#00b86e" opacity="0.9"/>
          </svg>
          Phone
        </dt>
        <dd>
          <a href={telHref}>{phone}</a>
        </dd>
      </div>
    )
  }
  {
    location && (
      <div class="contact-item">
        <dt class="ci-dt">
          <svg class="ci-atom" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#00b86e" stroke-width="0.8" opacity="0.7"/>
            <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#00b86e" stroke-width="0.8" opacity="0.7" transform="rotate(60 10 10)"/>
            <ellipse cx="10" cy="10" rx="7" ry="2.5" stroke="#00b86e" stroke-width="0.8" opacity="0.7" transform="rotate(-60 10 10)"/>
            <circle cx="10" cy="10" r="1.5" fill="#00b86e" opacity="0.9"/>
          </svg>
          Location
        </dt>
        <dd>{location}</dd>
      </div>
    )
  }
</dl>

<style>
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .contact-item > .ci-dt {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: #e89050;
  }

  .contact-item > dd {
    padding-left: calc(0.9rem + 0.35rem); /* match icon width + gap */
  }

  dt {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--lab-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ci-dt {
    color: #e89050;
  }

  .ci-atom {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
  }

  dd {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: #ffffff;
    margin: 0;
  }

  dd a {
    color: #00b86e;
    text-decoration: none;
    font-weight: 500;
  }

  .contact-phone a {
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    color: #00b86e;
  }

  dd a:hover {
    color: #fff;
    text-decoration: underline;
  }

  dd a:focus {
    outline: 2px solid var(--lab-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
