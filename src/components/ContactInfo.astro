---
import AtomIcon from "./AtomIcon.astro";
// ContactInfo — structured contact details using a semantic <dl>.
export interface Props {
  email: string;
  phone?: string;
  location?: string;
}

const { email, phone, location } = Astro.props;

const telHref = phone ? `tel:${phone.replace(/[\s()-]/g, "")}` : "";
---
import AtomIcon from "./AtomIcon.astro";

<dl class="contact-list">
  <div class="contact-item">
    <dt class="ci-dt">
      <AtomIcon class="ci-atom" />
      Email
    </dt>
    <dd><a href="mailto:{email}">{email}</a></dd>
  </div>
  {
    phone && (
      <div class="contact-item contact-phone">
        <dt class="ci-dt">
          <AtomIcon class="ci-atom" />
          Phone
        </dt>
        <dd>
          <a href={telHref}>{phone}</a>
        </dd>
      </div>
    )
  }
  {
    location && (
      <div class="contact-item">
        <dt class="ci-dt">
          <AtomIcon class="ci-atom" />
          Location
        </dt>
        <dd>{location}</dd>
      </div>
    )
  }
</dl>

<style>
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .contact-item > .ci-dt {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: #e89050;
  }

  .contact-item > dd {
    padding-left: calc(1.35rem + 0.35rem); /* match icon width + gap */
  }

  dt {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--lab-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ci-dt {
    color: #e89050;
  }

  .ci-atom {
    width: 1.35rem;
    height: 1.35rem;
    flex-shrink: 0;
  }

  dd {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: #ffffff;
    margin: 0;
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
  }

  dd a {
    color: #00b86e;
    text-decoration: none;
    font-weight: 500;
  }

  .contact-phone a {
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    color: #00b86e;
  }

  dd a:hover {
    color: #fff;
    text-decoration: underline;
  }

  dd a:focus {
    outline: 2px solid var(--lab-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
