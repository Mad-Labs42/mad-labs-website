---
// ContactInfo — structured contact details using a semantic <dl>.
export interface Props {
  email: string;
  phone?: string;
  location?: string;
}

const { email, phone, location } = Astro.props;

const telHref = phone ? `tel:${phone.replace(/[\s()-]/g, "")}` : "";
---

<dl class="contact-list">
  <div class="contact-item">
    <dt>Email</dt>
    <dd><a href="mailto:{email}">{email}</a></dd>
  </div>
  {
    phone && (
      <div class="contact-item">
        <dt>Phone</dt>
        <dd>
          <a href={telHref}>{phone}</a>
        </dd>
      </div>
    )
  }
  {
    location && (
      <div class="contact-item">
        <dt>Location</dt>
        <dd>{location}</dd>
      </div>
    )
  }
</dl>

<style>
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  dt {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--lab-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  dd {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--lab-heading);
    margin: 0;
  }

  dd a {
    color: var(--lab-accent);
    text-decoration: none;
    font-weight: 500;
  }

  dd a:hover {
    color: #fff;
    text-decoration: underline;
  }

  dd a:focus {
    outline: 2px solid var(--lab-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
