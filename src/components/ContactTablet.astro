---
// src/components/ContactTablet.astro
// CRT-themed intake terminal with 3 states: menu, booking, ticket.
// Placeholder-safe — replace realEmbedUrl values when Zoho snippets are provided.
---

<div class="contact-tablet" data-tablet-root aria-label="MAD LABS intake terminal">
  <!-- Tablet bezel with integrated bottom housing -->
  <div class="tablet-bezel">
    <!-- Top bezel strip with LED — minimal, like a tablet camera/sensor bar -->
    <div class="tablet-top-bar" aria-hidden="true">
      <span class="tablet-led"></span>
    </div>

    <!-- Screen area -->
    <div class="tablet-screen" data-tablet-screen>
      <div class="tablet-glare" aria-hidden="true"></div>
      <div class="tablet-tint" aria-hidden="true"></div>
      <div class="tablet-bands" aria-hidden="true"></div>
      <div class="tablet-phosphor-dots" aria-hidden="true"></div>
      <div class="tablet-scanlines" aria-hidden="true"></div>
      <div class="tablet-vignette" aria-hidden="true"></div>
      <div class="tablet-bevel-inner" aria-hidden="true"></div>

      <!-- Corner brackets — lab equipment detail -->
      <div class="tablet-corner tablet-corner--tl" aria-hidden="true"></div>
      <div class="tablet-corner tablet-corner--tr" aria-hidden="true"></div>
      <div class="tablet-corner tablet-corner--bl" aria-hidden="true"></div>
      <div class="tablet-corner tablet-corner--br" aria-hidden="true"></div>

      <!-- ─── State: Menu ─── -->
      <div class="tablet-state" data-tablet-state="menu">
        <div class="tablet-menu-content">
          <p class="tablet-logo">MAD LABS</p>
          <p class="tablet-menu-label">
            Welcome!<span class="tablet-cursor" aria-hidden="true">_</span>
          </p>
          <div class="tablet-menu-buttons">
            <button
              class="tablet-btn tablet-btn--primary"
              data-tablet-action="booking"
              type="button"
            >
              <span class="tablet-btn-icon" aria-hidden="true">[BOOK]</span>
              <span class="tablet-btn-label">Book a Consultation</span>
              <span class="tablet-btn-hint"
                >Diagnostics, service planning, AI help, websites, or questions</span
              >
            </button>
            <button
              class="tablet-btn tablet-btn--secondary"
              data-tablet-action="ticket"
              type="button"
            >
              <span class="tablet-btn-icon" aria-hidden="true">[REPAIR]</span>
              <span class="tablet-btn-label">Submit a Repair Ticket</span>
              <span class="tablet-btn-hint"
                >Computer repair, tuneups, malware, network, or existing requests</span
              >
            </button>
          </div>
        </div>
      </div>

      <!-- ─── State: Booking ─── -->
      <div class="tablet-state" data-tablet-state="booking" hidden>
        <div class="tablet-iframe-wrapper">
          <!--
            When BOOKING_EMBED_URL is set, uncomment:
            <iframe class="tablet-iframe" src={BOOKING_EMBED_URL} title="Book a consultation with MAD LABS" sandbox="allow-forms allow-scripts allow-same-origin allow-popups" loading="lazy"></iframe>
          -->
          <div class="tablet-placeholder">
            <div class="placeholder-panel">
              <span class="placeholder-icon" aria-hidden="true">[B]</span>
              <h3 class="placeholder-heading">Booking Terminal Ready</h3>
              <p class="placeholder-text">
                The consultation booking system is configured and waiting for the Zoho Bookings
                embed URL.
              </p>
              <div class="placeholder-status">
                <span class="status-dot"></span>Awaiting embed URL
              </div>
              <a
                href="mailto:customer-service@madlabs.rocks?subject=Consultation%20Request"
                class="placeholder-fallback"
                data-analytics-event="contact_fallback_booking"
                target="_blank"
                rel="noopener noreferrer">Book by Email instead →</a
              >
            </div>
          </div>
        </div>
        <button class="tablet-back-btn" data-tablet-action="back" type="button">← Back</button>
      </div>

      <!-- ─── State: Ticket ─── -->
      <div class="tablet-state" data-tablet-state="ticket" hidden>
        <div class="tablet-iframe-wrapper">
          <!--
            When TICKET_EMBED_URL is set, uncomment:
            <iframe class="tablet-iframe" src={TICKET_EMBED_URL} title="Submit a repair ticket to MAD LABS" sandbox="allow-forms allow-scripts allow-same-origin allow-popups" loading="lazy"></iframe>
          -->
          <div class="tablet-placeholder">
            <div class="placeholder-panel">
              <span class="placeholder-icon" aria-hidden="true">[T]</span>
              <h3 class="placeholder-heading">Repair Ticket Terminal Ready</h3>
              <p class="placeholder-text">
                The repair ticket system is configured and waiting for the Zoho Forms or Zoho Desk
                embed URL.
              </p>
              <div class="placeholder-status">
                <span class="status-dot"></span>Awaiting embed URL
              </div>
              <a
                href="mailto:customer-service@madlabs.rocks?subject=Repair%20Ticket"
                class="placeholder-fallback"
                data-analytics-event="contact_fallback_ticket"
                target="_blank"
                rel="noopener noreferrer">Submit by Email instead →</a
              >
            </div>
          </div>
        </div>
        <button class="tablet-back-btn" data-tablet-action="back" type="button">← Back</button>
      </div>
    </div>

    <!-- Bottom housing — slim, integrated into bezel -->
    <div class="tablet-bottom-housing" aria-hidden="true">
      <div class="tablet-speaker-grille tablet-speaker-grille--left">
        <span class="tablet-speaker-slot"></span>
        <span class="tablet-speaker-slot"></span>
      </div>
      <div class="tablet-power-btn" role="presentation"></div>
      <div class="tablet-speaker-grille tablet-speaker-grille--right">
        <span class="tablet-speaker-slot"></span>
        <span class="tablet-speaker-slot"></span>
      </div>
    </div>
  </div>
</div>

<script>
  /* eslint-disable @typescript-eslint/ban-ts-comment */
  // @ts-nocheck
  (function () {
    "use strict";
    const root = document.querySelector("[data-tablet-root]");
    if (!root) return;
    const screen = root.querySelector("[data-tablet-screen]");
    if (!screen) return;
    const states = {
      menu: screen.querySelector('[data-tablet-state="menu"]'),
      booking: screen.querySelector('[data-tablet-state="booking"]'),
      ticket: screen.querySelector('[data-tablet-state="ticket"]'),
    };
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    function trackEvent(name) {
      // TODO: Wire Clarity project ID — uncomment after setup:
      // if (typeof clarity !== "undefined") { clarity("event", name); }
      if (import.meta.env.DEV) {
        console.log("[Analytics]", name);
      }
    }
    function focusBackButton(target) {
      const stateEl = states[target];
      if (stateEl) {
        const backBtn = stateEl.querySelector(".tablet-back-btn");
        if (backBtn && !prefersReducedMotion) {
          window.setTimeout(function () {
            backBtn.focus();
          }, 50);
        }
      }
    }
    function switchState(target) {
      Object.keys(states).forEach(function (key) {
        const el = states[key];
        if (el) el.hidden = true;
      });
      const targetEl = states[target];
      if (targetEl) targetEl.hidden = false;
      if (target === "booking") {
        trackEvent("contact_tablet_interact_booking");
        focusBackButton("booking");
      } else if (target === "ticket") {
        trackEvent("contact_tablet_interact_ticket");
        focusBackButton("ticket");
      } else if (target === "menu") {
        trackEvent("contact_back_to_menu");
      }
    }
    function handleAction(action) {
      if (!action) return;
      if (action === "booking" || action === "ticket") {
        switchState(action);
        window.setTimeout(function () {
          trackEvent("contact_" + action + "_iframe_load");
        }, 500);
      } else if (action === "back") {
        switchState("menu");
      }
    }
    screen.addEventListener("click", function (e) {
      const target = e.target.closest("[data-tablet-action], [data-analytics-event]");
      if (!target) return;
      const action = target.getAttribute("data-tablet-action");
      if (action) {
        handleAction(action);
      }
      const analyticsEvent = target.getAttribute("data-analytics-event");
      if (analyticsEvent) {
        trackEvent(analyticsEvent);
      }
    });
    root.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        let currentKey = null;
        for (const key in states) {
          if (states[key] && !states[key].hidden && key !== "menu") {
            currentKey = key;
            break;
          }
        }
        if (currentKey) {
          switchState("menu");
        }
      }
    });
    switchState("menu");
    // === TODO: Add Zoho Forms postMessage listener when Zoho URLs are configured ===
  })();
</script>

<style>
  .contact-tablet {
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
  }

  /* ─── Bezel: tablet-form-factor, not monitor ─── */
  .tablet-bezel {
    position: relative;
    border-radius: 14px;
    padding: 8px;
    background: linear-gradient(180deg, #d7d0ca 0%, #c9c2bc 22%, #c3bcb6 56%, #b6b0ab 100%);
    box-shadow:
      inset 0 6px 10px rgba(255, 255, 255, 0.2),
      inset 4px 0 8px rgba(255, 255, 255, 0.08),
      inset 0 -8px 10px rgba(94, 87, 82, 0.25),
      inset -6px 0 8px rgba(118, 111, 105, 0.15),
      0 0 0 1.5px rgba(98, 90, 86, 0.7),
      0 0 0 4px rgba(47, 43, 41, 0.45),
      0 12px 36px rgba(0, 0, 0, 0.55);
  }
  .tablet-bezel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, transparent 15%, transparent 100%),
      repeating-linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.006) 0 2px,
        rgba(0, 0, 0, 0.005) 2px 4px
      ),
      repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.008) 0 1px, transparent 1px 3px);
    opacity: 0.6;
  }
  .tablet-bezel::after {
    content: "";
    position: absolute;
    inset: 4px;
    border-radius: 11px;
    pointer-events: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      inset 0 -1px 0 rgba(58, 52, 49, 0.2),
      inset 1px 0 0 rgba(255, 255, 255, 0.1),
      inset -1px 0 0 rgba(58, 52, 49, 0.1);
    opacity: 1;
  }

  /* ─── Top bar: minimal LED indicator ─── */
  .tablet-top-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3px 0 2px;
  }
  .tablet-led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00e676;
    box-shadow:
      0 0 3px rgba(0, 230, 118, 0.7),
      0 0 8px rgba(0, 230, 118, 0.3);
    flex-shrink: 0;
  }

  /* ─── Screen: uniform small radius, thin gasket ─── */
  .tablet-screen {
    position: relative;
    min-height: 310px;
    border-radius: 4px;
    background: #362866;
    overflow: hidden;
    box-shadow:
      inset 0 0 0 2px rgba(93, 72, 132, 0.4),
      inset 0 0 0 3px rgba(22, 14, 38, 0.75),
      inset 2px 3px 6px rgba(0, 0, 0, 0.55),
      inset -1px -1px 4px rgba(0, 0, 0, 0.35),
      0 0 24px rgba(180, 126, 255, 0.1);
    animation: screen-power-on 1.5s ease-out forwards;
  }
  @keyframes screen-power-on {
    0% {
      box-shadow:
        inset 0 0 0 2px rgba(93, 72, 132, 0.4),
        inset 0 0 0 3px rgba(22, 14, 38, 0.75),
        inset 2px 3px 6px rgba(0, 0, 0, 0.55),
        inset -1px -1px 4px rgba(0, 0, 0, 0.35),
        0 0 60px rgba(180, 126, 255, 0.25);
    }
    100% {
      box-shadow:
        inset 0 0 0 2px rgba(93, 72, 132, 0.4),
        inset 0 0 0 3px rgba(22, 14, 38, 0.75),
        inset 2px 3px 6px rgba(0, 0, 0, 0.55),
        inset -1px -1px 4px rgba(0, 0, 0, 0.35),
        0 0 24px rgba(180, 126, 255, 0.1);
    }
  }

  /* ─── Atmosphere layers ─── */
  .tablet-glare {
    position: absolute;
    inset: 0;
    z-index: 12;
    pointer-events: none;
    background: linear-gradient(
      162deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0.01) 30%,
      transparent 55%,
      transparent 100%
    );
    clip-path: polygon(8% 0%, 92% 0%, 88% 100%, 12% 100%);
  }
  .tablet-tint {
    position: absolute;
    inset: 0;
    z-index: 13;
    pointer-events: none;
    mix-blend-mode: soft-light;
    background: linear-gradient(
      180deg,
      rgba(60, 0, 80, 0.06) 0%,
      rgba(20, 0, 60, 0.02) 50%,
      rgba(60, 0, 80, 0.06) 100%
    );
  }
  .tablet-bands {
    position: absolute;
    inset: 0;
    z-index: 14;
    pointer-events: none;
    opacity: 0.5;
    mix-blend-mode: screen;
    background: repeating-linear-gradient(
      180deg,
      transparent 0,
      transparent 48px,
      rgba(255, 255, 255, 0.008) 48px,
      rgba(255, 255, 255, 0.008) 50px
    );
  }
  .tablet-phosphor-dots {
    position: absolute;
    inset: 0;
    z-index: 15;
    pointer-events: none;
    mix-blend-mode: screen;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 3px 3px;
  }
  .tablet-scanlines {
    position: absolute;
    inset: 0;
    z-index: 16;
    pointer-events: none;
    opacity: 0.55;
    background: repeating-linear-gradient(
      180deg,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.08) 2px,
      rgba(0, 0, 0, 0.08) 3px
    );
  }
  .tablet-vignette {
    position: absolute;
    inset: 0;
    z-index: 17;
    pointer-events: none;
    background:
      radial-gradient(ellipse at top left, rgba(0, 0, 0, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at top right, rgba(0, 0, 0, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at bottom left, rgba(0, 0, 0, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at bottom right, rgba(0, 0, 0, 0.12) 0%, transparent 50%);
  }
  .tablet-bevel-inner {
    position: absolute;
    inset: 0;
    z-index: 18;
    pointer-events: none;
    border-radius: 4px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      inset 1px 0 0 rgba(255, 255, 255, 0.03),
      inset -1px 0 0 rgba(255, 255, 255, 0.03),
      inset 0 -1px 0 rgba(0, 0, 0, 0.25);
  }

  /* ─── Bottom housing: slim, integrated ─── */
  .tablet-bottom-housing {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 6px 0 2px;
    position: relative;
  }
  .tablet-speaker-grille {
    display: flex;
    gap: 3px;
    opacity: 0.3;
  }
  .tablet-speaker-slot {
    display: block;
    width: 10px;
    height: 2px;
    border-radius: 1px;
    background: rgba(60, 54, 50, 0.45);
    box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.1);
  }
  .tablet-power-btn {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #c0b8b0 0%, #9a928c 55%, #7d7671 100%);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.35),
      inset 0 1px 2px rgba(255, 255, 255, 0.12),
      inset 0 -1px 1px rgba(0, 0, 0, 0.15);
    position: relative;
    flex-shrink: 0;
  }
  .tablet-power-btn::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    right: 2px;
    bottom: 2px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 35% 28%,
      rgba(255, 255, 255, 0.08) 0%,
      rgba(255, 255, 255, 0.01) 60%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ─── States ─── */
  .tablet-state {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    min-height: 310px;
  }
  .tablet-menu-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
    padding: 1.5rem 1.25rem 1.25rem;
  }
  .tablet-logo {
    margin: 0 0 0.25rem;
    font-family: "Monofett", "VT323", monospace;
    font-size: 1.4rem;
    color: #e89050;
    letter-spacing: 0.12em;
    text-shadow: 0 0 12px rgba(232, 144, 80, 0.5);
    line-height: 1;
  }
  .tablet-menu-label {
    margin: 0;
    color: var(--lab-heading, #e0d0ff);
    font-family: "VT323", "Courier New", monospace;
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-shadow: 0 0 10px rgba(232, 144, 80, 0.3);
    animation: welcome-glow 2s ease-out forwards;
  }
  @keyframes welcome-glow {
    0% {
      text-shadow:
        0 0 20px rgba(232, 144, 80, 0.6),
        0 0 40px rgba(232, 144, 80, 0.2);
    }
    100% {
      text-shadow: 0 0 10px rgba(232, 144, 80, 0.3);
    }
  }
  .tablet-menu-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 340px;
  }
  .tablet-btn {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    width: 100%;
    padding: 0.75rem 1rem 0.65rem;
    border: 1px solid rgba(255, 213, 164, 0.25);
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(50, 36, 70, 0.65) 0%, rgba(18, 12, 28, 0.75) 100%);
    color: var(--crt-text, #f0eaff);
    cursor: pointer;
    font-family: inherit;
    text-align: center;
    box-shadow:
      0 3px 0 rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      inset 0 -2px 0 rgba(0, 0, 0, 0.15);
    transition:
      background 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.1s ease;
    transform: translateY(0);
    -webkit-tap-highlight-color: transparent;
  }
  .tablet-btn::before {
    content: "";
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 6px;
    width: 3px;
    border-radius: 2px;
    background: rgba(232, 144, 80, 0.35);
    transition: background 0.18s ease;
  }
  .tablet-btn:hover::before {
    background: rgba(232, 144, 80, 0.7);
  }
  .tablet-btn:focus-visible {
    outline: 2px solid var(--lab-accent, #e89050);
    outline-offset: 3px;
  }
  .tablet-btn:hover {
    background: linear-gradient(180deg, rgba(232, 144, 80, 0.18) 0%, rgba(232, 144, 80, 0.08) 100%);
    border-color: rgba(255, 213, 164, 0.5);
    box-shadow:
      0 3px 0 rgba(0, 0, 0, 0.35),
      0 0 20px rgba(232, 144, 80, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -2px 0 rgba(0, 0, 0, 0.15);
    transform: translateY(-2px);
  }
  .tablet-btn:active {
    transform: translateY(2px);
    box-shadow:
      0 1px 0 rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      inset 0 -1px 0 rgba(0, 0, 0, 0.1);
  }
  .tablet-btn-icon {
    display: inline-block;
    font-family: "VT323", "Courier New", monospace;
    font-size: 0.85rem;
    color: #ffffff;
    padding: 0.15rem 0.6rem 0.1rem;
    border: 1px solid #e89050;
    border-radius: 6px;
    background: rgba(30, 26, 50, 0.95);
    text-shadow: 0 0 8px rgba(232, 144, 80, 0.4);
    letter-spacing: 0.08em;
    line-height: 1.3;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      inset 0 -1px 0 rgba(0, 0, 0, 0.2),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }
  .tablet-btn-label {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.2;
  }
  .tablet-btn-hint {
    font-size: 0.72rem;
    color: var(--crt-text-muted, #d0bcf4);
    opacity: 0.75;
    line-height: 1.25;
  }
  .tablet-iframe-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .tablet-iframe {
    width: 100%;
    flex: 1;
    border: none;
    min-height: 320px;
  }
  .tablet-placeholder {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1.25rem;
  }
  .placeholder-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    max-width: 340px;
    text-align: center;
  }
  .placeholder-icon {
    font-family: "VT323", "Courier New", monospace;
    font-size: 1.8rem;
    color: var(--lab-accent, #e89050);
    text-shadow: 0 0 12px rgba(232, 144, 80, 0.3);
  }
  .placeholder-heading {
    margin: 0;
    color: var(--lab-heading, #e0d0ff);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.06em;
  }
  .placeholder-text {
    margin: 0;
    color: var(--crt-text-muted, #d0bcf4);
    font-family: "Jersey 25", "VT323", monospace;
    font-size: 0.82rem;
    line-height: 1.5;
    opacity: 0.85;
  }
  .placeholder-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
    font-family: "VT323", "Courier New", monospace;
    font-size: 0.72rem;
    color: var(--lab-accent-dim, rgba(232, 144, 80, 0.6));
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--lab-accent, #e89050);
    box-shadow: 0 0 4px rgba(232, 144, 80, 0.5);
  }
  .placeholder-fallback {
