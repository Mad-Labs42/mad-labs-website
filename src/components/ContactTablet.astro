---
// src/components/ContactTablet.astro
// CRT-themed intake terminal with 3 states: menu, booking, ticket.
// Placeholder-safe — replace realEmbedUrl values when Zoho snippets are provided.
---

<!-- Configure these when Zoho embed URLs are available -->
<!--
  const BOOKING_EMBED_URL = "https://book.zoho.com/...";
  const TICKET_EMBED_URL = "https://forms.zoho.com/...";
-->
---

<div class="contact-tablet" data-tablet-root aria-label="MAD LABS intake terminal">
  <!-- Tablet bezel -->
  <div class="tablet-bezel">
    <!-- Status bar -->
    <div class="tablet-status-bar">
      <span class="tablet-led" aria-hidden="true"></span>
      <span class="tablet-status-text">MAD LABS — INTAKE TERMINAL v1.0</span>
    </div>

    <!-- Screen area -->
    <div class="tablet-screen" data-tablet-screen>
      <!-- Scan-line overlay (decorative) -->
      <div class="tablet-scanlines" aria-hidden="true"></div>

      <!-- ─── State: Menu ─── -->
      <div class="tablet-state" data-tablet-state="menu">
        <div class="tablet-menu-content">
          <p class="tablet-menu-label">SELECT OPERATION</p>
          <div class="tablet-menu-buttons">
            <button
              class="tablet-btn tablet-btn--primary"
              data-tablet-action="booking"
              type="button"
            >
              <span class="tablet-btn-icon" aria-hidden="true">[B]</span>
              <span class="tablet-btn-label">Book a Consultation</span>
              <span class="tablet-btn-hint">Schedule a diagnostic or service visit</span>
            </button>
            <button
              class="tablet-btn tablet-btn--secondary"
              data-tablet-action="ticket"
              type="button"
            >
              <span class="tablet-btn-icon" aria-hidden="true">[T]</span>
              <span class="tablet-btn-label">Submit a Repair Ticket</span>
              <span class="tablet-btn-hint">Describe your issue and we'll take it from there</span>
            </button>
          </div>
        </div>
      </div>

      <!-- ─── State: Booking ─── -->
      <div class="tablet-state" data-tablet-state="booking" hidden>
        <div class="tablet-iframe-wrapper">
          <!--
            When BOOKING_EMBED_URL is set, uncomment:
            <iframe
              class="tablet-iframe"
              src={BOOKING_EMBED_URL}
              title="Book a consultation with MAD LABS"
              sandbox="allow-forms allow-scripts allow-same-origin allow-popups"
              loading="lazy"
            ></iframe>
          -->
          <!-- Placeholder until Zoho Bookings embed URL is provided -->
          <div class="tablet-placeholder">
            <div class="placeholder-panel">
              <span class="placeholder-icon" aria-hidden="true">[B]</span>
              <h3 class="placeholder-heading">Booking Terminal Ready</h3>
              <p class="placeholder-text">
                The consultation booking system is configured and waiting for the
                Zoho Bookings embed URL. Once connected, this panel will display
                the live scheduling interface.
              </p>
              <div class="placeholder-status">
                <span class="status-dot"></span>
                Awaiting embed URL
              </div>
              <a
                href="mailto:customer-service@madlabs.rocks?subject=Consultation%20Request"
                class="placeholder-fallback"
                data-analytics-event="contact_fallback_booking"
                target="_blank"
                rel="noopener noreferrer"
              >
                Book by Email instead →
              </a>
            </div>
          </div>
        </div>
        <button
          class="tablet-back-btn"
          data-tablet-action="back"
          type="button"
        >
          ← Back
        </button>
      </div>

      <!-- ─── State: Ticket ─── -->
      <div class="tablet-state" data-tablet-state="ticket" hidden>
        <div class="tablet-iframe-wrapper">
          <!--
            When TICKET_EMBED_URL is set, uncomment:
            <iframe
              class="tablet-iframe"
              src={TICKET_EMBED_URL}
              title="Submit a repair ticket to MAD LABS"
              sandbox="allow-forms allow-scripts allow-same-origin allow-popups"
              loading="lazy"
            ></iframe>
          -->
          <!-- Placeholder until Zoho Forms embed URL is provided -->
          <div class="tablet-placeholder">
            <div class="placeholder-panel">
              <span class="placeholder-icon" aria-hidden="true">[T]</span>
              <h3 class="placeholder-heading">Repair Ticket Terminal Ready</h3>
              <p class="placeholder-text">
                The repair ticket system is configured and waiting for the Zoho
                Forms or Zoho Desk embed URL. Once connected, this panel will
                display the intake form.
              </p>
              <div class="placeholder-status">
                <span class="status-dot"></span>
                Awaiting embed URL
              </div>
              <a
                href="mailto:customer-service@madlabs.rocks?subject=Repair%20Ticket"
                class="placeholder-fallback"
                data-analytics-event="contact_fallback_ticket"
                target="_blank"
                rel="noopener noreferrer"
              >
                Submit by Email instead →
              </a>
            </div>
          </div>
        </div>
        <button
          class="tablet-back-btn"
          data-tablet-action="back"
          type="button"
        >
          ← Back
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  /* eslint-disable @typescript-eslint/ban-ts-comment */
  // @ts-nocheck
  (function () {
    "use strict";

    const root = document.querySelector("[data-tablet-root]");
    if (!root) return;

    const screen = root.querySelector("[data-tablet-screen]");
    if (!screen) return;

    const states = {
      menu: screen.querySelector('[data-tablet-state="menu"]'),
      booking: screen.querySelector('[data-tablet-state="booking"]'),
      ticket: screen.querySelector('[data-tablet-state="ticket"]'),
    };

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    // Analytics wrapper (no-op until Clarity ID is provided)
    function trackEvent(name) {
      // TODO: Wire Clarity project ID — uncomment after setup:
      // if (typeof clarity !== "undefined") { clarity("event", name); }
      if (import.meta.env.DEV) {
        console.log("[Analytics]", name);
      }
    }

    // Focus back button helper
    function focusBackButton(target) {
      const stateEl = states[target];
      if (stateEl) {
        const backBtn = stateEl.querySelector(".tablet-back-btn");
        if (backBtn && !prefersReducedMotion) {
          window.setTimeout(function () {
            backBtn.focus();
          }, 50);
        }
      }
    }

    // State switching
    function switchState(target) {
      Object.keys(states).forEach(function (key) {
        const el = states[key];
        if (el) el.hidden = true;
      });

      const targetEl = states[target];
      if (targetEl) targetEl.hidden = false;

      if (target === "booking") {
        trackEvent("contact_tablet_interact_booking");
        focusBackButton("booking");
      } else if (target === "ticket") {
        trackEvent("contact_tablet_interact_ticket");
        focusBackButton("ticket");
      } else if (target === "menu") {
        trackEvent("contact_back_to_menu");
      }
    }

    function handleAction(action) {
      if (!action) return;

      if (action === "booking" || action === "ticket") {
        switchState(action);
        window.setTimeout(function () {
          trackEvent("contact_" + action + "_iframe_load");
        }, 500);
      } else if (action === "back") {
        switchState("menu");
      }
    }

    screen.addEventListener("click", function (e) {
      const target = e.target.closest("[data-tablet-action], [data-analytics-event]");
      if (!target) return;

      const action = target.getAttribute("data-tablet-action");
      if (action) {
        handleAction(action);
      }

      const analyticsEvent = target.getAttribute("data-analytics-event");
      if (analyticsEvent) {
        trackEvent(analyticsEvent);
      }
    });

    root.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        let currentKey = null;
        for (const key in states) {
          if (states[key] && !states[key].hidden && key !== "menu") {
            currentKey = key;
            break;
          }
        }
        if (currentKey) {
          switchState("menu");
        }
      }
    });

    // Initialize
    switchState("menu");

    // === TODO: Add Zoho Forms postMessage listener when Zoho URLs are configured ===
    // window.addEventListener("message", function (event) {
    //   if (event.origin !== "https://forms.zoho.com") return;
    //   try {
    //     var payload = typeof event.data === "string"
    //       ? JSON.parse(event.data)
    //       : event.data;
    //     if (payload.type === "FORM_SUBMITTED") {
    //       trackEvent("contact_zoho_form_submitted");
    //     }
    //     if (payload.type === "FORM_COMPLETED") {
    //       trackEvent("contact_zoho_form_completed");
    //     }
    //   } catch (e) { /* ignore */ }
    // });
  })();
</script>

<style>
  /* ═══════════════════════════════════════════════
     Contact Tablet — CRT hardware terminal
     ═══════════════════════════════════════════════ */

  /* ─── Outer container ─── */
  .contact-tablet {
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
    font-family: "Jersey 25", "VT323", "Courier New", monospace;
  }

  /* ─── Bezel (beige/cream = CRT sibling) ─── */
  .tablet-bezel {
    border-radius: 16px;
    padding: 10px;
    background:
      linear-gradient(
        160deg,
        #e8e4e2 0%,
        #d0ccc9 35%,
        #c8c2c0 65%,
        #b8b0ab 100%
      );
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      inset 0 -1px 0 rgba(0, 0, 0, 0.08);
  }

  /* ─── Status bar ─── */
  .tablet-status-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.6rem 0.4rem;
    background: rgba(98, 88, 94, 0.35);
    border-radius: 8px 8px 0 0;
    border-bottom: 1px solid rgba(98, 88, 94, 0.2);
  }

  .tablet-led {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #00e676;
    box-shadow:
      0 0 4px rgba(0, 230, 118, 0.8),
      0 0 10px rgba(0, 230, 118, 0.4);
    flex-shrink: 0;
  }

  .tablet-status-text {
    font-family: "VT323", "Courier New", monospace;
    font-size: 0.65rem;
    color: rgba(246, 239, 255, 0.7);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ─── Screen (purple CRT) ─── */
  .tablet-screen {
    position: relative;
    min-height: 460px;
    border-radius: 0 0 8px 8px;
    background: var(--crt-screen-bg, #362866);
    overflow: hidden;
    box-shadow:
      inset 0 0 60px rgba(0, 0, 0, 0.35),
      inset 0 0 20px rgba(140, 80, 240, 0.12);
  }

  /* ─── Scan-line overlay ─── */
  .tablet-scanlines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.08) 2px,
      rgba(0, 0, 0, 0.08) 4px
    );
  }

  /* ─── State containers ─── */
  .tablet-state {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    min-height: 460px;
  }

  /* ─── Menu state ─── */
  .tablet-menu-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 2rem 1.25rem;
  }

  .tablet-menu-label {
    margin: 0;
    color: var(--lab-accent, #e89050);
    font-family: "VT323", "Courier New", monospace;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-shadow: 0 0 8px rgba(232, 144, 80, 0.3);
  }

  .tablet-menu-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 380px;
  }

  /* ─── Terminal-style buttons ─── */
  .tablet-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    width: 100%;
    padding: 1rem 1.25rem;
    border: 1px solid rgba(255, 213, 164, 0.35);
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.3);
    color: var(--crt-text, #f0eaff);
    cursor: pointer;
    font-family: inherit;
    text-align: center;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.15s ease;
    transform: translateY(0);
    -webkit-tap-highlight-color: transparent;
  }

  .tablet-btn:focus-visible {
    outline: 2px solid var(--lab-accent, #e89050);
    outline-offset: 3px;
  }

  .tablet-btn:hover {
    background: rgba(232, 144, 80, 0.12);
    border-color: rgba(255, 213, 164, 0.55);
    transform: translateY(-2px);
  }

  .tablet-btn:active {
    transform: translateY(0);
  }

  .tablet-btn-icon {
    font-family: "VT323", "Courier New", monospace;
    font-size: 1.4rem;
    color: var(--lab-accent, #e89050);
    text-shadow: 0 0 8px rgba(232, 144, 80, 0.25);
  }

  .tablet-btn-label {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.2;
  }

  .tablet-btn-hint {
    font-size: 0.75rem;
    color: var(--crt-text-muted, #d0bcf4);
    opacity: 0.8;
    line-height: 1.3;
  }

  /* ─── Iframe wrapper ─── */
  .tablet-iframe-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .tablet-iframe {
    width: 100%;
    flex: 1;
    border: none;
    min-height: 400px;
  }

  /* ─── Placeholder panel ─── */
  .tablet-placeholder {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.25rem;
  }

  .placeholder-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    max-width: 340px;
    text-align: center;
  }

  .placeholder-icon {
    font-family: "VT323", "Courier New", monospace;
    font-size: 1.8rem;
    color: var(--lab-accent, #e89050);
    text-shadow: 0 0 12px rgba(232, 144, 80, 0.3);
  }

  .placeholder-heading {
    margin: 0;
    color: var(--lab-heading, #e0d0ff);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.06em;
  }

  .placeholder-text {
    margin: 0;
    color: var(--crt-text-muted, #d0bcf4);
    font-family: "Jersey 25", "VT323", monospace;
    font-size: 0.82rem;
    line-height: 1.5;
    opacity: 0.85;
  }

  .placeholder-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
    font-family: "VT323", "Courier New", monospace;
    font-size: 0.72rem;
    color: var(--lab-accent-dim, rgba(232, 144, 80, 0.6));
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--lab-accent, #e89050);
    box-shadow: 0 0 4px rgba(232, 144, 80, 0.5);
  }

  .placeholder-fallback {
    margin-top: 0.5rem;
    color: var(--lab-accent, #e89050);
    font-family: "Jersey 25", "VT323", monospace;
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .placeholder-fallback:hover {
    color: #fff;
    text-decoration: underline;
  }

  .placeholder-fallback:focus-visible {
    outline: 2px solid var(--lab-accent, #e89050);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ─── Back button ─── */
  .tablet-back-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    margin: 0.75rem;
    padding: 0.45rem 1rem;
    border: 1px solid rgba(255, 213, 164, 0.3);
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.25);
    color: var(--crt-text, #f0eaff);
    cursor: pointer;
    font-family: "VT323", "Courier New", monospace;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
    align-self: flex-start;
    -webkit-tap-highlight-color: transparent;
  }

  .tablet-back-btn:hover {
    background: rgba(232, 144, 80, 0.12);
    border-color: rgba(255, 213, 164, 0.5);
  }

  .tablet-back-btn:focus-visible {
    outline: 2px solid var(--lab-accent, #e89050);
    outline-offset: 3px;
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .tablet-btn,
    .tablet-back-btn {
      transition: none;
      transform: none;
    }

    .tablet-btn:hover {
      transform: none;
    }

    .tablet-btn:active {
      transform: none;
    }
  }

  /* ─── Mobile adjustments ─── */
  @media (max-width: 480px) {
    .contact-tablet {
      max-width: 100%;
    }

    .tablet-screen {
      min-height: 380px;
    }

    .tablet-state {
      min-height: 380px;
    }

    .tablet-menu-content {
      padding: 1.5rem 1rem;
    }

    .tablet-btn {
      padding: 0.85rem 1rem;
    }

    .tablet-btn-label {
      font-size: 0.95rem;
    }

    .tablet-placeholder {
      padding: 1.5rem 1rem;
    }
  }
</style>
