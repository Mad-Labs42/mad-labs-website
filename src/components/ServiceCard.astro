---
export interface Props {
  name: string;
  shortDescription: string;
  bullets: string[];
  icon: string;
  pricing: string;
  category: string;
}

const { name, shortDescription, bullets, icon, pricing, category } = Astro.props;

const icons: Record<string, string> = {
  monitor:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="24" height="16" rx="1.5"/><line x1="6" y1="24" x2="22" y2="24"/><line x1="14" y1="19" x2="14" y2="24"/></svg>',
  globe:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="14" cy="14" r="11"/><ellipse cx="14" cy="14" rx="5" ry="11"/><line x1="3" y1="10" x2="25" y2="10"/><line x1="3" y1="18" x2="25" y2="18"/></svg>',
  signal:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 18.5a7 7 0 0 1 14 0"/><path d="M4 15a10 10 0 0 1 20 0"/><path d="M10 22a4 4 0 0 1 8 0"/><circle cx="14" cy="24" r="1"/></svg>',
  chip: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="6" width="16" height="16" rx="1.5"/><line x1="11" y1="2" x2="11" y2="6"/><line x1="17" y1="2" x2="17" y2="6"/><line x1="11" y1="22" x2="11" y2="26"/><line x1="17" y1="22" x2="17" y2="26"/><line x1="2" y1="11" x2="6" y2="11"/><line x1="2" y1="17" x2="6" y2="17"/><line x1="22" y1="11" x2="26" y2="11"/><line x1="22" y1="17" x2="26" y2="17"/></svg>',
  shield:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2.5 4 6v6c0 6.5 4 11.5 10 13.5 6-2 10-7 10-13.5V6l-10-3.5Z"/><path d="m9.5 13.5 3 3 6-6"/></svg>',
  brain:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5 A9 11 0 0 0 14 23"/><path d="M14 5 A9 11 0 0 1 14 23"/><path d="M7 9 A4 3 0 0 1 11 11"/><path d="M17 9 A4 3 0 0 0 21 11"/><path d="M7 17 A4 3 0 0 1 11 15"/><path d="M17 17 A4 3 0 0 0 21 15"/></svg>',
  bot: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="9" width="18" height="13" rx="2"/><rect x="10" y="12" width="3" height="2" rx="0.5"/><rect x="15" y="12" width="3" height="2" rx="0.5"/><line x1="12" y1="17" x2="16" y2="17"/><path d="M11 9V6a3 3 0 0 1 6 0v3"/><line x1="9" y1="22" x2="6" y2="25"/><line x1="19" y1="22" x2="22" y2="25"/></svg>',
};
---

<article class="service-card">
  <div class="icon-wrap" aria-hidden="true">
    <span class="icon-svg" set:html={icons[icon] || ""} />
  </div>
  <span class="card-category">{category}</span>
  <h2 class="card-title">{name}</h2>

  <hr class="summary-divider">

  <p class="card-summary">{shortDescription}</p>

  <hr class="bullets-divider">

  <ul class="card-bullets">
    {bullets.map((b) => <li>{b}</li>)}
  </ul>

  <hr class="pricing-divider">

  <div class="card-pricing">
    {pricing.includes("$") ? (
      <>
        <span class="pricing-label">{pricing.replace(/\s*\$.*$/, "").trim()}</span>
        <span class="pricing-value">
          <span class="prompt">$</span>
          <span class="price-number">{pricing.replace(/^.*\$/, "")}</span>
          <span class="cursor"></span>
        </span>
      </>
    ) : (
      <span class="pricing-label pricing-label--full">{pricing}</span>
    )}
  </div>
</article>

<style>
  .service-card {
    position: relative;
    background: var(--lab-card, #131325);
    border: 1px solid rgba(232, 144, 80, 0.18);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    isolation: isolate;
    overflow: visible;
    box-shadow:
      0 0 0 1px rgba(240, 234, 255, 0.05),
      0 4px 20px rgba(0, 0, 0, 0.35),
      0 0 60px rgba(232, 144, 80, 0.025),
      inset 0 1px 0 rgba(240, 234, 255, 0.03);
    transition: border-color 0.35s ease, box-shadow 0.35s ease;
  }

  .service-card:hover {
    border-color: rgba(232, 144, 80, 0.32);
    box-shadow:
      0 0 0 1px rgba(240, 234, 255, 0.08),
      0 4px 20px rgba(0, 0, 0, 0.35),
      0 0 60px rgba(232, 144, 80, 0.04),
      inset 0 1px 0 rgba(240, 234, 255, 0.05);
  }

  /* Keyboard focus parity — matches hover visual feedback */
  .service-card:focus-visible {
    border-color: rgba(232, 144, 80, 0.32);
    box-shadow:
      0 0 0 1px rgba(240, 234, 255, 0.08),
      0 4px 20px rgba(0, 0, 0, 0.35),
      0 0 60px rgba(232, 144, 80, 0.04),
      inset 0 1px 0 rgba(240, 234, 255, 0.05);
    outline: 2px solid rgba(232, 144, 80, 0.5);
    outline-offset: 2px;
  }

  .service-card:focus-visible::before {
    background: linear-gradient(90deg,
      rgba(232, 144, 80, 0.15) 0%,
      rgba(232, 144, 80, 0.65) 30%,
      rgba(232, 144, 80, 0.65) 70%,
      rgba(232, 144, 80, 0.15) 100%);
  }

  .service-card:focus-visible::after {
    background: radial-gradient(ellipse at 50% 25%, rgba(232,144,80,0.05) 0%, transparent 65%);
  }

  .service-card:focus-visible .icon-wrap {
    background: rgba(232,144,80,0.1);
    border-color: rgba(232,144,80,0.2);
  }

  .service-card:focus-visible .bullets-divider,
  .service-card:focus-visible .summary-divider,
  .service-card:focus-visible .pricing-divider {
    box-shadow: 0 0 8px rgba(232, 144, 80, 0.25);
    opacity: 0.9;
  }

  .service-card:focus-visible .card-bullets li::before {
    border-color: rgba(232, 144, 80, 0.8);
    box-shadow: 0 0 6px rgba(232, 144, 80, 0.3);
  }

  /* Top accent bar */
  .service-card::before {
    content: "";
    position: absolute;
    top: -1px; left: -1px; right: -1px;
    height: 2.5px;
    background: linear-gradient(90deg,
      rgba(232, 144, 80, 0.1) 0%,
      rgba(232, 144, 80, 0.5) 30%,
      rgba(232, 144, 80, 0.5) 70%,
      rgba(232, 144, 80, 0.1) 100%);
    border-radius: 8px 8px 0 0;
    pointer-events: none;
    z-index: 1;
  }
  .service-card:hover::before {
    background: linear-gradient(90deg,
      rgba(232, 144, 80, 0.15) 0%,
      rgba(232, 144, 80, 0.65) 30%,
      rgba(232, 144, 80, 0.65) 70%,
      rgba(232, 144, 80, 0.15) 100%);
  }

  /* Inner radial warmth */
  .service-card::after {
    content: "";
    position: absolute;
    inset: 0; border-radius: 8px;
    background: radial-gradient(ellipse at 50% 25%, rgba(232,144,80,0.025) 0%, transparent 65%);
    pointer-events: none; z-index: -1;
    transition: opacity 0.35s ease;
  }
  .service-card:hover::after {
    background: radial-gradient(ellipse at 50% 25%, rgba(232,144,80,0.05) 0%, transparent 65%);
  }

  /* Icon circle */
  .icon-wrap {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2.5rem; height: 2.5rem; border-radius: 50%;
    background: rgba(232,144,80,0.06);
    border: 1px solid rgba(232,144,80,0.08);
    margin-bottom: 0.75rem;
    transition: background 0.3s ease, border-color 0.3s ease;
    flex-shrink: 0;
  }
  .service-card:hover .icon-wrap { background: rgba(232,144,80,0.1); border-color: rgba(232,144,80,0.2); }
  .icon-svg { color: var(--lab-accent, #e89050); width: 1.25rem; height: 1.25rem; display: block; }
  .icon-svg :global(svg) { width: 100%; height: 100%; display: block; }

  /* Category label */
  .card-category {
    display: inline-block;
    font-family: "Jersey 25", monospace;
    font-size: clamp(0.5rem, 0.7vw, 0.6rem);
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(232, 144, 80, 0.55);
    margin-bottom: 0.1rem;
  }

  /* Title */
  .card-title {
    font-family: "Early GameBoy", "Jersey 25", "VT323", monospace;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    color: var(--lab-heading, #e0d0ff); font-weight: 400;
    letter-spacing: 0.04em; line-height: 1.2;
    margin-bottom: 0.25rem;
  }

  /* Divider before summary */
  .summary-divider {
    margin: 0.25rem 0 0.6rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(232,144,80,0.12) 0%, rgba(232,144,80,0.03) 100%);
    border: none;
    flex-shrink: 0;
    transition: opacity 0.35s ease, box-shadow 0.35s ease;
  }

  /* Summary — indented, with left bar */
  .card-summary {
    font-family: "Jersey 25", "VT323", monospace;
    font-size: clamp(0.68rem, 0.9vw, 0.78rem);
    color: var(--lab-text-muted, #a8a0c8); line-height: 1.45;
    margin-bottom: 0.75rem;
    padding-left: 0.6rem;
    border-left: 1px solid rgba(232, 144, 80, 0.1);
    letter-spacing: 0.03em;
  }

  /* Divider before bullets */
  .bullets-divider {
    margin: 0 0 0.6rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(232,144,80,0.2) 0%, rgba(232,144,80,0.06) 100%);
    border: none;
    flex-shrink: 0;
    transition: opacity 0.35s ease, box-shadow 0.35s ease;
  }

  /* Divider before pricing */
  .pricing-divider {
    margin: 0.5rem 0 0.6rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(232,144,80,0.2) 0%, rgba(232,144,80,0.06) 100%);
    border: none;
    flex-shrink: 0;
    transition: opacity 0.35s ease, box-shadow 0.35s ease;
  }

  /* All dividers glow on card hover */
  .service-card:hover .bullets-divider,
  .service-card:hover .summary-divider,
  .service-card:hover .pricing-divider {
    box-shadow: 0 0 8px rgba(232, 144, 80, 0.25);
    opacity: 0.9;
  }

  /* Bullets — Jersey 25 with orange pulse rings */
  .card-bullets {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.35rem;
    flex: 1;
  }
  .card-bullets li {
    font-family: "VT323", "Courier New", monospace;
    font-size: clamp(0.7rem, 0.9vw, 0.78rem);
    color: var(--lab-text, #b0a8c8); line-height: 1.35;
    padding-left: 0.9rem;
    position: relative;
    letter-spacing: 0.02em;
  }
  .card-bullets li::before {
    content: "";
    position: absolute;
    left: 0; top: 0.2em;
    width: 7px; height: 7px;
    border: 1.5px solid rgba(232, 144, 80, 0.5);
    border-radius: 50%;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .service-card:hover .card-bullets li::before {
    border-color: rgba(232, 144, 80, 0.8);
    box-shadow: 0 0 6px rgba(232, 144, 80, 0.3);
  }

  /* Pricing — orange label left, green price right */
  .card-pricing {
    font-family: "VT323", "Courier New", monospace;
    font-size: clamp(0.8rem, 1.1vw, 0.95rem);
    color: var(--crt-led-on, #00e676);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0;
  }
  .pricing-label {
    font-family: "Jersey 25", monospace;
    font-size: clamp(0.5rem, 0.7vw, 0.6rem);
    letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(232, 144, 80, 0.55);
  }
  .pricing-value { display: flex; align-items: center; gap: 0.15rem; }
  .prompt { color: var(--crt-led-on, #00e676); opacity: 0.75; font-size: 0.85em; }
  .price-number { color: var(--crt-led-on, #00e676); }
  .cursor {
    display: inline-block; width: 5px; height: 0.8em;
    background: var(--crt-led-on, #00e676);
    margin-left: 1px; vertical-align: text-bottom;
    animation: cursor-blink 1s step-end infinite;
  }

  @keyframes cursor-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .service-card, .service-card::before, .service-card::after,
    .summary-divider, .bullets-divider, .pricing-divider,
    .icon-wrap, .card-summary, .card-bullets li::before { transition: none; }
    .service-card:hover {
      box-shadow: 0 0 0 1px rgba(240, 234, 255, 0.08), 0 4px 20px rgba(0, 0, 0, 0.35);
    }
    .cursor { display: none; }
  }
</style>