---
// src/layouts/BaseLayout.astro

import "../styles/global.css";
import { CONTACT_EMAIL, CONTACT_PHONE } from "../data/contact";
import SiteNav from "../components/SiteNav.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  jsonLdType?: "home" | "about" | "services" | "contact" | "none";
  homeHeroClassifier?: boolean;
}

const {
  title,
  description = "MAD LABS computer repair and mobile IT solutions.",
  image = "/favicon.svg",
  noindex = false,
  jsonLdType = "none",
  homeHeroClassifier = false,
} = Astro.props;
const pageTitle = title === "MAD LABS" ? "MAD LABS" : `${title} — MAD LABS`;
const clarityId = import.meta.env.PUBLIC_CLARITY_ID || "";
const enableClarity = import.meta.env.PUBLIC_ENABLE_CLARITY === "true" && clarityId.length > 0;
const ga4MeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID || "";

const SITE_URL = Astro.site?.origin || "https://madlabs.rocks";
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL);
const socialImageUrl = new URL(image, SITE_URL);

const homeHeroClassifierScript = String.raw`
(() => {
  const STORAGE_KEY = "madlabs-home-hero";
  const applyHero = (hero) => {
    document.documentElement.dataset.homeHero = hero;
  };

  try {
    const saved = window.sessionStorage.getItem(STORAGE_KEY);
    if (saved === "mobile" || saved === "crt") {
      applyHero(saved);
      return;
    }

    const width = window.innerWidth;
    const height = window.innerHeight;
    const dimensionsKnown =
      Number.isFinite(width) && Number.isFinite(height) && width > 0 && height > 0;
    const shortSide = Math.min(window.innerWidth, window.innerHeight);
    const reducedMotion =
      typeof window.matchMedia === "function"
        ? window.matchMedia("(prefers-reduced-motion: reduce)").matches
        : true;
    const enoughSpaceForCrt = dimensionsKnown && shortSide >= 768;
    const hero = enoughSpaceForCrt && !reducedMotion ? "crt" : "mobile";

    window.sessionStorage.setItem(STORAGE_KEY, hero);
    applyHero(hero);
  } catch {
    applyHero("mobile");
  }
})();
`;

const ga4InlineScript = String.raw`
window.dataLayer = window.dataLayer || [];
function gtag() {
  window.dataLayer.push(arguments);
}
gtag("js", new Date());
gtag("config", ${JSON.stringify(ga4MeasurementId)});
`;

const clarityScript = String.raw`
(() => {
  const loadClarity = () => {
    (function (c, l, a, r, i, t, y) {
      c[a] =
        c[a] ||
        function () {
          (c[a].q = c[a].q || []).push(arguments);
        };
      t = l.createElement(r);
      t.async = 1;
      t.src = "https://www.clarity.ms/tag/" + i;
      y = l.getElementsByTagName(r)[0];
      y.parentNode.insertBefore(t, y);
    })(window, document, "clarity", "script", ${JSON.stringify(clarityId)});
  };

  if ("requestIdleCallback" in window) {
    window.requestIdleCallback(loadClarity, { timeout: 2500 });
  } else {
    window.setTimeout(loadClarity, 1500);
  }
})();
`;

const serviceGraph = [
  {
    "@type": "Service",
    name: "Computer repair and tune-ups",
    serviceType:
      "Computer repair, diagnostics, malware removal, tune-ups, and performance optimization",
    areaServed: "Greater Cincinnati Area",
  },
  {
    "@type": "Service",
    name: "Small business websites",
    serviceType:
      "Website design, local business pages, contact forms, launch support, and website care",
    areaServed: "Greater Cincinnati Area",
  },
  {
    "@type": "Service",
    name: "Wi-Fi, network and device setup",
    serviceType:
      "Wi-Fi troubleshooting, mesh networks, router setup, printers, peripherals, and smart-home setup",
    areaServed: "Greater Cincinnati Area",
  },
  {
    "@type": "Service",
    name: "Hardware upgrades and custom PCs",
    serviceType:
      "Hardware upgrades, custom PC builds, home servers, NAS setup, and thermal maintenance",
    areaServed: "Greater Cincinnati Area",
  },
  {
    "@type": "Service",
    name: "Security and backup",
    serviceType:
      "Security checkups, backup setup, cybersecurity hardening, parental controls, and safe browsing setup",
    areaServed: "Greater Cincinnati Area",
  },
  {
    "@type": "Service",
    name: "Custom agents and local AI setup",
    serviceType:
      "Local AI setup, AI agents, model tooling, workflow automation, and practical AI consulting",
    areaServed: "Greater Cincinnati Area",
  },
];

// JSON-LD builders per page type. Uses @graph pattern for multi-type pages.
function buildJsonLd(type: string): Record<string, unknown> {
  const localBusiness = {
    "@id": `${SITE_URL}/#local-business`,
    "@type": ["LocalBusiness", "ProfessionalService"],
    name: "MAD LABS",
    description:
      "Mobile computer repair, tech support, diagnostics, and practical AI solutions for Cincinnati homes and small businesses.",
    url: SITE_URL,
    telephone: CONTACT_PHONE,
    email: CONTACT_EMAIL,
    areaServed: {
      "@type": "AdministrativeArea",
      name: "Greater Cincinnati Area",
    },
    contactPoint: [
      {
        "@type": "ContactPoint",
        telephone: CONTACT_PHONE,
        email: CONTACT_EMAIL,
        contactType: "customer support",
        areaServed: "Greater Cincinnati Area",
      },
    ],
  };

  const website = {
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    name: "MAD LABS",
    url: SITE_URL,
    publisher: { "@id": `${SITE_URL}/#local-business` },
  };

  const webPage = {
    "@type": "WebPage",
    "@id": `${canonicalUrl.href}#webpage`,
    url: canonicalUrl.href,
    name: pageTitle,
    description,
    isPartOf: { "@id": `${SITE_URL}/#website` },
    about: { "@id": `${SITE_URL}/#local-business` },
  };

  const serviceNodes = serviceGraph.map((service, index) => ({
    "@id": `${SITE_URL}/#service-${index + 1}`,
    provider: { "@id": `${SITE_URL}/#local-business` },
    ...service,
  }));

  switch (type) {
    case "home":
      return {
        "@context": "https://schema.org",
        "@graph": [website, webPage, localBusiness, ...serviceNodes],
      };
    case "about":
      return {
        "@context": "https://schema.org",
        "@graph": [
          website,
          {
            ...webPage,
            "@type": "AboutPage",
            name: "About MAD LABS",
            url: `${SITE_URL}/about/`,
          },
          localBusiness,
        ],
      };
    case "services":
      return {
        "@context": "https://schema.org",
        "@graph": [
          website,
          {
            ...webPage,
            name: "Computer Repair & IT Support Services",
            url: `${SITE_URL}/services/`,
          },
          localBusiness,
          ...serviceNodes,
        ],
      };
    case "contact":
      return {
        "@context": "https://schema.org",
        "@graph": [
          website,
          {
            ...webPage,
            "@type": "ContactPage",
            name: "Contact MAD LABS",
            url: `${SITE_URL}/contact/`,
          },
          localBusiness,
        ],
      };
    default:
      return {};
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="192x192" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0a0618" />
    <title>{pageTitle}</title>

    {homeHeroClassifier && <script is:inline set:html={homeHeroClassifierScript} />}

    <!-- Canonical: absolute URL, strip query params -->
    <link rel="canonical" href={canonicalUrl.href} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Preload critical above-fold fonts -->
    <link
      rel="preload"
      href="/fonts/monofett-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/jersey-25-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preload" href="/fonts/early-gameboy.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/vt323-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph / Social -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={socialImageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="MAD LABS — Computer Repair and IT Support in Cincinnati"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl.href} />

    {
      jsonLdType !== "none" && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(buildJsonLd(jsonLdType))}
        />
      )
    }

    <!-- Google Analytics 4 -->
    {
      ga4MeasurementId ? (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}
          />
          <script is:inline set:html={ga4InlineScript} />
        </>
      ) : null
    }

    <!-- Microsoft Clarity - temporary UX-debugging instrumentation.
         Remove after the short debugging window. Disclosed on /privacy/. -->
    {enableClarity ? <script is:inline set:html={clarityScript} /> : null}
  </head>

  <body>
    <a class="skip-link" href="#main-content" data-skip-link> Skip to main content </a>

    {Astro.url.pathname !== "/" && <SiteNav />}

    <main id="main-content" aria-label="Main content">
      <slot />
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="footer-inner">
        <p class="footer-copyright">
          &copy; {new Date().getFullYear()} MAD LABS. All rights reserved.
        </p>
        <nav class="footer-links" aria-label="Footer">
          <a href="mailto:customer-service@madlabs.rocks" class="footer-email"
            >customer-service@madlabs.rocks</a
          >
          <a href="/privacy/" class="footer-privacy-link">Privacy</a>
          <a href="/sitemap-index.xml" class="footer-sitemap-link">Sitemap</a>
        </nav>
      </div>
    </footer>

    <button class="back-to-top" type="button" aria-label="Back to top" data-back-to-top>
      <span class="back-to-top-chevron" aria-hidden="true"></span>
    </button>

    <style>
      .skip-link {
        position: fixed;
        top: 0;
        left: 50%;
        z-index: 100;
        transform: translate(-50%, -100%);
        padding: 0.6rem 1.2rem;
        border-radius: 0 0 6px 6px;
        background: rgba(20, 10, 32, 0.96);
        color: rgba(246, 239, 255, 0.94);
        font-family: "Jersey 25", "VT323", "Courier New", monospace;
        font-size: 0.95rem;
        letter-spacing: 0.06em;
        text-decoration: none;
        text-transform: uppercase;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
        transition: transform 0.2s ease;
      }

      .skip-link:focus {
        transform: translate(-50%, 0);
      }

      .back-to-top {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border: 1px solid rgba(247, 158, 85, 0.5);
        border-radius: 50%;
        background: rgba(20, 10, 32, 0.88);
        cursor: pointer;
        opacity: 0;
        visibility: hidden;
        transform: translateY(12px);
        transition:
          opacity 0.3s ease,
          visibility 0.3s ease,
          transform 0.3s ease,
          box-shadow 0.2s ease;
      }

      .back-to-top.is-visible {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }

      .back-to-top:hover {
        box-shadow:
          0 0 16px rgba(247, 158, 85, 0.45),
          0 0 32px rgba(247, 158, 85, 0.18);
      }

      .back-to-top:focus-visible {
        outline: 2px solid rgba(247, 158, 85, 0.86);
        outline-offset: 4px;
      }

      .back-to-top-chevron {
        display: block;
        width: 10px;
        height: 10px;
        border-right: 2px solid rgba(247, 158, 85, 0.85);
        border-top: 2px solid rgba(247, 158, 85, 0.85);
        transform: rotate(-45deg) translate(1px, 2px);
      }
    </style>

    <script>
      const skipLink = document.querySelector<HTMLAnchorElement>("[data-skip-link]");
      const backToTop = document.querySelector<HTMLButtonElement>("[data-back-to-top]");
      const mainContent = document.getElementById("main-content");

      if (skipLink) {
        skipLink.addEventListener("click", (e: Event) => {
          e.preventDefault();
          // Make main content focusable (tabindex is set dynamically
          // to avoid lint warnings on non-interactive <main> in markup).
          if (mainContent) {
            if (mainContent.getAttribute("tabindex") === null) {
              mainContent.setAttribute("tabindex", "-1");
            }
            // Focus main content immediately. The CRT blur transition
            // runs async — it does NOT block focus.
            mainContent.focus();
          }
          // Dispatch to CrtHero to trigger accelerated transition.
          window.dispatchEvent(new CustomEvent("madlabs:skip-intro"));
        });
      }

      if (backToTop) {
        let visible = false;
        let ticking = false;

        const updateBackToTop = (): void => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const shouldShow = window.scrollY > window.innerHeight;
            if (shouldShow !== visible) {
              visible = shouldShow;
              backToTop.classList.toggle("is-visible", visible);
            }
            ticking = false;
          });
        };

        window.addEventListener("scroll", updateBackToTop, { passive: true });

        backToTop.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
  </body>
</html>
