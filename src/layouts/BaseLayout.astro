---
// src/layouts/BaseLayout.astro

import "../styles/global.css";
import { CONTACT_EMAIL, CONTACT_PHONE } from "../data/contact";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  jsonLdType?: "home" | "about" | "services" | "contact" | "none";
}

const {
  title,
  description = "MAD LABS computer repair and mobile IT solutions.",
  image = "/favicon.svg",
  noindex = false,
  jsonLdType = "none",
} = Astro.props;
const pageTitle = title === "MAD LABS" ? "MAD LABS" : `${title} — MAD LABS`;
const clarityId = import.meta.env.PUBLIC_CLARITY_ID || "x4385g64yq";
const ga4MeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID || "";

const SITE_URL = Astro.site?.origin || "https://madlabs.rocks";

// JSON-LD builders per page type. Uses @graph pattern for multi-type pages.
function buildJsonLd(type: string): Record<string, unknown> {
  const localBusiness = {
    "@type": "LocalBusiness",
    name: "MAD LABS",
    description:
      "Computer repair, diagnostics, IT support, and AI automation in the Greater Cincinnati area.",
    url: SITE_URL,
    telephone: CONTACT_PHONE,
    email: CONTACT_EMAIL,
    areaServed: "Greater Cincinnati Area",
    openingHoursSpecification: [
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "09:00",
        closes: "18:00",
      },
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: "Saturday",
        opens: "10:00",
        closes: "16:00",
      },
    ],
  };

  switch (type) {
    case "home":
      return {
        "@context": "https://schema.org",
        "@graph": [{ "@type": "WebSite", name: "MAD LABS", url: SITE_URL }, localBusiness],
      };
    case "about":
      return {
        "@context": "https://schema.org",
        "@graph": [
          { "@type": "AboutPage", name: "About MAD LABS", url: `${SITE_URL}/about/` },
          localBusiness,
        ],
      };
    case "services":
      return {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Service",
            name: "Computer Repair & IT Support",
            provider: localBusiness,
            areaServed: "Greater Cincinnati Area",
            description:
              "Computer repair, tuneups, malware removal, network setup, and AI automation services.",
          },
          localBusiness,
        ],
      };
    case "contact":
      return {
        "@context": "https://schema.org",
        "@graph": [
          { "@type": "ContactPage", name: "Contact MAD LABS", url: `${SITE_URL}/contact/` },
          localBusiness,
        ],
      };
    default:
      return {};
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0a0618" />
    <title>{pageTitle}</title>

    <!-- Canonical: absolute URL, strip query params -->
    <link rel="canonical" href={`${Astro.site?.origin || "https://madlabs.rocks"}${Astro.url.pathname}`} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Preload critical above-fold fonts -->
    <link rel="preload" href="/fonts/monofett-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jersey-25-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph / Social -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://madlabs.rocks${Astro.url.pathname}`} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`https://madlabs.rocks${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="MAD LABS — Computer Repair and IT Support in Cincinnati" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://madlabs.rocks${image}`} />

    {jsonLdType !== "none" && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(buildJsonLd(jsonLdType))}
      />
    )}

    <!-- Google Analytics 4 -->
    {
      ga4MeasurementId ? (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`} />
          <script is:inline define:vars={{ ga4MeasurementId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", ga4MeasurementId);
          </script>
        </>
      ) : null
    }

    <!-- Microsoft Clarity — analytics -->
    <script is:inline define:vars={{ clarityId }}>
      /* eslint-disable prefer-rest-params */
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", clarityId);
      /* eslint-enable prefer-rest-params */
    </script>
  </head>

  <body>
    
    <a class="skip-link" href="#main-content" data-skip-link> Skip to main content </a>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} MAD LABS. All rights reserved.</p>
    </footer>

    
    <button class="back-to-top" type="button" aria-label="Back to top" data-back-to-top>
      <span class="back-to-top-chevron" aria-hidden="true"></span>
    </button>

    <style>
      .skip-link {
        position: fixed;
        top: 0;
        left: 50%;
        z-index: 100;
        transform: translate(-50%, -100%);
        padding: 0.6rem 1.2rem;
        border-radius: 0 0 6px 6px;
        background: rgba(20, 10, 32, 0.96);
        color: rgba(246, 239, 255, 0.94);
        font-family: "Jersey 25", "VT323", "Courier New", monospace;
        font-size: 0.95rem;
        letter-spacing: 0.06em;
        text-decoration: none;
        text-transform: uppercase;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
        transition: transform 0.2s ease;
      }

      .skip-link:focus {
        transform: translate(-50%, 0);
      }

      .back-to-top {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: 1px solid rgba(247, 158, 85, 0.5);
        border-radius: 50%;
        background: rgba(20, 10, 32, 0.88);
        cursor: pointer;
        opacity: 0;
        visibility: hidden;
        transform: translateY(12px);
        transition:
          opacity 0.3s ease,
          visibility 0.3s ease,
          transform 0.3s ease,
          box-shadow 0.2s ease;
      }

      .back-to-top.is-visible {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }

      .back-to-top:hover {
        box-shadow:
          0 0 16px rgba(247, 158, 85, 0.45),
          0 0 32px rgba(247, 158, 85, 0.18);
      }

      .back-to-top:focus-visible {
        outline: 2px solid rgba(247, 158, 85, 0.86);
        outline-offset: 4px;
      }

      .back-to-top-chevron {
        display: block;
        width: 10px;
        height: 10px;
        border-right: 2px solid rgba(247, 158, 85, 0.85);
        border-top: 2px solid rgba(247, 158, 85, 0.85);
        transform: rotate(-45deg) translate(1px, 2px);
      }
    </style>

    <script>
      const skipLink = document.querySelector<HTMLAnchorElement>("[data-skip-link]");
      const backToTop = document.querySelector<HTMLButtonElement>("[data-back-to-top]");
      const mainContent = document.getElementById("main-content");

      if (skipLink) {
        skipLink.addEventListener("click", (e: Event) => {
          e.preventDefault();
          // Make main content focusable (tabindex is set dynamically
          // to avoid lint warnings on non-interactive <main> in markup).
          if (mainContent) {
            if (mainContent.getAttribute("tabindex") === null) {
              mainContent.setAttribute("tabindex", "-1");
            }
            // Focus main content immediately. The CRT blur transition
            // runs async — it does NOT block focus.
            mainContent.focus();
          }
          // Dispatch to CrtHero to trigger accelerated transition.
          window.dispatchEvent(new CustomEvent("madlabs:skip-intro"));
        });
      }

      if (backToTop) {
        let visible = false;
        let ticking = false;

        const updateBackToTop = (): void => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const shouldShow = window.scrollY > window.innerHeight;
            if (shouldShow !== visible) {
              visible = shouldShow;
              backToTop.classList.toggle("is-visible", visible);
            }
            ticking = false;
          });
        };

        window.addEventListener("scroll", updateBackToTop, { passive: true });

        backToTop.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
  </body>
</html>
